public PaginatedResultInternalDTO<AgencyOfficesResponseEntity> searchWithDynamicQueryAndPagination(
        int page, int pageSize, String sortBy, String sortDir) {

    logger.info("QUERY START - Offset Pagination | Page={}, PageSize={}, SortBy={}, SortDir={}", page, pageSize, sortBy, sortDir);

    long queryStartTime = System.currentTimeMillis();
    List<SqlParameter> parameters = new ArrayList<>();
    List<AgencyOfficesResponseEntity> results = new ArrayList<>();
    double ruCharge = 0;

    // Validate and calculate offset
    int offset = page * pageSize;

    // Build base query
    StringBuilder queryBuilder = new StringBuilder("SELECT * FROM c WHERE 1=1 ");

    // Sorting (validate field and direction outside this method if needed)
    if (StringUtils.isNotBlank(sortBy) && StringUtils.isNotBlank(sortDir)) {
        queryBuilder.append("ORDER BY c.").append(sortBy).append(" ").append(sortDir).append(" ");
    }

    // Add OFFSET and LIMIT
    queryBuilder.append("OFFSET ").append(offset).append(" LIMIT ").append(pageSize);

    SqlQuerySpec querySpec = new SqlQuerySpec(queryBuilder.toString(), parameters);

    // Cosmos query options
    CosmosQueryRequestOptions options = new CosmosQueryRequestOptions();

    logger.debug("Executing Cosmos DB query: {}", querySpec.getQueryText());

    try {
        Iterator<FeedResponse<AgencyOfficesResponseEntity>> iterator = cosmosContainer
                .queryItems(querySpec, options, AgencyOfficesResponseEntity.class)
                .iterableByPage(pageSize)  // ✅ Required to ensure correct page size
                .iterator();

        if (iterator.hasNext()) {
            FeedResponse<AgencyOfficesResponseEntity> response = iterator.next();
            results = response.getResults();
            ruCharge = response.getRequestCharge();
        } else {
            logger.warn("No results found for offset {} (page {})", offset, page);
        }

        long totalTime = System.currentTimeMillis() - queryStartTime;
        logger.info("QUERY END - Items: {}, RU: {}, Time: {} ms", results.size(), ruCharge, totalTime);

        Utils.printListAsJson(results, "Entity results in Repository");

    } catch (Exception e) {
        logger.error("Unexpected error during offset pagination: {}", e.getMessage(), e);
        throw e;
    }

    return new PaginatedResultInternalDTO<>(results);
}