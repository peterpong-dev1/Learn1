4) Service Bus sender (thread‑safe singleton) + send helper

package com.neo.notification.bus;

import com.azure.core.util.BinaryData;
import com.azure.messaging.servicebus.*;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.time.Duration;
import java.util.Map;
import java.util.concurrent.atomic.AtomicReference;
import java.util.logging.Logger;

public final class ServiceBusSenderProvider {
    private static final AtomicReference<ServiceBusSenderClient> SENDER = new AtomicReference<>();
    private static final Object LOCK = new Object();
    private static final ObjectMapper M = new ObjectMapper();

    private ServiceBusSenderProvider() {}

    public static ServiceBusSenderClient get() {
        ServiceBusSenderClient existing = SENDER.get();
        if (existing != null) return existing;

        synchronized (LOCK) {
            existing = SENDER.get();
            if (existing != null) return existing;

            String conn = env("ServiceBusConnection");
            String entity = env("ServiceBusEntity");

            ServiceBusClientBuilder b = new ServiceBusClientBuilder()
                    .connectionString(conn);

            // Decide queue or topic automatically
            ServiceBusSenderClient sender;
            try {
                sender = b.sender()
                         .queueName(entity)
                         .buildClient();
            } catch (Exception ignore) {
                sender = b.sender()
                         .topicName(entity)
                         .buildClient();
            }
            SENDER.set(sender);
            return sender;
        }
    }

    public static void send(EventMessage payload,
                            Map<String,String> appProps,
                            String sessionIdOrNull,
                            Logger log) {
        try {
            byte[] json = M.writeValueAsBytes(payload);
            ServiceBusMessage msg = new ServiceBusMessage(BinaryData.fromBytes(json));
            msg.setMessageId(payload.messageId);
            msg.setCorrelationId(payload.correlationId);
            msg.setContentType("application/json");

            if (sessionIdOrNull != null && Boolean.parseBoolean(env("ServiceBusUseSessions"))) {
                msg.setSessionId(sessionIdOrNull);
            }
            if (appProps != null) {
                appProps.forEach((k,v) -> { if (v != null) msg.getApplicationProperties().put(k, v); });
            }
            String ttlMin = System.getenv("DefaultTtlMinutes");
            if (ttlMin != null && !ttlMin.isBlank()) {
                msg.setTimeToLive(Duration.ofMinutes(Long.parseLong(ttlMin)));
            }

            get().sendMessage(msg);
            log.info("ServiceBus SENT: eventId=" + payload.event.eventId +
                     " docId=" + payload.event.docId +
                     " messageId=" + payload.messageId);
        } catch (Exception ex) {
            log.severe("ServiceBus SEND FAILED: " + ex.getMessage());
            throw new RuntimeException("ServiceBus send failed", ex);
        }
    }

    private static String env(String k) {
        String v = System.getenv(k);
        if (v == null || v.isBlank()) throw new IllegalStateException("Missing app setting: " + k);
        return v;
    }
}


