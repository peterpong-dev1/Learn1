import static org.mockito.Mockito.*;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;
import org.springframework.test.web.servlet.setup.MockMvcBuilders;
import java.util.Collections;
import java.util.List;

@ExtendWith(MockitoExtension.class)
class AgentControllerTest {

    private MockMvc mockMvc;

    @Mock
    private AgentDetailByAgentIdService agentDetailByAgentIdService;

    @InjectMocks
    private AgentController agentController;

    private final ObjectMapper objectMapper = new ObjectMapper();

    @BeforeEach
    void setUp() {
        // ✅ Register Global Exception Handler so that it catches exceptions
        mockMvc = MockMvcBuilders.standaloneSetup(agentController)
                .setControllerAdvice(new GlobalExceptionHandler()) // ✅ Add ControllerAdvice for exception handling
                .build();
    }

    // ✅ 1. Success Case: GET /agents/{agentId}
    @Test
    void testGetAgentByAgentId_Success() throws Exception {
        List<AgentDTO> mockAgents = List.of(new AgentDTO(
                "001", "12345", "CL001", "Admin",
                List.of(new NameDTO("John", "Doe")), true, false, "1990-01-01",
                Gender.MALE, List.of(new PhoneNumberDTO("mobile", "home", "1234567890")),
                List.of(new EmailDTO("john@example.com", true)),
                List.of(new DigitalTouchpointDTO("portalSite", "98765")),
                new SolicitorDTO("emp123", "SOL001", "Legal Advisor"),
                new AgencyDTO("AG001", "10010", "Some Agency"),
                new AgencyOfficeDTO("0000", "Main Office")
        ));

        when(agentDetailByAgentIdService.searchUsingAgentId(eq("12345"), anyMap()))
                .thenReturn(mockAgents);

        mockMvc.perform(get("/agents/12345"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.size()").value(1))
                .andExpect(jsonPath("$[0].agentId").value("12345"))
                .andExpect(jsonPath("$[0].eMail[0].address").value("john@example.com"));

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("12345"), anyMap());
    }

    // ✅ 2. Not Found Case: Service returns empty list
    @Test
    void testGetAgentByAgentId_NotFound() throws Exception {
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("99999"), anyMap()))
                .thenReturn(Collections.emptyList());

        mockMvc.perform(get("/agents/99999"))
                .andExpect(status().isNotFound()); // ✅ Global Exception Handler should catch and return 404

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("99999"), anyMap());
    }

    // ✅ 3. Bad Request: Service throws `IllegalArgumentException`
    @Test
    void testGetAgentByAgentId_BadRequest() throws Exception {
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("invalid"), anyMap()))
                .thenThrow(new IllegalArgumentException("Invalid Agent ID"));

        mockMvc.perform(get("/agents/invalid"))
                .andExpect(status().isBadRequest()) // ✅ Expect 400 Bad Request from Global Exception Handler
                .andExpect(content().string("Invalid Agent ID"));

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("invalid"), anyMap());
    }

    // ✅ 4. Internal Server Error: Service throws `RuntimeException`
    @Test
    void testGetAgentByAgentId_InternalServerError() throws Exception {
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("12345"), anyMap()))
                .thenThrow(new RuntimeException("Simulated Database Failure"));

        mockMvc.perform(get("/agents/12345"))
                .andExpect(status().isInternalServerError()) // ✅ Expect 500 Internal Server Error
                .andExpect(content().string("Internal Server Error"));

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("12345"), anyMap());
    }
}