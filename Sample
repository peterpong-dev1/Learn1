2) MessageFactory (build the JSON payload + ServiceBusMessage)

package com.neo.bus;

import com.azure.messaging.servicebus.ServiceBusMessage;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.nio.charset.StandardCharsets;
import java.time.OffsetDateTime;
import java.util.List;
import java.util.Map;
import java.util.UUID;

/** Builds compact, versioned JSON messages for Service Bus. */
public final class MessageFactory {
    private static final ObjectMapper M = new ObjectMapper();

    private MessageFactory() {}

    /**
     * @param schemaVersion e.g. "1.0"
     * @param correlationId stable ID to trace across services (you define format)
     * @param container     cosmos container name
     * @param docId         document id
     * @param eventId       config-defined event id (e.g., "appInfoProgressManagement:application_submitted")
     * @param eventName     human readable
     * @param when          "insert" | "update"
     * @param changes       list of small maps: {field, old, new}
     * @param context       optional: {_etag,_lsn, readAtUtc ...}
     * @param sessionId     optional: set if you enabled sessions on the entity (often docId)
     */
    public static ServiceBusMessage build(
            String schemaVersion,
            String correlationId,
            String container,
            String docId,
            String eventId,
            String eventName,
            String when,
            List<Map<String, Object>> changes,
            Map<String, Object> context,
            String sessionId
    ) {
        ObjectNode root = M.createObjectNode();
        root.put("schemaVersion", schemaVersion);
        root.put("messageId", UUID.randomUUID().toString()); // good for duplicate detection windows
        root.put("correlationId", correlationId);
        root.put("createdUtc", OffsetDateTime.now().toString());

        ObjectNode ev = root.putObject("event");
        ev.put("container", container);
        ev.put("docId", docId);
        ev.put("eventId", eventId);
        ev.put("eventName", eventName);
        ev.put("when", when);

        if (changes != null && !changes.isEmpty()) {
            var arr = root.putArray("changes");
            for (var c : changes) {
                var n = arr.addObject();
                n.put("field", String.valueOf(c.get("field")));
                n.put("old",  c.get("old") == null ? null : String.valueOf(c.get("old")));
                n.put("new",  c.get("new") == null ? null : String.valueOf(c.get("new")));
            }
        }

        if (context != null && !context.isEmpty()) {
            var ctx = root.putObject("context");
            context.forEach((k,v) -> ctx.put(k, v == null ? null : String.valueOf(v)));
        }

        byte[] body = toBytes(root);
        ServiceBusMessage msg = new ServiceBusMessage(body)
                .setContentType("application/json")
                .setCorrelationId(correlationId);
        // you can also set msg.setMessageId(...) with your own deterministic id if needed
        if (sessionId != null && !sessionId.isBlank()) {
            msg.setSessionId(sessionId);
        }

        // helpful filter headers
        msg.getApplicationProperties().put("container", container);
        msg.getApplicationProperties().put("eventId", eventId);
        msg.getApplicationProperties().put("docId", docId);
        msg.getApplicationProperties().put("when", when);

        return msg;
    }

    private static byte[] toBytes(ObjectNode node) {
        try {
            return M.writeValueAsBytes(node);
        } catch (Exception e) {
            throw new RuntimeException("Failed to serialize message JSON", e);
        }
    }
}


