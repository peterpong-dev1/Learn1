// 0) Common values once
String prepareAt = Instant.now().toString();
List<Map<String,Object>> agents = (List<Map<String,Object>>) fieldsContext.getOrDefault("agents", List.of());

// Back-compat: if no 'agents' array, derive one from single values (optional)
if (agents.isEmpty()) {
  Map<String,Object> single = new LinkedHashMap<>();
  single.put("agentRegistrationNumber", fieldsContext.get("agentRegistrationNumber"));
  single.put("email1", fieldsContext.get("recipient.email"));
  single.put("agencyId", fieldsContext.get("agency.agencyId"));
  single.put("agencyName", fieldsContext.get("agency.agencyName"));
  agents = List.of(single);
}

for (Map<String,Object> a : agents) {
  String arn   = str(a.get("agentRegistrationNumber"));
  String email = str(a.get("email1"));                    // your key names
  String agencyId   = str(a.get("agencyId"));
  String agencyName = str(a.get("agencyName"));

  if (arn == null || arn.isBlank()) { 
    context.getLogger().warning("Skip: missing ARN");
    continue;
  }

  // 1) Allowed-agency check (now per agent)
  boolean allowed = AllowedAgencyValidator.checkIfAgencyAllowedForNotification(
      parsedMessage,
      /* per-agent map to check */ a,
      SKIPPED_NOTALLOWED_LOG_CONTAINER, CONFIG_CONTAINER, ERROR_CONTAINER, DATA_CONTAINER,
      context, CATEGORY);
  if (!allowed) {
    context.getLogger().warning("Skip: agency not allowed for arn=" + arn);
    continue;
  }

  // 2) Build payload JSON (per agent)
  //    Change your builder to accept the per-agent slice *plus* the common fieldsContext
  String json = NotificationPayloadBuilder.buildJsonPerAgent(
      /* common */ fieldsContext,
      /* per-agent */ a,
      parsedMessage,
      context.getLogger(),
      ERROR_CONTAINER, CATEGORY,
      prepareAt
  );
  if (json == null || json.isEmpty()) {
    context.getLogger().severe("Skip: payload build failed for arn=" + arn);
    continue;
  }

  // 3) Table upsert (per agent, per day) – use a composite key!
  //    Example row key: <policyId>#<arn>#<yyyyMMdd>
  boolean tableUpdated = MessageTrackerUpdater.updateTableForLatestProcessing(
      TABLE_CLIENT,
      parsedMessage,
      context,
      CATEGORY,
      json, 
      prepareAt,
      /* rowKeyOverride */ dailyRowKey(fieldsContext, arn) // NEW: add an overload or pass via appProps
  );
  if (!tableUpdated) {
    context.getLogger().severe("Skip sending: table update failed for arn=" + arn);
    continue;
  }

  // 4) Send to Notification API queue (per agent)
  boolean sent = NotificationQueueSender.sendJson(
      SB_SENDER,
      json,
      correlationIdFor(parsedMessage, arn),   // NEW: include arn in correlation for idempotency
      parsedMessage,
      /* appProps */ Map.of("agentRegistrationNumber", arn), // optional
      SB_USE_SESSIONS,
      context, DATA_CONTAINER, ERROR_CONTAINER, CATEGORY
  );
  if (!sent) {
    context.getLogger().severe("Queue send failed for arn=" + arn);
    // optional: continue or break; your choice
  }
}
private static String str(Object o) { return o == null ? null : String.valueOf(o); }

private static String dailyRowKey(Map<String,Object> ctx, String arn) {
  String policyId = str(ctx.get("policyId"));
  String ymd = java.time.LocalDate.now(java.time.ZoneId.of("Asia/Tokyo")).toString(); // 2025-09-20
  return policyId + "#" + arn + "#" + ymd;
}

private static String correlationIdFor(IncomingMessage msg, String arn) {
  return msg.getCorrelationId() + "#" + arn;
}
====

int total = agents.size();
int skippedNotAllowed = 0;  // step 1 "skip"
int buildFails = 0;         // step 2 "fail"
int tableFails = 0;         // step 3 "fail"
int sendFails = 0;          // step 4 "fail"
int successes = 0;          // completed send

for (Map<String,Object> agentCtx : agents) {
    String arn = String.valueOf(agentCtx.get("agentRegistrationNumber"));

    // ---- 1) Allowed-agency check ----
    if (!AllowedAgencyValidator.checkIfAgencyAllowedForNotification(
            parsedMessage, agentCtx,
            SKIPPED_NOTALLOWED_LOG_CONTAINER, CONFIG_CONTAINER,
            ERROR_CONTAINER, DATA_CONTAINER, context, CATEGORY)) {
        skippedNotAllowed++;
        continue; // move to next agent
    }

    // ---- 2) Build payload ----
    String json = NotificationPayloadBuilder.buildJsonPerAgent(
        fieldsContext, agentCtx, parsedMessage, context.getLogger(),
        ERROR_CONTAINER, CATEGORY, prepareAt);
    if (json == null || json.isBlank()) {
        buildFails++;
        continue;
    }

    // ---- 3) Upsert "latest in a day" ----
    boolean tableUpdated = MessageTrackerUpdater.updateTableForLatestProcessing(
        TABLE_CLIENT, parsedMessage, context, CATEGORY, json, prepareAt,
        /* rowKeyOverride if you added one */ null);
    if (!tableUpdated) {
        tableFails++;
        continue;
    }

    // ---- 4) Send ----
    boolean sent = NotificationQueueSender.sendJson(
        SB_SENDER, json, parsedMessage.getCorrelationId() + "#" + arn,
        parsedMessage, Map.of("agentRegistrationNumber", arn),
        SB_USE_SESSIONS, context, DATA_CONTAINER, ERROR_CONTAINER, CATEGORY);
    if (!sent) {
        sendFails++;
        continue;
    }

    successes++;  // made it through all 4 steps
}

// -------- AFTER LOOP: compute overall outcome --------
boolean allSkipped = (skippedNotAllowed == total);  // everyone skipped at step 1
int attempted = total - skippedNotAllowed;          // those that passed step 1
boolean allFailedAfterAllow = (successes == 0) && (attempted > 0) &&
                              ((buildFails + tableFails + sendFails) == attempted);

if (allSkipped) {
    // e.g., update a message/correlation status = ALL_SKIPPED_NOT_ALLOWED
    MessageStatusUpdater.updateStatus(correlationId, "ALL_SKIPPED_NOT_ALLOWED",
        Map.of("total", total, "skippedNotAllowed", skippedNotAllowed));
} else if (allFailedAfterAllow) {
    // none succeeded, but at least one got past step 1
    MessageStatusUpdater.updateStatus(correlationId, "ALL_FAILED",
        Map.of("total", total,
               "buildFails", buildFails,
               "tableFails", tableFails,
               "sendFails", sendFails));
} else if (successes > 0 && (skippedNotAllowed + buildFails + tableFails + sendFails) > 0) {
    // some passed, some didn’t
    MessageStatusUpdater.updateStatus(correlationId, "PARTIAL_SUCCESS",
        Map.of("total", total,
               "successes", successes,
               "skippedNotAllowed", skippedNotAllowed,
               "buildFails", buildFails,
               "tableFails", tableFails,
               "sendFails", sendFails));
} else if (successes == total) {
    // everyone succeeded
    MessageStatusUpdater.updateStatus(correlationId, "ALL_SUCCESS",
        Map.of("total", total));
} else {
    // Edge cases (e.g., total==0)
    MessageStatusUpdater.updateStatus(correlationId, "NO_RECIPIENTS",
        Map.of("total", total));
}
