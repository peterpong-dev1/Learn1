Got it — here’s a cleaned‑up, defensive “S1-style” function that matches what we agreed:
	•	Parse the Cosmos DB change feed safely (treat payload as List<String>).
	•	For each item: parse → extract id → load current blob snapshot (baseline or latest) → compute deltas (only if not CREATE) → optionally decide whether to notify (hook provided) → always persist the snapshot (overwrite id.json; blob versioning will keep history) after you send.
	•	Concurrency: pass the previous ETag to the updater; if it changed, we surface a clear log and let the platform retry.
	•	Lots of guardrails and logs.

package com.neo.notification.function;

import com.azure.storage.blob.BlobContainerClient;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.microsoft.azure.functions.ExecutionContext;
import com.microsoft.azure.functions.annotation.CosmosDBTrigger;
import com.microsoft.azure.functions.annotation.FunctionName;

import java.nio.charset.StandardCharsets;
import java.util.ArrayList;
import java.util.List;
import java.util.logging.Logger;

/**
 * Processes Cosmos DB change feed rows for one logical container.
 *
 * Flow per document:
 *  1) Parse the row defensively (JSON object expected).
 *  2) Extract id.
 *  3) Read current snapshot from Blob (baseline for first time, otherwise latest).
 *  4) If MODIFY, compute deltas of tracked fields (for your message payload).
 *  5) Send message (not shown here; plug your Service Bus sender).
 *  6) Persist snapshot:
 *       - CREATE  -> create id.json if absent (idempotent)
 *       - MODIFY  -> overwrite id.json; Blob Versioning keeps the history
 *
 * Notes:
 *  - This class assumes you already have helpers:
 *      BlobClientProvider.container(...),
 *      GetBlob.getCurrentBlob(...),
 *      TrackedChangeHandler.processChanges(...),
 *      CreateBlob.createBlobIfCreateEvent(...),
 *      UpdateBlob.overwriteWithVersioning(...)
 *  - We treat every exception per-document so one bad row doesn’t block the batch.
 */
public class NeoNotificationTriggerFunction {

  private static final ObjectMapper MAPPER = new ObjectMapper();

  private static final String CONFIG_CONTAINER_NAME =
      System.getenv("Blob_ContainerName_Config");
  private static final String DATA_CONTAINER_NAME =
      System.getenv("Blob_ContainerName_Data");

  // Safe singletons for clients
  private static final BlobContainerClient CONFIG_CONTAINER =
      BlobClientProvider.container(CONFIG_CONTAINER_NAME);
  private static final BlobContainerClient DATA_CONTAINER =
      BlobClientProvider.container(DATA_CONTAINER_NAME);

  @FunctionName("NeoCosmosChangeFeedTrigger")
  public void run(
      @CosmosDBTrigger(
          name = "docs",
          databaseName = "%DatabaseName_1%",
          containerName = "%ContainerNameToTrack_1%",
          leaseContainerName = "%LeaseContainer_1%",
          leaseDatabaseName = "%DatabaseName_1%",
          createLeaseContainerIfNotExists = true,
          connection = "CosmosDBConnection")
      List<String> documents,
      final ExecutionContext context) {

    final Logger log = context.getLogger();

    if (documents == null || documents.isEmpty()) {
      log.info("Change feed batch is empty; nothing to do.");
      return;
    }

    // Load tracked fields from config (your existing helper)
    final String cosmosContainerName = System.getenv("ContainerNameToTrack_1");
    List<String> fieldsToTrack = NeoGetTrackedFieldsFromBlob.getTrackedFields(
        CONFIG_CONTAINER, cosmosContainerName, log);
    if (fieldsToTrack == null) fieldsToTrack = List.of();

    log.info("Batch size=" + documents.size() + ", trackedFields=" + fieldsToTrack.size());

    for (int i = 0; i < documents.size(); i++) {
      final int idx = i;
      try {
        // ---- 1) Parse defensively
        String raw = documents.get(i);
        if (raw == null || raw.isBlank()) {
          log.warning("Doc[" + idx + "] is null/blank; skipping.");
          continue;
        }

        JsonNode node = MAPPER.readTree(raw);
        if (node == null || !node.isObject()) {
          log.warning("Doc[" + idx + "] is not a JSON object; skipping. Raw len=" + raw.length());
          continue;
        }
        ObjectNode newDoc = (ObjectNode) node;

        // ---- 2) Extract id (null-safe)
        String id = newDoc.path("id").asText(null);
        if (id == null || id.isBlank()) {
          log.warning("Doc[" + idx + "] missing 'id'; skipping.");
          continue;
        }

        // ---- 3) Load current snapshot from Blob
        ResultWrapperForBlob current = GetBlob.getCurrentBlob(
            DATA_CONTAINER, cosmosContainerName, id, log);

        boolean isCreate = current.isCreate();
        ObjectNode baseline = current.json(); // may be null only for CREATE
        String previousETag = current.eTag(); // may be null on first create

        // ---- 4) Compute deltas when MODIFY (tracked fields only)
        List<ChangeInfo> deltas = new ArrayList<>();
        if (!isCreate && !fieldsToTrack.isEmpty()) {
          deltas = TrackedChangeHandler.processChanges(
              cosmosContainerName, newDoc, DATA_CONTAINER, fieldsToTrack, baseline, log);
        }

        // ---- 5) Build/send your message (CREATE vs MODIFY)
        String eventType = isCreate ? "CREATE" : "MODIFY";
        if (isCreate || !deltas.isEmpty()) {
          // TODO: call your Service Bus sender here
          // busSender.send(MessageFactory.build(newDoc, baseline, eventType, cosmosContainerName, deltas));
          log.info("Doc[" + idx + "] id=" + id + " sending eventType=" + eventType
              + " (deltas=" + deltas.size() + ")");
        } else {
          log.info("Doc[" + idx + "] id=" + id + " has no tracked changes; no message.");
        }

        // ---- 6) Persist snapshot ALWAYS (after send)
        if (isCreate) {
          // idempotent create (If-None-Match="*")
          CreateBlob.createBlobIfCreateEvent(DATA_CONTAINER, cosmosContainerName, id, newDoc, log);
        } else {
          // optimistic overwrite using previous ETag (avoid lost update)
          UpdateBlob.overwriteWithVersioning(
              DATA_CONTAINER, cosmosContainerName, id, newDoc, previousETag, log);
        }

      } catch (com.fasterxml.jackson.core.JsonProcessingException jp) {
        log.severe("Doc[" + idx + "] JSON parse error: " + jp.getMessage());
        // continue next doc
      } catch (IllegalStateException ise) {
        // e.g., your helpers can throw on unexpected states
        log.severe("Doc[" + idx + "] invalid state: " + ise.getMessage());
      } catch (RuntimeException re) {
        // Blob/Cosmos transient issues bubble up as runtime in your helpers
        log.severe("Doc[" + idx + "] runtime error: " + re.getMessage());
        // Let the platform retry the whole batch if you prefer:
        // throw re;
        // For now, continue next doc so one bad row doesn't block the batch.
      } catch (Exception ex) {
        log.severe("Doc[" + idx + "] unexpected error: " + ex.getMessage());
      }
    }
  }
}

Why this matches the plan
	•	Final‑state reasoning (S1): deltas are used only to enrich the message; decision to persist is independent — we always overwrite the snapshot (Blob Versioning keeps history automatically).
	•	CREATE is idempotent: the helper should use If-None-Match="*"; “already exists” is success.
	•	MODIFY is race‑safe: pass the previous ETag to your updater; if someone else already overwrote, you’ll get a 412 and your helper can log/throw so the Function runtime retries with fresh state.
	•	Defensive feed handling: the trigger can hand you non‑objects/odd rows; we bail fast and keep processing the rest.

