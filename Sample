got it—you want just the “compute delta” piece: compare only the tracked fields from your config between newDoc (from change feed) and oldSnap (from Blob), including support for nested paths like address.city or items[0].name. Here’s a tight, productiony utility you can drop in.

Change model

public final class ChangeDelta {
    public enum Kind { ADDED, REMOVED, MODIFIED }

    private final String fieldPath;      // e.g., "address.city"
    private final JsonNode oldValue;     // may be null
    private final JsonNode newValue;     // may be null
    private final Kind kind;

    public ChangeDelta(String fieldPath, JsonNode oldValue, JsonNode newValue, Kind kind) {
        this.fieldPath = fieldPath;
        this.oldValue  = oldValue;
        this.newValue  = newValue;
        this.kind      = kind;
    }

    public String  getFieldPath() { return fieldPath; }
    public JsonNode getOldValue() { return oldValue; }
    public JsonNode getNewValue() { return newValue; }
    public Kind     getKind()     { return kind; }

    @Override public String toString() {
        return "ChangeDelta{" + fieldPath + ", " + kind + ", old=" + oldValue + ", new=" + newValue + "}";
    }
}

Delta calculator (only tracked fields)

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.node.MissingNode;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.util.*;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public final class TrackedDelta {

    private TrackedDelta() {}

    /**
     * Compare only the tracked field paths and return deltas.
     * Paths support dots and array indexes, e.g.:
     *   "address.city", "policy.status.code", "items[0].name", "lines[2].amount.value"
     *
     * @param newDoc       full latest document from change feed
     * @param oldDoc       snapshot from Blob (may be null or empty)
     * @param trackedPaths list of field paths to compare
     */
    public static List<ChangeDelta> compute(ObjectNode newDoc,
                                            ObjectNode oldDoc,
                                            List<String> trackedPaths) {
        Objects.requireNonNull(newDoc, "newDoc");
        if (trackedPaths == null || trackedPaths.isEmpty()) return Collections.emptyList();

        final ObjectNode safeOld = oldDoc == null ? newDoc.objectNode() : oldDoc;
        final List<ChangeDelta> out = new ArrayList<>(trackedPaths.size());

        for (String path : trackedPaths) {
            if (path == null || path.isBlank()) continue;

            JsonNode newVal = getByPath(newDoc, path);
            JsonNode oldVal = getByPath(safeOld, path);

            boolean newMissing = isMissingOrNull(newVal);
            boolean oldMissing = isMissingOrNull(oldVal);

            if (oldMissing && newMissing) {
                // both absent/null → no delta
                continue;
            } else if (oldMissing && !newMissing) {
                out.add(new ChangeDelta(path, null, newVal, ChangeDelta.Kind.ADDED));
            } else if (!oldMissing && newMissing) {
                out.add(new ChangeDelta(path, oldVal, null, ChangeDelta.Kind.REMOVED));
            } else if (!jsonDeepEquals(oldVal, newVal)) {
                out.add(new ChangeDelta(path, oldVal, newVal, ChangeDelta.Kind.MODIFIED));
            }
        }
        return out;
    }

    /* -------------------- helpers -------------------- */

    // Accepts dot + [index] segments: a.b[0].c
    private static final Pattern SEGMENT = Pattern.compile("(\\w+)(\\[(\\d+)])?");

    /** Navigate by a dotted/Indexed path. Returns MissingNode if not found. */
    private static JsonNode getByPath(JsonNode root, String path) {
        if (root == null || root.isMissingNode() || root.isNull()) return MissingNode.getInstance();

        String[] parts = path.split("\\.");
        JsonNode cur = root;

        for (String raw : parts) {
            Matcher m = SEGMENT.matcher(raw);
            if (!m.matches()) return MissingNode.getInstance(); // invalid segment

            String field = m.group(1);
            String indexStr = m.group(3);

            cur = cur.get(field);
            if (cur == null) return MissingNode.getInstance();

            if (indexStr != null) {
                if (!cur.isArray()) return MissingNode.getInstance();
                int idx = Integer.parseInt(indexStr);
                if (idx < 0 || idx >= cur.size()) return MissingNode.getInstance();
                cur = cur.get(idx);
            }
        }
        return cur == null ? MissingNode.getInstance() : cur;
    }

    /** Treat MissingNode OR explicit null as “missing” for change semantics. */
    private static boolean isMissingOrNull(JsonNode n) {
        return n == null || n.isMissingNode() || n.isNull();
    }

    /** Deep structural equality, tolerant to numeric 1 vs 1.0 differences. */
    private static boolean jsonDeepEquals(JsonNode a, JsonNode b) {
        if (a == b) return true;
        if (a == null || b == null) return false;

        // Normalize numbers to string form to avoid 1 vs 1.0 surprises
        if (a.isNumber() && b.isNumber()) {
            return a.decimalValue().compareTo(b.decimalValue()) == 0;
        }
        return a.equals(b);
    }
}

How you call it in your handler

// inside your TrackedChangeHandler.detectChanges(...)
ObjectNode newDoc = incoming;          // from change feed
ObjectNode oldDoc = oldSnapshotObject; // from blob (null if none)
List<String> tracked = fieldsToTrack;  // from config JSON

List<ChangeDelta> deltas = TrackedDelta.compute(newDoc, oldDoc, tracked);

// now you can build your Service Bus message from `deltas`

Notes
	•	Only tracked paths are checked—everything else is ignored.
	•	Works for nested and indexed fields.
	•	Treats “missing vs null” as meaningful (ADDED/REMOVED).
	•	Returns a small, clean ChangeDelta list you can serialize straight into your message payload.

