// imports you likely already have:
import com.azure.storage.blob.BlobContainerClient;
import com.azure.storage.blob.BlobServiceClientBuilder;
import com.neo.notification.config.EventConfig;
import com.neo.notification.config.EventConfigLoader;

// --- somewhere near your static initialization (re-using what you already set up) ---
private static final String CONFIG_CONTAINER_NAME =
        System.getenv("Blob_ContainerName_Config"); // you already use this name
private static final BlobContainerClient CONFIG_CONTAINER =
        new BlobServiceClientBuilder()
            .connectionString(System.getenv("AzureWebJobsStorage"))
            .buildClient()
            .getBlobContainerClient(CONFIG_CONTAINER_NAME);

// --- inside your run(...) method, before you evaluate anything ---
final Logger log = context.getLogger();

String cosmosDbContainerName = System.getenv("ContainerNameToTrack_1");
if (cosmosDbContainerName == null || cosmosDbContainerName.isBlank()) {
    log.severe("CUSTOM ERROR: env 'ContainerNameToTrack_1' is missing/blank.");
    return; // nothing we can do
}

// Convention: one rules file per Cosmos container, e.g. "appInfoProgressManagement_events.json"
String rulesBlobName = cosmosDbContainerName + "_events.json";

// Load the event rules (no caching as per your request)
EventConfig rules = EventConfigLoader.loadFromBlob(CONFIG_CONTAINER, rulesBlobName, log);
if (rules == null) {
    log.severe("No event rules loaded; aborting this invocation.");
    return;
}

log.info("Loaded " + rules.events.size() + " event rule(s) for container: " + rules.container);

// …now pass `rules` to your evaluator/notification logic as you already planned.

