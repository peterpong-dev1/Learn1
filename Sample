5. Updating the DTO to Convert Epoch Back to Date

Since Cosmos DB stores calendarDay as epoch, we need to convert it back to a yyyy-MM-dd formatted date before returning the response.

package com.example.calendar.dto;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

import java.time.Instant;
import java.time.LocalDate;
import java.time.ZoneId;

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Calender {
    private String id;
    private long calendarDay; // Stores epoch milliseconds in DB
    private boolean businessDayFlag;

    public String getCalendarDayAsDate() {
        return LocalDate.ofInstant(Instant.ofEpochMilli(this.calendarDay), ZoneId.systemDefault()).toString();
    }
}

6. Updating CalendarMapper to Handle Epoch-to-Date Conversion

When converting database results into response DTOs, we must convert epoch milliseconds into formatted dates.

package com.example.calendar.mapper;

import com.example.calendar.dto.Calender;
import com.example.calendar.entity.CalenderEntity;
import java.util.List;
import java.util.stream.Collectors;

public class CalendarMapper {
    
    public static CalenderEntity toEntity(Calender dto) {
        return new CalenderEntity(dto.getId(), dto.getCalendarDay(), dto.isBusinessDayFlag());
    }

    public static Calender toDto(CalenderEntity entity) {
        return new Calender(entity.getId(), entity.getCalendarDay(), entity.isBusinessDayFlag());
    }

    public static List<Calender> toDtoList(List<CalenderEntity> entities) {
        return entities.stream().map(CalendarMapper::toDto).collect(Collectors.toList());
    }
}

