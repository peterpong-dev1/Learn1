paths:
  /v1/agency/office:
    get:
      summary: Search agency offices
      parameters:
        - name: X-Request-ID
          in: header
          required: true
          description: Correlation ID for request tracing
          schema:
            type: string

        - name: page
          in: query
          required: false
          description: Page number (1-based)
          schema:
            type: integer
            minimum: 1

        - name: limit
          in: query
          required: false
          description: Number of items per page
          schema:
            type: integer
            minimum: 1

        - name: sortBy
          in: query
          required: false
          description: Field to sort by
          schema:
            type: string

        - name: sortDir
          in: query
          required: false
          description: Sort direction (ASC or DESC)
          schema:
            type: string
            enum: [ASC, DESC]

      responses:
        '200':
          description: Successful agency search
          headers:
            X-Page:
              description: Current page number
              schema:
                type: integer

            X-Limit:
              description: Limit used for pagination
              schema:
                type: integer

            X-Returned-Count:
              description: Number of items returned in this response
              schema:
                type: integer

          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgencyOfficesSearchResponse'