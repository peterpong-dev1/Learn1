package jp.co.neofirst.api.common.dto;

import com.fasterxml.jackson.annotation.JsonInclude;
import lombok.AllArgsConstructor;
import lombok.Getter;
import lombok.NoArgsConstructor;
import lombok.Setter;

import javax.validation.Valid;
import javax.validation.constraints.NotBlank;
import javax.validation.constraints.NotNull;
import java.util.Map;

/**
 * Incoming Notification request payload.
 * - placeholders is dynamic (Map<String,Object>)
 * - metadata is optional but recommended for tracing
 */
@Getter @Setter
@AllArgsConstructor @NoArgsConstructor
@JsonInclude(JsonInclude.Include.NON_NULL)
public class NotificationRequest {
    @NotBlank private String notificationType;   // newBusiness | transaction | policyMaintenance | unpaid
    @NotBlank private String triggerType;        // established | received | ...
    @NotBlank private String messageType;        // email | sms | line
    @NotBlank private String language;           // ja | en | ...

    private String applicationId;                // required conditionally
    private String policyId;                     // required conditionally

    @NotNull @Valid private Recipient recipient;
    @NotNull @Valid private Agency agency;

    private Map<String, Object> placeholders;    // dynamic key/value for template merge
    @Valid private Metadata metadata;            // tracing / extra info
}

