✅ 3. Mapper Layer (Model ↔ DTO)

📌 AddressMapper.java

package jp.co.neofirst.servicing.mapper;

import jp.co.neofirst.servicing.dto.AddressDTO;
import jp.co.neofirst.servicing.dto.AddressDetailsDTO;
import jp.co.neofirst.servicing.model.AddressModel;
import jp.co.neofirst.servicing.model.AddressDetailsModel;
import org.springframework.stereotype.Component;
import java.util.List;
import java.util.stream.Collectors;

/**
 * Mapper class to convert between AddressModel and AddressDTO.
 */
@Component
public class AddressMapper {

    public AddressDTO toDTO(AddressModel model) {
        AddressDTO dto = new AddressDTO();
        dto.setId(model.getId());
        dto.setAddressCode(model.getAddressCode());
        dto.setAddress(model.getAddress().stream()
                .map(this::toDetailsDTO)
                .collect(Collectors.toList()));
        return dto;
    }

    private AddressDetailsDTO toDetailsDTO(AddressDetailsModel model) {
        AddressDetailsDTO dto = new AddressDetailsDTO();
        dto.setCharacterSetType(model.getCharacterSetType());
        dto.setPostalCode(model.getPostalCode());
        dto.setCountry(model.getCountry());
        dto.setPrefecture(model.getPrefecture());
        dto.setCity(model.getCity());
        dto.setTown(model.getTown());
        dto.setLane(model.getLane());
        dto.setEffectiveDate(model.getEffectiveDate());
        dto.setTerminationDate(model.getTerminationDate());
        return dto;
    }
}

