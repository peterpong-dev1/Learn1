public void simulateTokenPaginationPerformance(int targetPage, int pageSize, String sortBy, String sortDir) {
    String continuationToken = null;
    double totalRU = 0;
    long totalStartTime = System.currentTimeMillis();

    CosmosQueryRequestOptions options = new CosmosQueryRequestOptions();

    for (int currentPage = 1; currentPage <= targetPage; currentPage++) {
        long pageStart = System.currentTimeMillis();

        PaginatedResultInternalDTO<AgencyOfficesResponseEntity> page =
                searchWithDynamicQueryAndPagination(continuationToken, pageSize, sortBy, sortDir, options);

        continuationToken = page.getContinuationToken();

        // Optional: short-circuit if data ends before reaching target
        if (page.getItems().isEmpty() || continuationToken == null) {
            logger.warn("Reached end of data before page {}", currentPage);
            break;
        }

        logger.info("Page {} => Results: {}, Time: {}ms", currentPage, page.getItems().size(),
                (System.currentTimeMillis() - pageStart));

        // Approx RU tracking (assuming you log or return RU per page — otherwise, you can estimate)
        // Add a `getRuCharge()` to your DTO if needed for exact accumulation.
    }

    logger.info("==== TOKEN PAGINATION PERFORMANCE ====");
    logger.info("Pages Fetched: {}", targetPage);
    logger.info("Total Time (ms): {}", System.currentTimeMillis() - totalStartTime);
    logger.info("Total RU Consumed: {}", totalRU); // fill if exact tracking needed
}