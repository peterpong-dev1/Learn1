package com.yourorg.messageapi.service;

import com.fasterxml.jackson.databind.JsonNode;
import com.yourorg.messageapi.model.IncomingMessage;
import com.yourorg.messageapi.util.JsonUtil;

import java.util.logging.Logger;

/**
 * Parses raw Service Bus body into IncomingMessage.
 * Always validate minimal required fields here.
 */
public final class ParserService {
    private ParserService(){}

    public static IncomingMessage parse(String body, Logger log) {
        try {
            JsonNode root = JsonUtil.M().readTree(body);

            // Minimal validation (extend as needed)
            if (root == null || !root.hasNonNull("event") || !root.hasNonNull("ids")) {
                log.warning("ParserService: body missing 'event' or 'ids'");
                return null;
            }

            IncomingMessage msg = new IncomingMessage();
            // ids
            JsonNode ids = root.path("ids");
            msg.setMessageId(ids.path("messageId").asText(null));
            msg.setCorrelationId(ids.path("correlationId").asText(null));

            // event
            JsonNode ev = root.path("event");
            msg.setContainer(ev.path("container").asText(null));
            msg.setDocId(ev.path("docId").asText(null));
            msg.setEventId(ev.path("eventId").asText(null));
            msg.setEventName(ev.path("eventName").asText(null));
            msg.setWhen(ev.path("when").asText(null));
            msg.setProducedAtEpochMs(ev.path("producedAtEpochMs").asLong(0));

            // payload (optional)
            msg.setNewDoc(root.path("newDoc").isMissingNode() ? null : root.path("newDoc"));
            msg.setChanges(root.path("changes").isMissingNode() ? null : root.path("changes"));

            // Basic sanity
            if (msg.getCorrelationId() == null || msg.getEventId() == null || msg.getDocId() == null) {
                log.warning("ParserService: required id fields missing");
                return null;
            }
            return msg;
        } catch (Exception e) {
            log.severe("ParserService error: " + e.getMessage());
            return null;
        }
    }
}


