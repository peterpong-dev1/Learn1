final ObjectMapper M = new ObjectMapper();
ObjectNode extracted = M.createObjectNode();

// Copy simple extracted fields (skip agencies; we’ll handle them separately)
for (Map.Entry<String,String> e : event.extractedFields.entrySet()) {
    String name = e.getKey();
    String ptr  = e.getValue();
    if ("agencies".equals(name)) continue;              // skip array
    if (ptr == null || ptr.isEmpty() || ptr.charAt(0) != '/') continue;

    JsonNode v = newDoc.at(ptr);
    if (v != null && !v.isMissingNode() && !v.isNull()) {
        extracted.set(name, v.isValueNode() ? M.valueToTree(v.asText()) : v);
    }
}

// Collect ALL agentRegistrationNumbers
ArrayNode arnArray = M.createArrayNode();
Set<String> seen = new HashSet<>();
JsonNode agenciesNode = newDoc.at("/agency");
if (agenciesNode != null && agenciesNode.isArray()) {
    for (JsonNode a : agenciesNode) {
        String arn = a.path("agentRegistrationNumber").asText(null);
        if (arn == null || arn.isBlank()) continue;
        if (!seen.add(arn)) continue;                  // dedupe
        arnArray.add(arn);
    }
}
extracted.set("agentRegistrationNumbers", arnArray);   // ✅ add the array

// Build the message
ObjectNode msg = M.createObjectNode();
msg.put("eventId", event.id);
msg.put("eventName", event.name);
msg.put("container", event.container);
msg.put("notificationType", event.notificationType);
msg.put("triggerType", event.triggerType);
msg.set("extracted", extracted);

enqueueToServiceBus(msg);