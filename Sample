{
  "version": "1.0",
  "container": "appInfoProgressManagement",
  "events": [
    {
      "id": "appInfoProgressManagement_application_submitted",
      "name": "Application Submitted",
      "when": ["insert", "update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "eq", "field": "applicationStatus", "value": "1" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_application_amended",
      "name": "Application Amended",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "becameNotNull", "field": "applicationAmendmentDate" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_application_cancelled",
      "name": "Application Cancelled",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "applicationCancelDate" },
          { "op": "changedTo", "field": "applicationStatus", "value": "9" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_status_updated",
      "name": "Status Updated",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "changed", "field": "applicationStatus" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_payment_received",
      "name": "Payment Received",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "changedTo", "field": "newBusinessDepositStatus", "value": "2" },
          { "op": "becameNotNull", "field": "firstReceiptDate" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_deficiency_notification_sent",
      "name": "Deficiency Notification Sent",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "errorCode" },
          { "op": "becameNotNull", "field": "deficiencyNotificationSentDate" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_deficiency_resolved",
      "name": "Deficiency Resolved",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "becameNotNull", "field": "deficiencyResolutionDate" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_decision_notification_sent",
      "name": "Decision Notification Sent",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "decisionNotificationSentDate" },
          { "op": "becameNotNull", "field": "decisionNotificationDetails" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_policy_issued",
      "name": "Policy Issued",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "issueDate" },
          { "op": "becameNotNull", "field": "policyId" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_policy_pending",
      "name": "Policy Pending",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "pendingStatus" },
          { "op": "becameNotNull", "field": "issuePendingDate" }
        ]
      }
    },
    {
      "id": "appInfoProgressManagement_policy_cancelled",
      "name": "Policy Cancelled",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "becameNotNull", "field": "issueCancelDate" }
        ]
      }
    }
  ]
}