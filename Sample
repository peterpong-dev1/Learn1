2) EventProcessing.evaluate(…)

Add the early guard right at the top of your existing method.

public static boolean evaluate(EventConfig.Event evt,
                               boolean isCreate,
                               ObjectNode newDoc,
                               ObjectNode baseline,
                               List<ChangeInfo> deltas) {

  // --- NEW: honor the event's "when" filter ---
  if (isCreate && !evt.allowInsert()) return false; // not allowed on insert
  if (!isCreate && !evt.allowUpdate()) return false; // not allowed on update
  // --------------------------------------------

  // (keep the rest exactly as you have it)
  Map<String, ChangeInfo> idx = indexByFieldPath(deltas);

  boolean hasAny = false;
  boolean allOk = true;

  for (EventConfig.Rule r : evt.conditions.rules) {
    boolean hit = evalRule(r, isCreate, newDoc, baseline, idx);
    hasAny |= hit;
    allOk  &= hit;

    if (evt.conditions.isOr()  && hit)  return true;   // OR short‑circuit
    if (evt.conditions.isAnd() && !hit) return false;  // AND short‑circuit
  }

  if (evt.conditions.rules == null || evt.conditions.rules.isEmpty()) return false;
  return evt.conditions.isAnd() ? allOk : hasAny;
}

Nothing else in evalRule(...) or your delta helpers needs to change.

