Example usage (inside your Function or service)

// You already build this elsewhere; pass it in:
BlobContainerClient container = /* your code to create client */;

// Create resolver (basePath = "templates/")
TemplateResolver resolver = new TemplateResolver(container, "templates");

// Resolve + load
TemplateResolver.TemplateDocument tpl = resolver.resolveAndLoad(
        parsed.getNotificationType(),  // e.g., "newBusiness"
        parsed.getTriggerType(),       // e.g., "established"
        parsed.getAgencyId(),          // e.g., "pru001" or null → default
        parsed.getLanguage(),          // e.g., "ja-JP"
        parsed.getMessageType()        // e.g., "email"
);

// Hand off to your email service
String subject = tpl.getSubject();     // may be null if plain-text template
String html    = tpl.getBodyHtml();    // may be null
String text    = tpl.getBodyText();    // guaranteed if plain-text; optional for JSON
Map<String,Object> extras = tpl.getExtras(); // optional hints


