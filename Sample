1) RestClientConfig.java — Bean

package your.pkg.config;

import org.springframework.boot.web.client.RestTemplateBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.web.client.RestTemplate;

import java.time.Duration;

/**
 * Provides a shared RestTemplate bean with conservative production defaults.
 * Thread-safe to reuse across services.
 */
@Configuration
public class RestClientConfig {

    @Bean
    public RestTemplate restTemplate(RestTemplateBuilder builder) {
        return builder
                .setConnectTimeout(Duration.ofSeconds(3))  // TCP connect timeout
                .setReadTimeout(Duration.ofSeconds(10))    // server response timeout
                .build();
    }
}


