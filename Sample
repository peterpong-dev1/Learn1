package com.example.notification;

import com.azure.core.util.BinaryData;
import com.azure.storage.blob.*;
import com.azure.storage.blob.models.BlobDownloadContentResponse;
import com.azure.storage.blob.models.BlobStorageException;
import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.*;
import java.util.concurrent.atomic.AtomicReference;
import java.util.logging.Level;
import java.util.logging.Logger;

/**
 * Thread-safe class that loads a list of allowed agency IDs from Azure Blob Storage
 * and provides validation logic.
 */
public class AllowedAgencyValidator {

    private static final Logger logger = Logger.getLogger(AllowedAgencyValidator.class.getName());
    private static final ObjectMapper objectMapper = new ObjectMapper();

    // AtomicReference ensures visibility and safe concurrent reads
    private final AtomicReference<Set<String>> allowedAgenciesRef = new AtomicReference<>(Set.of());

    /**
     * Loads allowed agencies from the blob file.
     *
     * Expected blob JSON format:
     * {
     *   "allowedAgencies": ["AGENCY001", "AGENCY002", ...]
     * }
     *
     * @param blobClient BlobClient pointing to the JSON blob
     */
    public AllowedAgencyValidator(BlobClient blobClient) {
        loadAllowedAgencies(blobClient);
    }

    /**
     * Reloads the allowed agencies set from blob and stores it in an atomic reference.
     * Can be called periodically if dynamic refresh is required.
     *
     * @param blobClient BlobClient instance pointing to allowed-agencies.json
     */
    public void loadAllowedAgencies(BlobClient blobClient) {
        try {
            BlobDownloadContentResponse content = blobClient.downloadContent();
            String json = content.getContent().toString();

            Map<String, List<String>> map = objectMapper.readValue(json, new TypeReference<>() {});
            List<String> agencyList = map.getOrDefault("allowedAgencies", List.of());

            // Safely update the reference to new data
            allowedAgenciesRef.set(Collections.unmodifiableSet(new HashSet<>(agencyList)));

            logger.info("Allowed agencies loaded: " + agencyList.size());

        } catch (Exception e) {
            logger.log(Level.SEVERE, "Error loading allowed agencies from blob", e);
            // Leave the previous list intact if error occurs
        }
    }

    /**
     * Validates whether a given agency is in the allowed list.
     * If not allowed, logs and optionally stores the rejected event to blob.
     *
     * @param agencyId            The agency ID to validate
     * @param eventJson           The full JSON payload of the event (for logging)
     * @param fallbackBlobClient  Optional: blob to store rejected event if agency not allowed
     * @return true if agency is allowed, false otherwise
     */
    public boolean isAgencyAllowed(String agencyId, String eventJson, BlobClient fallbackBlobClient) {
        if (!allowedAgenciesRef.get().contains(agencyId)) {
            logger.warning("Rejected event: unauthorized agencyId = " + agencyId);
            if (fallbackBlobClient != null) {
                try {
                    fallbackBlobClient.upload(BinaryData.fromString(eventJson), true);
                } catch (BlobStorageException e) {
                    logger.log(Level.SEVERE, "Failed to write rejected event to fallback blob", e);
                }
            }
            return false;
        }
        return true;
    }
}