package jp.co.mycompany.servicing.controller;

import jp.co.mycompany.servicing.dto.FinancialInstitutionDTO;
import jp.co.mycompany.servicing.dto.FinancialInstitutionSearchConditionsDTO;
import jp.co.mycompany.servicing.service.FinancialInstitutionService;
import jp.co.mycompany.servicing.util.LogUtil;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.ResponseEntity;

import java.util.Collections;
import java.util.List;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class FinancialInstitutionControllerTest {

    @Mock
    private FinancialInstitutionService financialInstitutionService;

    @InjectMocks
    private FinancialInstitutionController financialInstitutionController;

    private FinancialInstitutionSearchConditionsDTO searchConditions;
    private FinancialInstitutionDTO financialInstitutionDTO;

    @BeforeEach
    void setUp() {
        // Populate all fields in searchConditions
        searchConditions = new FinancialInstitutionSearchConditionsDTO();
        searchConditions.setFinancialInstitutionCode("123");
        searchConditions.setFinancialInstitutionBranchCode("001");
        searchConditions.setName("XYZ Bank");
        searchConditions.setOrderCode("ORD001");
        searchConditions.setNameKana("KanaXYZ");

        // Populate all fields in financialInstitutionDTO
        financialInstitutionDTO = new FinancialInstitutionDTO();
        financialInstitutionDTO.setFinancialInstitutionCode("123");
        financialInstitutionDTO.setFinancialInstitutionBranchCode("001");
        financialInstitutionDTO.setName("XYZ Bank");
        financialInstitutionDTO.setOrderCode("ORD001");
        financialInstitutionDTO.setNameKana("KanaXYZ");
    }

    /**
     * ✅ Test: When valid input is provided, should return a list of financial institutions.
     */
    @Test
    void testSearchFinancialInstitutions_Success() {
        List<FinancialInstitutionDTO> expectedResults = Collections.singletonList(financialInstitutionDTO);
        when(financialInstitutionService.searchInstitutions(any())).thenReturn(expectedResults);

        ResponseEntity<List<FinancialInstitutionDTO>> response = financialInstitutionController.searchFinancialInstitutions(searchConditions);

        assertEquals(200, response.getStatusCodeValue());
        assertEquals(1, response.getBody().size());
        assertEquals("XYZ Bank", response.getBody().get(0).getName());
        verify(financialInstitutionService, times(1)).searchInstitutions(any());
    }

    /**
     * ✅ Test: When no matching results are found, should return an empty list.
     */
    @Test
    void testSearchFinancialInstitutions_NoResults() {
        when(financialInstitutionService.searchInstitutions(any())).thenReturn(Collections.emptyList());

        ResponseEntity<List<FinancialInstitutionDTO>> response = financialInstitutionController.searchFinancialInstitutions(searchConditions);

        assertEquals(200, response.getStatusCodeValue());
        assertEquals(0, response.getBody().size());
        verify(financialInstitutionService, times(1)).searchInstitutions(any());
    }

    /**
     * ✅ Test: When the service throws an exception, should handle it properly.
     */
    @Test
    void testSearchFinancialInstitutions_ExceptionHandling() {
        when(financialInstitutionService.searchInstitutions(any())).thenThrow(new RuntimeException("Internal Server Error"));

        try {
            financialInstitutionController.searchFinancialInstitutions(searchConditions);
        } catch (Exception e) {
            assertEquals("Internal Server Error", e.getMessage());
        }

        verify(financialInstitutionService, times(1)).searchInstitutions(any());
    }
}