@startuml
start

:Client Sends API Request;
if (Filter Enabled?) then (Yes)
    :Extract Request ID & Log Input Fields;
    :Pass Request to Controller;
endif

:Controller Receives API Request;
if (Is Request Valid?) then (Yes)
    :Convert DTO to Model;
    :Call Service Layer;
else (No)
    :Return 400 Bad Request;
    stop
endif

:Service Layer Executes Business Logic;
:Call Repository Layer;

if (DB Query Success?) then (Yes)
    :Save Data in CosmosDB;
    :Return 201 Created Response;
else (No)
    :Return 500 Internal Server Error;
    stop
endif

:Log API Response;
stop
@enduml