✅ Implementing Error Handling Without Lombok

Since you don’t want to use Lombok, we will manually create constructors, getters, and setters instead.

📌 Step 1: Define ErrorDetailDTO

This class stores field-specific validation errors.

package jp.co.mycompany.servicing.dto;

import java.io.Serializable;

public class ErrorDetailDTO implements Serializable {
    private String field;
    private String issue;

    public ErrorDetailDTO() {
    }

    public ErrorDetailDTO(String field, String issue) {
        this.field = field;
        this.issue = issue;
    }

    public String getField() {
        return field;
    }

    public void setField(String field) {
        this.field = field;
    }

    public String getIssue() {
        return issue;
    }

    public void setIssue(String issue) {
        this.issue = issue;
    }
}

📌 Step 2: Define ErrorResponseDTO

This class stores the main error details, including the error code, message, timestamp, and request ID.

package jp.co.mycompany.servicing.dto;

import java.io.Serializable;
import java.time.LocalDateTime;
import java.util.List;

public class ErrorResponseDTO implements Serializable {
    private String code;
    private String message;
    private List<ErrorDetailDTO> details;
    private LocalDateTime timestamp;
    private String requestId;

    public ErrorResponseDTO() {
    }

    public ErrorResponseDTO(String code, String message, List<ErrorDetailDTO> details, LocalDateTime timestamp, String requestId) {
        this.code = code;
        this.message = message;
        this.details = details;
        this.timestamp = timestamp;
        this.requestId = requestId;
    }

    public String getCode() {
        return code;
    }

    public void setCode(String code) {
        this.code = code;
    }

    public String getMessage() {
        return message;
    }

    public void setMessage(String message) {
        this.message = message;
    }

    public List<ErrorDetailDTO> getDetails() {
        return details;
    }

    public void setDetails(List<ErrorDetailDTO> details) {
        this.details = details;
    }

    public LocalDateTime getTimestamp() {
        return timestamp;
    }

    public void setTimestamp(LocalDateTime timestamp) {
        this.timestamp = timestamp;
    }

    public String getRequestId() {
        return requestId;
    }

    public void setRequestId(String requestId) {
        this.requestId = requestId;
    }
}

📌 Step 3: Define ErrorContainerDTO (Outer Error Wrapper)

Since the Swagger file requires an “error” key wrapping the response, we use this class to match that structure.

package jp.co.mycompany.servicing.dto;

import java.io.Serializable;

public class ErrorContainerDTO implements Serializable {
    private ErrorResponseDTO error;

    public ErrorContainerDTO() {
    }

    public ErrorContainerDTO(ErrorResponseDTO error) {
        this.error = error;
    }

    public ErrorResponseDTO getError() {
        return error;
    }

    public void setError(ErrorResponseDTO error) {
        this.error = error;
    }
}

📌 Step 4: Implement Global Exception Handling

The exception handler catches errors, generates a unique requestId, and returns a structured response.

package jp.co.mycompany.servicing.exception;

import jp.co.mycompany.servicing.dto.ErrorContainerDTO;
import jp.co.mycompany.servicing.dto.ErrorDetailDTO;
import jp.co.mycompany.servicing.dto.ErrorResponseDTO;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.validation.FieldError;
import org.springframework.web.bind.MethodArgumentNotValidException;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;

import java.time.LocalDateTime;
import java.util.List;
import java.util.UUID;
import java.util.stream.Collectors;

@RestControllerAdvice
public class GlobalExceptionHandler {

    private static final String ERROR_REQUEST_ID_PREFIX = "ERR-";

    // 🛑 Handle Validation Errors (400 Bad Request)
    @ExceptionHandler(MethodArgumentNotValidException.class)
    public ResponseEntity<ErrorContainerDTO> handleValidationException(MethodArgumentNotValidException ex) {
        List<ErrorDetailDTO> details = ex.getBindingResult().getAllErrors().stream()
                .map(error -> new ErrorDetailDTO(
                        ((FieldError) error).getField(),
                        error.getDefaultMessage()
                ))
                .collect(Collectors.toList());

        ErrorResponseDTO errorResponse = new ErrorResponseDTO(
                "400",
                "Invalid parameter value",
                details,
                LocalDateTime.now(),
                generateRequestId()
        );

        return new ResponseEntity<>(new ErrorContainerDTO(errorResponse), HttpStatus.BAD_REQUEST);
    }

    // 🛑 Handle Business Logic Errors (e.g., Invalid Input)
    @ExceptionHandler(IllegalArgumentException.class)
    public ResponseEntity<ErrorContainerDTO> handleIllegalArgument(IllegalArgumentException ex) {
        ErrorResponseDTO errorResponse = new ErrorResponseDTO(
                "400",
                "Invalid input",
                List.of(new ErrorDetailDTO("general", ex.getMessage())),
                LocalDateTime.now(),
                generateRequestId()
        );

        return new ResponseEntity<>(new ErrorContainerDTO(errorResponse), HttpStatus.BAD_REQUEST);
    }

    // 🛑 Handle Generic Exceptions (500 Internal Server Error)
    @ExceptionHandler(Exception.class)
    public ResponseEntity<ErrorContainerDTO> handleGenericException(Exception ex) {
        ErrorResponseDTO errorResponse = new ErrorResponseDTO(
                "500",
                "Internal Server Error",
                List.of(new ErrorDetailDTO("general", ex.getMessage())),
                LocalDateTime.now(),
                generateRequestId()
        );

        return new ResponseEntity<>(new ErrorContainerDTO(errorResponse), HttpStatus.INTERNAL_SERVER_ERROR);
    }

    // ✅ Generate a unique requestId for debugging purposes
    private String generateRequestId() {
        return ERROR_REQUEST_ID_PREFIX + UUID.randomUUID().toString();
    }
}

