1) Drop-in helper (small + threadsafe)

/** Returns the first non-blank string from the arguments. */
private static String firstNonBlank(String... vals) {
    for (String v : vals) if (v != null && !v.isBlank()) return v;
    return null;
}

/**
 * Choose display name based on language, using values already in context.
 * language: "ja" -> prefer kanji, then kana, then alphabet
 *           "en" -> prefer alphabet, then kanji, then kana
 *           otherwise -> first non-blank among (kanji, kana, alphabet)
 */
private static void computeRecipientDisplayName(Map<String,Object> context, String language) {
    String kanji    = (String) context.get("recipient.name.kanji");
    String kana     = (String) context.get("recipient.name.kana");
    String alphabet = (String) context.get("recipient.name.alphabet");

    String lang = language == null ? "" : language.trim().toLowerCase();
    String chosen;
    switch (lang) {
        case "ja":
            chosen = firstNonBlank(kanji, kana, alphabet);
            break;
        case "en":
            chosen = firstNonBlank(alphabet, kanji, kana);
            break;
        default:
            chosen = firstNonBlank(kanji, kana, alphabet);
            break;
    }
    if (chosen != null) context.put("recipient.name", chosen);
}

2) Where to call it (one line in your flow)

Right after your lookup executor populates the context (and before you build the Notification API payload):

