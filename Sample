    public List<Calender> searchCalendar(String requestId, CalenderSearchConditions searchConditions) {
        log.info("Processing calendar search for requestId: {}", requestId);

        searchConditions.validateDates();

        String startEpoch = searchConditions.getStartDate() != null
                ? Calender.convertDateToEpoch(searchConditions.getStartDate()) // Convert `yyyy-MM-dd` to epoch String
                : null;

        String endEpoch = searchConditions.getEndDate() != null
                ? Calender.convertDateToEpoch(searchConditions.getEndDate()) // Convert `yyyy-MM-dd` to epoch String
                : null;

        List<Calender> calendars = CalendarMapper.toDtoList(
                calendarRepository.findByDateRange(startEpoch, endEpoch) // Pass as String
        );

        if (calendars.isEmpty()) {
            log.warn("No calendar data found for requestId: {}", requestId);
        }

        return calendars;
    }
