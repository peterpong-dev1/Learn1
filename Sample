// NeoGetTrackedFieldsFromBlob.java
public static List<String> getTrackedFields(BlobContainerClient configContainer,
                                            String logicalContainerName) {
    if (configContainer == null || !configContainer.exists()) {
        System.err.println("Config container is null or does not exist.");
        return Collections.emptyList();
    }
    if (logicalContainerName == null || logicalContainerName.isBlank()) {
        return Collections.emptyList();
    }

    String blobName = logicalContainerName + "-tracked-fields.json";
    try {
        var blob = configContainer.getBlobClient(blobName);
        if (!blob.exists()) {
            System.err.println("Tracked-fields blob missing: " + blobName);
            return Collections.emptyList();
        }
        String json = blob.downloadContent().toString(); // BinaryData -> String
        if (json == null || json.isBlank()) return Collections.emptyList();

        return MAPPER.readValue(json, new TypeReference<List<String>>() {});
    } catch (Exception e) {
        System.err.println("Error reading tracked fields: " + e.getMessage());
        return Collections.emptyList();
    }
}