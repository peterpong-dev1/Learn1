4) Example usage inside your CosmosDB-trigger Function

// inside your @FunctionName run method, after you computed:
// - isCreate (true/false)
// - a list of event decisions (some may be 0..N per document)
// - a compact list of changes for that event (only tracked fields)

import com.neo.bus.MessageFactory;
import com.neo.bus.BusSender;
import com.azure.messaging.servicebus.ServiceBusMessage;

// Example variables you already have from your pipeline:
String schemaVersion   = "1.0";
String correlationId   = buildCorrelationId(containerName, docId); // your helper
String when            = isCreate ? "insert" : "update";
String sessionId       = System.getenv("UseSessions") != null && System.getenv("UseSessions").equalsIgnoreCase("true")
                         ? docId : null;

// context you may want to add
Map<String,Object> context = Map.of(
   "_etag",    newDoc.path("_etag").asText(""),
   "_lsn",     newDoc.path("_lsn").asText(""),
   "readAtUtc", java.time.OffsetDateTime.now().toString()
);

// For each event decision:
ServiceBusMessage msg = MessageFactory.build(
        schemaVersion,
        correlationId,
        containerName,
        docId,
        eventId,          // from your config, e.g., "appInfoProgressManagement:application_submitted"
        eventName,        // human readable label
        when,
        smallChangesList, // List<Map<String,Object>> of {field, old, new} (can be empty on create)
        context,
        sessionId         // null if you disabled sessions on the queue
);

// Send
BusSender.send(msg, contextLogger);


