Perfect — here’s a drop‑in version that wires the scalar comparison into a computeDelta(...) method. Paste these methods into your existing class (e.g., the same class where you handle the change feed). No utilities, no extras—just scalar logic (Scenarios 1–3).

// ======= Delta (Scalar-only) =======

/**
 * Compute delta for scalar tracked fields only (ADDED / REMOVED / UPDATED).
 * - snapshotOld: previous JSON snapshot (from blob). May be null for first-time.
 * - newDoc: latest Cosmos DB document (from change feed). Required.
 * - trackedFields: dot-paths, e.g., "status", "email", "Item.address.phone".
 * @return list of change records: {path, type, oldValue, newValue}
 */
private List<Map<String, Object>> computeDelta(ObjectNode snapshotOld,
                                               ObjectNode newDoc,
                                               List<String> trackedFields) {
    List<Map<String, Object>> changes = new ArrayList<>();
    if (newDoc == null || trackedFields == null || trackedFields.isEmpty()) {
        return changes;
    }
    compareScalarFields(snapshotOld, newDoc, trackedFields, changes);
    return changes;
}

/**
 * Compares only scalar fields between old and new documents.
 * Adds any detected changes to the provided deltaResults list.
 *
 * Scenarios covered:
 * 1) UPDATED: old & new present, values differ
 * 2) ADDED:   old missing, new present
 * 3) REMOVED: old present, new missing
 */
private void compareScalarFields(ObjectNode oldDoc,
                                 ObjectNode newDoc,
                                 List<String> trackedFields,
                                 List<Map<String, Object>> deltaResults) {
    for (String fieldPath : trackedFields) {
        if (fieldPath == null || fieldPath.isBlank()) continue;

        JsonNode oldValue = getValueByPath(oldDoc, fieldPath);
        JsonNode newValue = getValueByPath(newDoc, fieldPath);

        boolean oldPresent = oldValue != null && !oldValue.isMissingNode();
        boolean newPresent = newValue != null && !newValue.isMissingNode();

        if (oldPresent && newPresent) {
            if (!safeEqualsScalar(oldValue, newValue)) {
                deltaResults.add(changeRecord(fieldPath, "UPDATED", oldValue, newValue));
            }
        } else if (!oldPresent && newPresent) {
            deltaResults.add(changeRecord(fieldPath, "ADDED", null, newValue));
        } else if (oldPresent && !newPresent) {
            deltaResults.add(changeRecord(fieldPath, "REMOVED", oldValue, null));
        }
        // else: both missing → no change
    }
}

/** Navigate a dot-separated path like "Item.address.phone"; returns null if any segment missing. */
private JsonNode getValueByPath(JsonNode node, String fieldPath) {
    if (node == null || fieldPath == null || fieldPath.isBlank()) return null;
    String[] parts = fieldPath.split("\\.");
    JsonNode current = node;
    for (String part : parts) {
        if (current == null || current.isMissingNode()) return null;
        current = current.get(part);
    }
    return current;
}

/** Compare two scalar JsonNodes safely (treats nulls correctly). */
private boolean safeEqualsScalar(JsonNode a, JsonNode b) {
    if (a == null && b == null) return true;
    if (a == null || b == null) return false;
    if (!a.isValueNode() || !b.isValueNode()) return false; // non-scalar not supported here
    // Normalize to Java types
    Object va = toScalar(a);
    Object vb = toScalar(b);
    return Objects.equals(va, vb);
}

/** Convert a scalar JsonNode to a plain Java value. */
private Object toScalar(JsonNode n) {
    if (n == null || n.isNull()) return null;
    if (n.isTextual())  return n.asText();
    if (n.isNumber())   return n.numberValue();
    if (n.isBoolean())  return n.asBoolean();
    return n.asText(); // fallback
}

/** Build a standard change record map. */
private Map<String, Object> changeRecord(String path, String type, JsonNode oldVal, JsonNode newVal) {
    Map<String, Object> record = new LinkedHashMap<>();
    record.put("path", path);
    record.put("type", type);
    record.put("oldValue", (oldVal != null && !oldVal.isMissingNode()) ? toScalar(oldVal) : null);
    record.put("newValue", (newVal != null && !newVal.isMissingNode()) ? toScalar(newVal) : null);
    return record;
}

How it works (quick recap)
	•	Dot paths like Item.address.phone walk the JSON tree with getValueByPath.
	•	Only scalars (string/number/boolean/null) are compared.
	•	Produces a simple list of { path, type, oldValue, newValue } maps you can pass to your message builder.

When you’re ready to add arrays or arrays-of-objects, we’ll extend computeDelta(...) to call additional helpers (e.g., compareArraySet, compareArrayObjectKeyed) without changing the return shape.