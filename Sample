Here’s a production-grade, thread-safe, idempotent Java helper to record one row per (day, agentId, eventKey, docId) in Azure Table Storage.
	•	Insert-only (first writer wins).
	•	Idempotent: duplicate inserts return ALREADY_EXISTS.
	•	Thread-safe: uses exponential backoff + jitter on transient errors.
	•	Key-safe: sanitizes PartitionKey/RowKey and enforces length limits.
	•	Compatible with Azure Data Tables v12 (com.azure:azure-data-tables).

import com.azure.data.tables.TableClient;
import com.azure.data.tables.TableClientBuilder;
import com.azure.data.tables.models.TableEntity;
import com.azure.data.tables.models.TableServiceException;

import java.time.*;
import java.time.format.DateTimeFormatter;
import java.util.Objects;
import java.util.Random;
import java.util.logging.Logger;

public final class DailyAgentEventDocsWriter {

    public enum InsertResult { INSERTED, ALREADY_EXISTS }

    private static final DateTimeFormatter DAY_FMT = DateTimeFormatter.BASIC_ISO_DATE; // yyyyMMdd
    private static final ZoneId TOKYO = ZoneId.of("Asia/Tokyo");
    private static final int MAX_KEY_LEN = 512; // conservative, Azure allows up to 1KB
    private static final Random JITTER = new Random();

    private final TableClient table;
    private final Logger log;

    public DailyAgentEventDocsWriter(TableClient table, Logger log) {
        this.table = Objects.requireNonNull(table, "table");
        this.log = (log != null) ? log : Logger.getLogger(DailyAgentEventDocsWriter.class.getName());
    }

    /**
     * Records that a (agentId,eventKey,docId) occurred on the given 'occurredAtUtc' timestamp (UTC).
     * Idempotent: if the row already exists, returns ALREADY_EXISTS and does not throw.
     *
     * Row shape:
     *   PK = yyyyMMdd (Tokyo day)
     *   RK = agentId#eventKey#docId
     *   Properties: agentId, eventKey, docId, wonAtUtc
     */
    public InsertResult insertOnce(String agentId, String eventKey, String docId, Instant occurredAtUtc)
            throws InterruptedException {
        Objects.requireNonNull(agentId, "agentId");
        Objects.requireNonNull(eventKey, "eventKey");
        Objects.requireNonNull(docId, "docId");
        Objects.requireNonNull(occurredAtUtc, "occurredAtUtc");

        final String dayPk = toTokyoDay(occurredAtUtc);
        final String rk = sanitizeKey(agentId) + "#" + sanitizeKey(eventKey) + "#" + sanitizeKey(docId);

        final TableEntity e = new TableEntity(dayPk, rk)
                .addProperty("agentId", agentId)
                .addProperty("eventKey", eventKey)
                .addProperty("docId", docId)
                .addProperty("wonAtUtc", occurredAtUtc.toString());

        // Robust insert with retries on transient errors
        final int maxAttempts = 6; // ~1.7s avg backoff; adjust if you expect heavy contention
        long backoffMs = 100;

        for (int attempt = 1; attempt <= maxAttempts; attempt++) {
            try {
                table.createEntity(e);                 // INSERT ONLY
                return InsertResult.INSERTED;          // success, first writer
            } catch (TableServiceException ex) {
                int code = ex.getResponse().getStatusCode();

                // 409 means the row already exists -> idempotent success
                if (code == 409) {
                    if (attempt == 1) {
                        log.fine(() -> String.format(
                            "DailyAgentEventDocs already had row (PK=%s, RK=%s).", dayPk, rk));
                    }
                    return InsertResult.ALREADY_EXISTS;
                }

                // Retry on common transients: 408, 429, 5xx
                if (code == 408 || code == 429 || (code >= 500 && code <= 599)) {
                    if (attempt == maxAttempts) {
                        log.warning(() -> String.format(
                            "Transient error (code=%d) after %d attempts inserting PK=%s RK=%s: %s",
                            code, attempt, dayPk, rk, ex.getMessage()));
                        throw ex; // bubble up after exhausting retries
                    }
                    long jitter = JITTER.nextInt(60); // small jitter to reduce thundering herd
                    long sleep = backoffMs + jitter;
                    log.fine(() -> String.format(
                        "Transient error (code=%d). Retry %d/%d after %d ms for PK=%s RK=%s",
                        code, attempt, maxAttempts, sleep, dayPk, rk));
                    Thread.sleep(sleep);
                    backoffMs = Math.min(backoffMs * 2, 1200); // cap growth
                    continue;
                }

                // Non-retryable: rethrow
                log.severe(() -> String.format(
                    "Non-retryable TableServiceException (code=%d) inserting PK=%s RK=%s: %s",
                    code, dayPk, rk, ex.getMessage()));
                throw ex;
            } catch (RuntimeException ex) {
                // SDK/runtime failures: retry a few times, then rethrow
                if (attempt == maxAttempts) {
                    log.severe(() -> String.format(
                        "Runtime error after %d attempts inserting PK=%s RK=%s: %s",
                        attempt, dayPk, rk, ex.toString()));
                    throw ex;
                }
                long sleep = backoffMs + JITTER.nextInt(60);
                Thread.sleep(sleep);
                backoffMs = Math.min(backoffMs * 2, 1200);
            }
        }
        // Should never reach here
        throw new IllegalStateException("Exhausted retries unexpectedly.");
    }

    // --- Helpers -----------------------------------------------------------------

    /** Convert an Instant to Tokyo calendar day yyyyMMdd. */
    private static String toTokyoDay(Instant utc) {
        return DAY_FMT.format(ZonedDateTime.ofInstant(utc, TOKYO).toLocalDate());
    }

    /**
     * Sanitize a value for PartitionKey/RowKey:
     *  - Remove/replace forbidden characters: '/', '\\', '#', '?'
     *  - Trim control chars
     *  - Enforce length limit
     */
    private static String sanitizeKey(String raw) {
        String s = raw;
        // Disallow control chars
        s = s.replaceAll("[\\p{Cntrl}]", "");
        // Replace forbidden Table chars
        s = s.replace('/', '-').replace('\\', '-').replace('#', '-').replace('?', '-');
        // Optional: collapse whitespace
        s = s.trim();
        // Enforce conservative length
        if (s.length() > MAX_KEY_LEN) {
            // keep tail which is often most unique (ids), include a hash prefix if you prefer
            s = s.substring(s.length() - MAX_KEY_LEN);
        }
        if (s.isEmpty()) s = "_";
        return s;
        // (If your agentId/eventKey/docId can contain other risky chars, extend this.)
    }

    // Factory (example)
    public static DailyAgentEventDocsWriter fromConnStr(String connStr, String tableName, Logger log) {
        TableClient client = new TableClientBuilder()
                .connectionString(connStr)
                .tableName(tableName)
                .buildClient();
        // Ensure table exists (idempotent)
        client.createTableIfNotExists();
        return new DailyAgentEventDocsWriter(client, log);
    }
}

