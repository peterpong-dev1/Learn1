@Test
void testGetAgencyOffices_OffsetPagination_Success() throws Exception {
    List<AgencyOfficesResponseDTO> mockOffices = List.of(
        new AgencyOfficesResponseDTO("id1", "支店1", "担当者", "2025-07-14")
    );

    when(service.getAllAgencyOfficesService(eq(3), eq(6), eq("associationRegistrationNumber"), eq("ASC")))
        .thenReturn(new PaginatedResultInternalDTO<>(mockOffices, null));

    mockMvc.perform(get("/v1/agency/office")
            .param("page", "3")
            .param("limit", "6")
            .param("sortBy", "associationRegistrationNumber")
            .param("sortDir", "ASC")
            .contentType(MediaType.APPLICATION_JSON))
        .andExpect(status().isOk())
        .andExpect(jsonPath("$[0].id").value("id1"))
        .andExpect(jsonPath("$[0].name").value("支店1"));

    verify(service).getAllAgencyOfficesService(3, 6, "associationRegistrationNumber", "ASC");
}

