3) Use it in your Function run(...)

// Build JSON you already have:
String json = NotificationQueuePayloadBuilder.buildJson(fieldsContext, parsedMessage, context.getLogger());

// Get cached sender (App Setting must contain the connection string)
final String CONNECTION_SETTING = "AzureWebJobsServiceBus";  // or your key
final String QUEUE_NAME = "notification-request";

var sender = ServiceBusSenderProvider.get(CONNECTION_SETTING, QUEUE_NAME);

// Optional app properties (good for filtering/diagnostics)
Map<String,Object> props = Map.of(
    "notificationType", fieldsContext.getOrDefault("notificationType", ""),
    "triggerType",      fieldsContext.getOrDefault("triggerType", ""),
    "messageType",      fieldsContext.getOrDefault("messageType", "")
);

// IDs from parsedMessage if available
String messageId     = parsedMessage != null ? parsedMessage.getMessageId()     : null;
String correlationId = parsedMessage != null ? parsedMessage.getCorrelationId() : null;

// Send
QueuePublisher.sendJson(sender, json, messageId, correlationId, props, context.getLogger());


