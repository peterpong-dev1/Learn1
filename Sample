1) Rule evaluation utility

Create RuleEngine.java:

package com.neo.notification.rules;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.util.ArrayList;
import java.util.List;
import java.util.Objects;

/**
 * Stateless evaluator for EventConfig rules.
 *
 * Supported ops:
 *  - "eq"            : field equals value (string compare on .asText())
 *  - "changed"       : field value changed between old and new
 *  - "changedTo"     : field value changed to the supplied value
 *  - "becameNotNull" : field was null/missing/empty and is now non-empty
 *
 * "when": ["insert","update"] decides applicability by isCreate flag.
 *
 * All comparisons are null-safe and treat missing node == null.
 */
public final class RuleEngine {

    private RuleEngine() {}

    /** Evaluate one event’s rules against the docs. Returns true if the event should fire. */
    public static boolean evaluateEvent(
            EventConfig.Event event,
            boolean isCreate,
            ObjectNode newDoc,
            ObjectNode oldDocOrNull) {

        // 1) Gate on when
        boolean wantsInsert = event.when != null && event.when.stream()
                .anyMatch(s -> "insert".equalsIgnoreCase(s));
        boolean wantsUpdate = event.when != null && event.when.stream()
                .anyMatch(s -> "update".equalsIgnoreCase(s));

        if (isCreate && !wantsInsert) return false;
        if (!isCreate && !wantsUpdate) return false;

        // 2) Evaluate rules
        List<Boolean> results = new ArrayList<>();
        if (event.conditions != null && event.conditions.rules != null) {
            for (EventConfig.Rule r : event.conditions.rules) {
                results.add(evalRule(r, newDoc, oldDocOrNull));
            }
        }

        // 3) Combine by logic
        String logic = (event.conditions == null || event.conditions.logic == null)
                ? "AND" : event.conditions.logic.toUpperCase();

        if (results.isEmpty()) return true; // no rules means always true

        if ("AND".equals(logic)) {
            return results.stream().allMatch(Boolean::booleanValue);
        } else if ("OR".equals(logic)) {
            return results.stream().anyMatch(Boolean::booleanValue);
        } else {
            // unknown logic -> be conservative
            return false;
        }
    }

    private static boolean evalRule(EventConfig.Rule r, ObjectNode newDoc, ObjectNode oldDocOrNull) {
        String op = safe(r.op);
        String field = safe(r.field);
        String value = r.value; // may be null

        JsonNode newVal = get(newDoc, field);
        JsonNode oldVal = oldDocOrNull == null ? null : get(oldDocOrNull, field);

        switch (op) {
            case "eq":
                return equalsText(newVal, value);
            case "changed":
                return !equalsText(newVal, text(oldVal));
            case "changedTo":
                return !equalsText(newVal, text(oldVal)) && equalsText(newVal, value);
            case "becameNotNull":
                return isEmpty(oldVal) && !isEmpty(newVal);
            default:
                // Unknown op -> do not match
                return false;
        }
    }

    // ----- helpers -----

    private static JsonNode get(ObjectNode obj, String simpleField) {
        if (obj == null || simpleField == null || simpleField.isBlank()) return null;
        // NOTE: simple top-level fields. If you need dotted paths, split here.
        return obj.get(simpleField);
    }

    private static String text(JsonNode n) {
        return n == null || n.isNull() ? null : n.asText(null);
    }

    private static boolean equalsText(JsonNode a, String b) {
        String ta = text(a);
        return Objects.equals(ta, b);
    }

    private static boolean isEmpty(JsonNode n) {
        if (n == null || n.isNull()) return true;
        if (n.isTextual()) return n.asText().isBlank();
        // treat “missing”/empty arrays/objects as empty if you need later
        return false;
    }

    private static String safe(String s) {
        return s == null ? "" : s.trim();
    }
}

This expects your single-file model (EventConfig.java) to be in com.neo.notification.rules (or adjust package imports). It references EventConfig.Event, EventConfig.Rule, and EventConfig.Conditions—the nested classes from the single-file model I gave earlier.

