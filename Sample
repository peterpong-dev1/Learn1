package com.example.calendar.dto;

import lombok.Builder;
import lombok.Data;

import java.time.Instant;
import java.time.LocalDate;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

@Data
@Builder
public class CalenderDTO {
    private String id;
    private String calendarDay; // Kept as String to match API format (yyyy-MM-dd)
    private boolean businessDayFlag;

    // Convert Epoch (DB format) to String (`yyyy-MM-dd`) for API response
    public static String convertEpochToDate(String epochMillis) {
        long epoch = Long.parseLong(epochMillis); // Convert stored String to long
        return Instant.ofEpochMilli(epoch)
                .atZone(ZoneId.systemDefault())
                .toLocalDate()
                .format(DateTimeFormatter.ISO_LOCAL_DATE);
    }

    // Convert `yyyy-MM-dd` String to Epoch (DB format) when saving
    public static String convertDateToEpoch(String date) {
        return String.valueOf(LocalDate.parse(date, DateTimeFormatter.ISO_LOCAL_DATE)
                .atStartOfDay(ZoneId.systemDefault())
                .toInstant()
                .toEpochMilli());
    }
}

🔹 Why calendarDay is a String?
	•	Cosmos DB stores calendarDay as a String (Epoch timestamp).
	•	API requires yyyy-MM-dd, so we convert it when sending responses.

📌 CalenderMapper.java
	•	Converts between CalenderDTO (API) and CalenderEntity (DB).
	•	Handles String ↔ Epoch conversion.
	•	Uses @Builder for clean object creation.

package com.example.calendar.mapper;

import com.example.calendar.dto.CalenderDTO;
import com.example.calendar.entity.CalenderEntity;
import java.util.List;
import java.util.stream.Collectors;

public class CalenderMapper {

    // Convert DTO to Entity (API Request → DB Model)
    public static CalenderEntity toEntity(CalenderDTO dto) {
        return new CalenderEntity(
                dto.getId(),
                CalenderDTO.convertDateToEpoch(dto.getCalendarDay()), // Convert date to epoch string
                dto.isBusinessDayFlag()
        );
    }

    // Convert Entity to DTO (DB Model → API Response)
    public static CalenderDTO toDto(CalenderEntity entity) {
        return CalenderDTO.builder()
                .id(entity.getId())
                .calendarDay(CalenderDTO.convertEpochToDate(entity.getCalendarDay())) // Convert epoch string to date
                .businessDayFlag(entity.isBusinessDayFlag())
                .build();
    }

    // Convert List of Entities to List of DTOs
    public static List<CalenderDTO> toDtoList(List<CalenderEntity> entities) {
        return entities.stream().map(CalenderMapper::toDto).collect(Collectors.toList());
    }
}

🚀 Summary of Features

✅ CalenderDTO (API Layer):
	•	Stores calendarDay as String (yyyy-MM-dd).
	•	Converts between String ↔ Epoch (long stored as String in DB).
	•	Uses @Builder for easy object creation.

✅ CalenderMapper (Mapping Logic):
	•	Converts DTO ↔ Entity with proper epoch handling.
	•	Supports bulk list conversion (List<Entity> → List<DTO>).

📌 Example Usage

🔹 Convert CalenderEntity to CalenderDTO (DB → API Response)

CalenderEntity entity = new CalenderEntity("1", "1709337600000", true);

CalenderDTO dto = CalenderMapper.toDto(entity);
System.out.println(dto); 

// Output: { "id": "1", "calendarDay": "2024-03-01", "businessDayFlag": true }

🔹 Convert CalenderDTO to CalenderEntity (API Request → DB Storage)

CalenderDTO dto = CalenderDTO.builder()
        .id("1")
        .calendarDay("2024-03-01")
        .businessDayFlag(true)
        .build();

CalenderEntity entity = CalenderMapper.toEntity(dto);
System.out.println(entity);

// Output: { "id": "1", "calendarDay": "1709337600000", "businessDayFlag": true }

