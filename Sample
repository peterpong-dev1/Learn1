import com.azure.storage.blob.BlobClient;
import com.azure.storage.blob.BlobContainerClient;
import com.azure.core.util.BinaryData;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

public List<Map<String, String>> handleTrackedChange(
        ObjectNode newDoc,
        BlobContainerClient blobContainerClient,
        List<String> trackedFields,
        String containerName,
        java.util.logging.Logger logger) {

    List<Map<String, String>> changes = new ArrayList<>();
    String docId = newDoc.get("id").asText();
    String oldBlobName = containerName + "/" + docId + ".json";
    String latestBlobName = containerName + "/" + docId + "-latest.json";

    ObjectMapper mapper = new ObjectMapper();

    try {
        // Load oldDoc from {id}.json
        BlobClient oldBlobClient = blobContainerClient.getBlobClient(oldBlobName);
        if (!oldBlobClient.exists()) {
            logger.warning("Missing base file (id.json): " + oldBlobName);
            return changes;
        }

        BinaryData oldData = oldBlobClient.downloadContent();
        ObjectNode oldDoc = (ObjectNode) mapper.readTree(oldData.toString());

        // Prepare new tracked values
        ObjectNode newTracked = mapper.createObjectNode();
        for (String field : trackedFields) {
            if (newDoc.has(field)) {
                newTracked.set(field, newDoc.get(field));
            }
        }

        // Compare
        for (String field : trackedFields) {
            JsonNode oldVal = oldDoc.get(field);
            JsonNode newVal = newTracked.get(field);
            if ((oldVal == null && newVal != null) || (oldVal != null && !oldVal.equals(newVal))) {
                Map<String, String> change = new HashMap<>();
                change.put("field", field);
                change.put("oldValue", oldVal == null ? null : oldVal.toString());
                change.put("newValue", newVal == null ? null : newVal.toString());
                changes.add(change);
            }
        }

        BlobClient latestClient = blobContainerClient.getBlobClient(latestBlobName);
        if (changes.isEmpty()) {
            // No changes: still create latest.json from oldDoc
            latestClient.upload(BinaryData.fromString(oldDoc.toString()), true);
            logger.info("No tracked changes for " + docId + "; latest.json updated from oldDoc.");
        } else {
            // Version and update latest.json
            String timestamp = java.time.Instant.now().toString();
            String versionBlob = containerName + "/" + docId + "-" + timestamp + ".json";
            blobContainerClient.getBlobClient(versionBlob)
                    .upload(BinaryData.fromString(newTracked.toString()), true);

            latestClient.upload(BinaryData.fromString(newTracked.toString()), true);
            logger.info("Tracked changes for " + docId + "; version created and latest.json updated.");
        }

    } catch (Exception e) {
        logger.severe("Error in handleTrackedChange for id " + docId + ": " + e.getMessage());
    }

    return changes;
}

public void uploadBlobFromStream(BlobContainerClient blobContainerClient) {
    BlockBlobClient blockBlobClient = blobContainerClient.getBlobClient("sampleBlob.txt").getBlockBlobClient();
    String sampleData = "Sample data for blob";
    try (ByteArrayInputStream dataStream = new ByteArrayInputStream(sampleData.getBytes())) {
        blockBlobClient.upload(dataStream, sampleData.length());
    } catch (IOException ex) {
        ex.printStackTrace();
    }
}

public void uploadDataToBlob(BlobContainerClient blobContainerClient) {
    // Create a BlobClient object from BlobContainerClient
    BlobClient blobClient = blobContainerClient.getBlobClient("sampleBlob.txt");
    String sampleData = "Sample data for blob";
    blobClient.upload(BinaryData.fromString(sampleData));
}
