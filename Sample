@Test
void test_SearchWithValidInputFields_Success() {
    // Input parameters
    int page = 1;
    int limit = 20;
    String sortBy = "associationRegistrationNumber";
    String sortDir = "ASC";

    // Calculated value as per service logic (internal page is zero-based)
    int expectedPage = page - 1;

    // Mock repository response
    when(repository.searchWithDynamicQueryAndPagination(
            eq(expectedPage), eq(limit), eq(sortBy), eq(sortDir)))
        .thenReturn(new PaginatedResultInternalDTO<>(List.of(mockEntity), null));

    // Mock mapper response
    when(mapper.toDTO(mockEntity)).thenReturn(mockDto);

    // Call the actual service method
    PaginatedResultInternalDTO<AgencyOfficesResponseDTO> result =
        serviceImpl.getAllAgencyOfficesService(page, limit, sortBy, sortDir);

    // Assertions
    assertNotNull(result);
    assertNotNull(result.getItems());
    assertEquals(1, result.getItems().size());
    assertEquals("5d11d871-1d5a-4db9-48c2-f9ba29c8475f", result.getItems().get(0).getId());
    assertEquals("04DJXYZ100007", result.getItems().get(0).getAssociationRegistrationNumber());

    // Verify repository and mapper interactions
    verify(repository, times(1))
        .searchWithDynamicQueryAndPagination(eq(expectedPage), eq(limit), eq(sortBy), eq(sortDir));
    verify(mapper, times(1)).toDTO(mockEntity);
}