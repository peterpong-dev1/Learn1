import java.util.List;
import java.util.stream.Collectors;

public class AccountMapper {

    public static AccountDTO toDTO(Account entity) {
        if (entity == null) return null;

        AccountDTO dto = new AccountDTO();
        dto.setId(entity.getId());
        dto.setPolicyId(entity.getPolicyId());
        dto.setAccountUsage(entity.getAccountUsage());
        dto.setCurrencyType(entity.getCurrencyType());
        dto.setYenPayment(entity.getYenPayment());
        dto.setAccountStartDate(entity.getAccountStartDate());
        dto.setAccountIdentifier(entity.getAccountIdentifier());
        dto.setAccountHolder(entity.getAccountHolder());
        dto.setAuthorizationDate(entity.getAuthorizationDate());

        dto.setBank(toBankDTO(entity.getBank()));
        dto.setJapanpost(toJapanPostDTO(entity.getJapanpost()));
        dto.setMrfAccount(toMRFAccountDTO(entity.getMrfAccount()));

        return dto;
    }

    public static List<AccountDTO> toDTOList(List<Account> entities) {
        return entities.stream()
                .map(AccountMapper::toDTO)
                .collect(Collectors.toList());
    }

    private static BankDTO toBankDTO(Bank entity) {
        if (entity == null) return null;

        BankDTO dto = new BankDTO();
        dto.setFinancialInstitutionCode(entity.getFinancialInstitutionCode());
        dto.setFinancialInstitutionBranchCode(entity.getFinancialInstitutionBranchCode());
        dto.setAccountCategory(entity.getAccountCategory());
        dto.setAccountNumber(entity.getAccountNumber());
        return dto;
    }

    private static JapanPostDTO toJapanPostDTO(JapanPost entity) {
        if (entity == null) return null;

        JapanPostDTO dto = new JapanPostDTO();
        dto.setPassbookSymbol(entity.getPassbookSymbol());
        dto.setPassbookNumber(entity.getPassbookNumber());
        return dto;
    }

    private static MRFAccountDTO toMRFAccountDTO(MRFAccount entity) {
        if (entity == null) return null;

        MRFAccountDTO dto = new MRFAccountDTO();
        dto.setDealerCode(entity.getDealerCode());
        dto.setAccountNumber(entity.getAccountNumber());
        dto.setAccountHolder(entity.getAccountHolder());
        return dto;
    }
}