      "name": "Create Lapse Notice",
      "when": ["insert", "update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "lapseDate" },
          { "op": "changed", "field": "lapseDate" }
        ]
      },
      "schedule": {
        "type": "atField",
        "field": "lapseDate",
        "time": "09:00",
        "tz": "Asia/Tokyo"
