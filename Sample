2) MessageValidator — checks mandatory fields on your IncomingMessage

package com.yourco.notification.validation;

import java.util.*;

/** Stateless validator for IncomingMessage. */
public final class MessageValidator {

    private MessageValidator() {}

    /**
     * Return the list of missing fields (empty if valid).
     * Field names are logical labels you can log (not JSONPath).
     */
    public static List<String> validateRequired(IncomingMessage msg) {
        List<String> missing = new ArrayList<>();

        mustHave(nonBlank(msg.getMessageId()),       "messageId", missing);
        mustHave(nonBlank(msg.getCorrelationId()),   "correlationId", missing);
        mustHave(nonBlank(msg.getContainer()),       "container", missing);
        mustHave(nonBlank(msg.getDocId()),           "docId", missing);
        mustHave(nonBlank(msg.getEventId()),         "eventId", missing);
        mustHave(nonBlank(msg.getEventName()),       "eventName", missing);

        // notify.*
        if (msg.getNotify() == null) {
            missing.add("notify.notificationType");
            missing.add("notify.triggerType");
        } else {
            mustHave(nonBlank(msg.getNotify().getNotificationType()), "notify.notificationType", missing);
            mustHave(nonBlank(msg.getNotify().getTriggerType()),      "notify.triggerType", missing);
        }

        // optional: extracted keys you consider mandatory for later steps
        Map<String,String> extracted = msg.getExtractedFields();
        if (extracted == null) {
            // if you require at least one of them:
            // missing.add("extractedFields");
        } else {
            // Example: require at least one business key
            if (isBlank(extracted.get("applicationNumber")) &&
                isBlank(extracted.get("policyId"))) {
                missing.add("extractedFields.(applicationNumber|policyId)");
            }
        }

        return missing;
    }

    private static void mustHave(boolean ok, String name, List<String> missing) {
        if (!ok) missing.add(name);
    }
    private static boolean nonBlank(String s) { return s != null && !s.isBlank(); }
    private static boolean isBlank(String s) { return s == null || s.isBlank(); }
}

Update the “extracted keys” part to match your real requirements.

