Step 1 — Method definition + how to call it from the trigger

1) Define a tiny result type for the changes

package com.neo.notification.model;

public class ChangeDelta {
    private final String field;
    private final String oldValue;
    private final String newValue;

    public ChangeDelta(String field, String oldValue, String newValue) {
        this.field = field;
        this.oldValue = oldValue;
        this.newValue = newValue;
    }
    public String getField()    { return field; }
    public String getOldValue() { return oldValue; }
    public String getNewValue() { return newValue; }

    @Override public String toString() {
        return field + ": [" + oldValue + " -> " + newValue + "]";
    }
}

