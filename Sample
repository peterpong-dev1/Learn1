package jp.co.neofirst.api.common.util;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.fasterxml.jackson.databind.node.ArrayNode;

import java.util.List;
import java.util.Map;

/**
 * Utility to build JSON payloads for Email Service.
 * Thread-safe (uses static final ObjectMapper).
 */
public final class EmailPayloadBuilder {

    // Thread-safe ObjectMapper instance
    private static final ObjectMapper MAPPER = new ObjectMapper();

    // Prevent instantiation
    private EmailPayloadBuilder() {}

    /**
     * Builds JSON payload string for Email Service.
     *
     * @param requestId   unique id (UUID or correlationId)
     * @param fromAddress sender email
     * @param fromName    sender display name
     * @param replyAddress reply-to email
     * @param subject     rendered subject
     * @param bodyText    plain text body
     * @param bodyHtml    html body (can be null)
     * @param deliveryMailAddressPropertyName key in deliveryData for recipient address
     * @param recipients  list of recipient maps (each map contains required and optional fields)
     * @param oneClickUnsub true/false
     * @return JSON string ready to POST
     * @throws Exception if building fails
     */
    public static String buildEmailPayload(String requestId,
                                           String fromAddress,
                                           String fromName,
                                           String replyAddress,
                                           String subject,
                                           String bodyText,
                                           String bodyHtml,
                                           String deliveryMailAddressPropertyName,
                                           List<Map<String, Object>> recipients,
                                           boolean oneClickUnsub) throws Exception {
        try {
            ObjectNode root = MAPPER.createObjectNode();

            root.put("requestId", requestId);
            root.put("fromAddress", fromAddress);
            root.put("fromName", fromName);
            root.put("replyAddress", replyAddress);
            root.put("subject", subject);
            root.put("bodyText", bodyText);
            if (bodyHtml != null) {
                root.put("bodyHtml", bodyHtml);
            }
            root.put("deliveryMailAddressPropertyName", deliveryMailAddressPropertyName);
            root.put("count", recipients != null ? recipients.size() : 0);
            root.put("oneClickUnsubscriptionReady", oneClickUnsub);

            // Recipients array
            ArrayNode deliveryData = MAPPER.createArrayNode();
            if (recipients != null) {
                for (Map<String, Object> r : recipients) {
                    deliveryData.add(MAPPER.valueToTree(r));
                }
            }
            root.set("deliveryData", deliveryData);

            return MAPPER.writeValueAsString(root);

        } catch (Exception e) {
            // Log error (use your logger instead of printStackTrace in real code)
            System.err.println("Failed to build Email payload: " + e.getMessage());
            throw e;
        }
    }
}


