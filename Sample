@PostMapping("/search")
public ResponseEntity<?> searchFinancialInstitutions(@Valid @RequestBody SearchConditionsDTO searchConditions) {
    try {
        List<FinancialInstitutionDTO> results = financialInstitutionService.searchInstitutions(searchConditions);
        return ResponseEntity.ok(results);
    } catch (CosmosException ex) {
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body("Cosmos DB Error: " + ex.getMessage());
    } catch (Exception ex) {
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body("Unexpected Error: " + ex.getMessage());
    }
}
