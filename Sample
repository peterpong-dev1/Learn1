Perfect—that’s exactly the pattern. Here’s a tiny, production-lean utility that:
	•	takes a Map<String, Object> of JSON paths → values (e.g. "/stages.notificationApi.status" -> "PROCESSED"),
	•	PATCHes those fields (creating the doc first if it doesn’t exist),
	•	and lets you read by correlationId.

import com.azure.cosmos.*;
import com.azure.cosmos.models.*;
import com.azure.cosmos.util.CosmosPagedIterable;
import com.fasterxml.jackson.databind.node.*;

import java.time.Instant;
import java.util.Map;

public final class CosmosReportingUtil {
    private CosmosReportingUtil() {}

    /** Create minimal doc if not exists (id == correlationId, pk == /correlationId). */
    public static ObjectNode createIfNotExists(CosmosContainer container, String correlationId) {
        try {
            return container.readItem(correlationId, new PartitionKey(correlationId), ObjectNode.class).getItem();
        } catch (CosmosException e) {
            if (e.getStatusCode() != 404) throw e;
        }
        ObjectNode doc = JsonNodeFactory.instance.objectNode();
        doc.put("id", correlationId);
        doc.put("correlationId", correlationId);
        doc.put("workflowStatus", "IN_PROGRESS");
        doc.set("stages", JsonNodeFactory.instance.objectNode());
        doc.put("createdAt", Instant.now().toString());
        return container.createItem(doc, new PartitionKey(correlationId), new CosmosItemRequestOptions()).getItem();
    }

    /**
     * Upsert fields via PATCH. Keys are JSON paths (dot or slash), e.g.:
     *  "/workflowStatus" -> "IN_PROGRESS"
     *  "/stages.notificationApi.status" -> "PROCESSED"
     *  "delivery.httpStatus" -> 202
     * If the document doesn't exist, it's created first.
     */
    public static void patchFields(CosmosContainer container, String correlationId, Map<String, Object> fields) {
        // try patch; if 404, create then patch
        try {
            doPatch(container, correlationId, fields);
        } catch (CosmosException e) {
            if (e.getStatusCode() == 404) {
                createIfNotExists(container, correlationId);
                doPatch(container, correlationId, fields);
            } else {
                throw e;
            }
        }
    }

    /** Read by correlationId (id == correlationId, pk == /correlationId). */
    public static ObjectNode read(CosmosContainer container, String correlationId) {
        return container.readItem(correlationId, new PartitionKey(correlationId), ObjectNode.class).getItem();
    }

    // --------- internal helpers ---------

    private static void doPatch(CosmosContainer container, String correlationId, Map<String, Object> fields) {
        CosmosPatchOperations ops = CosmosPatchOperations.create();
        for (Map.Entry<String, Object> e : fields.entrySet()) {
            String path = normalizePath(e.getKey());      // convert "a.b" → "/a/b", keep "/a.b" → "/a/b"
            ops.set(path, e.getValue());
        }
        ops.set("/lastUpdatedAt", Instant.now().toString());

        container.patchItem(
                correlationId,
                new PartitionKey(correlationId),
                ops,
                ObjectNode.class
        );
    }

    /** Accepts "/a/b", "a.b", "a/b" → returns "/a/b" (JSON Pointer style for Cosmos PATCH). */
    private static String normalizePath(String raw) {
        if (raw == null || raw.isBlank()) throw new IllegalArgumentException("Empty patch path");
        String p = raw.trim();
        // strip leading slash if present
        if (p.startsWith("/")) p = p.substring(1);
        // convert dot notation to slashes
        p = p.replace('.', '/');
        // collapse accidental double slashes
        while (p.contains("//")) p = p.replace("//", "/");
        return "/" + p;
    }
}

Example usage

// Build container once (pk path = /correlationId)
CosmosClient client = new CosmosClientBuilder()
    .endpoint(System.getenv("COSMOS_URI"))
    .key(System.getenv("COSMOS_KEY"))
    .contentResponseOnWriteEnabled(true)
    .buildClient();
CosmosContainer container = client
    .getDatabase("notification_reporting_db")
    .getContainer("message_workflow");

// 1) Ensure doc exists (first stage)
CosmosReportingUtil.createIfNotExists(container, "corr-123");

// 2) Patch a few fields later (add or update)
CosmosReportingUtil.patchFields(container, "corr-123", Map.of(
    "workflowStatus", "IN_PROGRESS",
    "stages.scheduledConsumer.status", "PROCESSED",
    "stages.scheduledConsumer.processedAt", Instant.now().toString(),
    "delivery.httpStatus", 202
));

// 3) Read when needed
var doc = CosmosReportingUtil.read(container, "corr-123");
System.out.println(doc.toPrettyString());

Notes
	•	Keys in the map can be "a.b.c" or "/a/b/c"; the helper normalizes to JSON Pointer.
	•	If the document doesn’t exist, patchFields creates it first (minimal shape), then applies your updates.
	•	This uses PATCH (cheap RUs) and grows the document over time as you add fields.