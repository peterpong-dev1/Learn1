// Start with the basics (you already do this)
Map<String, Object> fieldsContext = new HashMap<>();
fieldsContext.putAll(parsedMessage.getExtractedFields());  // applicationNumber, policyId, etc.

// Collect all ARNs
List<String> arns = new ArrayList<>();
Object arnsObj = parsedMessage.getExtractedFields().get("agentRegistrationNumbers");
if (arnsObj instanceof List<?>) {
    for (Object o : (List<?>) arnsObj) {
        if (o != null && !o.toString().isBlank()) arns.add(o.toString());
    }
} else if (arnsObj instanceof String s && !s.isBlank()) {
    arns.add(s);  // fallback: single string
}
arns = arns.stream().distinct().toList();

// For each ARN → resolve agent info
List<Map<String,Object>> agentInfos = new ArrayList<>();

for (String arn : arns) {
    Map<String,Object> agent = new LinkedHashMap<>();
    agent.put("agentRegistrationNumber", arn);

    try {
        // 👇 call your existing lookup logic here
        Map<String,Object> perAgentCtx = new HashMap<>();
        perAgentCtx.putAll(parsedMessage.getExtractedFields());
        perAgentCtx.put("agentRegistrationNumber", arn);

        Map<String,Object> execResult = new LookupExecutor().executeLookupSteps(perAgentCtx, rule);
        if (!Boolean.TRUE.equals(execResult.get("ok"))) {
            agent.put("errorCode", execResult.get("errorCode"));
            agent.put("message",  execResult.get("message"));
        } else {
            // Copy only outputs you care about from perAgentCtx
            copyIfPresent(perAgentCtx, agent, "email1");
            copyIfPresent(perAgentCtx, agent, "agencyName");
            copyIfPresent(perAgentCtx, agent, "agencyNumber");
            copyIfPresent(perAgentCtx, agent, "recipient.name.kanji");
            copyIfPresent(perAgentCtx, agent, "recipient.name.kana");
            copyIfPresent(perAgentCtx, agent, "recipient.name.alphabet");
            copyIfPresent(perAgentCtx, agent, "recipient.phone");
        }
    } catch (Exception e) {
        agent.put("error", "Lookup failed: " + e.getMessage());
    }

    agentInfos.add(agent);
}

// ✅ Add to your main context
fieldsContext.put("agents", agentInfos);

// Helper
private static void copyIfPresent(Map<String,Object> src, Map<String,Object> dst, String key) {
    Object v = src.get(key);
    if (v == null) return;
    if (v instanceof com.fasterxml.jackson.databind.JsonNode j) {
        if (j.isArray() && j.size()==1) v = j.get(0);
        v = j.isValueNode() ? j.asText() : j.toString();
    }
    dst.put(key, v);
}