Utility (returns if first time)

public enum ScheduleResult { CREATED_AND_SHOULD_SEND, ALREADY_PRESENT }

public static ScheduleResult ensureSummaryRow(TableClient controlTable,
                                              String agentId, String dayYMD,
                                              String messageId) {
    String pk = dayYMD + "#" + agentId;   // per-agent/day partition
    String rk = "summary";

    TableEntity e = new TableEntity(pk, rk)
        .addProperty("claimedAtUtc", java.time.Instant.now().toString())
        .addProperty("claimerMsgId", messageId);

    try {
        controlTable.createEntity(e);      // INSERT only
        return ScheduleResult.CREATED_AND_SHOULD_SEND; // first time
    } catch (com.azure.data.tables.models.TableServiceException ex) {
        if (ex.getResponse().getStatusCode() == 409) {
            return ScheduleResult.ALREADY_PRESENT;     // someone else did it
        }
        throw ex; // other errors bubble up
    }
}

