package com.yourorg.messageapi.service;

import com.azure.cosmos.*;
import com.azure.cosmos.models.CosmosQueryRequestOptions;
import com.azure.cosmos.models.FeedResponse;
import com.fasterxml.jackson.databind.JsonNode;
import com.yourorg.messageapi.model.IncomingMessage;
import com.yourorg.messageapi.util.CosmosClientProvider;

import java.util.logging.Logger;

/**
 * Resolves recipient information (agent/customer) by querying Cosmos DB directly.
 * Example shows a simple lookup; adjust SQL and containers per your schema.
 */
public final class RecipientService {
    private RecipientService(){}

    public static boolean resolve(IncomingMessage msg, Logger log) {
        try {
            // Example: lookup recipient by docId in a "Directory" container
            CosmosClient client = CosmosClientProvider.client();
            CosmosContainer container = client
                    .getDatabase(System.getenv("DirectoryDb"))
                    .getContainer(System.getenv("DirectoryContainer"));

            String sql = "SELECT TOP 1 c.recipientType, c.recipientId, c.email " +
                         "FROM c WHERE c.docId = @docId";
            SqlParameterList params = new SqlParameterList(new SqlParameter("@docId", msg.getDocId()));

            CosmosPagedIterable<JsonNode> results = container.queryItems(
                    new SqlQuerySpec(sql, params),
                    new CosmosQueryRequestOptions(),
                    JsonNode.class
            );

            JsonNode first = results.stream().findFirst().orElse(null);
            if (first == null) {
                log.warning("RecipientService: no recipient found for docId=" + msg.getDocId());
                return false; // no recipient => stop
            }

            msg.setRecipientType(first.path("recipientType").asText("unknown"));
            msg.setRecipientId(first.path("recipientId").asText(null));
            msg.setRecipientEmail(first.path("email").asText(null));

            if (msg.getRecipientId() == null && msg.getRecipientEmail() == null) {
                log.warning("RecipientService: recipient lacks id/email for docId=" + msg.getDocId());
                return false;
            }
            return true;

        } catch (Exception e) {
            log.severe("RecipientService error: " + e.getMessage());
            return false;
        }
    }
}


