1) ErrorBlobWriter — writes a JSON error record to a blob

package com.yourco.notification.errors;

import com.azure.core.util.BinaryData;
import com.azure.storage.blob.BlobClient;
import com.azure.storage.blob.BlobContainerClient;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.time.Instant;
import java.util.Map;
import java.util.logging.Level;
import java.util.logging.Logger;

/** Stateless helper to persist error details to Blob Storage. */
public final class ErrorBlobWriter {
    private static final ObjectMapper M = new ObjectMapper();

    private ErrorBlobWriter() {}

    /**
     * Writes an error JSON blob named: {docIdOrUnknown}_{UTC}.json
     */
    public static void write(
            String reason,
            String rawBody,                       // raw Service Bus body (may be null)
            Object parsedMessageOrNull,           // your IncomingMessage or null if parse failed
            Map<String, Object> headers,          // envelope headers you collected
            BlobContainerClient errorContainer,
            Logger log
    ) {
        try {
            String ts = Instant.now().toString().replace(":", "-");
            String docId = safeDocId(parsedMessageOrNull);
            String name = (docId.isBlank() ? "unknownDoc" : docId) + "_" + ts + ".json";

            ObjectNode root = M.createObjectNode();
            root.put("timestamp", Instant.now().toString());
            root.put("reason", reason);
            if (rawBody != null) root.put("rawBody", rawBody);
            if (headers != null) root.putPOJO("headers", headers);
            if (parsedMessageOrNull != null) root.putPOJO("message", parsedMessageOrNull);

            BlobClient blob = errorContainer.getBlobClient(name);
            blob.upload(BinaryData.fromString(M.writeValueAsString(root)), true);

            log.info("Error blob written: " + name + " (reason=" + reason + ")");
        } catch (Exception e) {
            log.log(Level.SEVERE, "Failed to write error blob", e);
        }
    }

    private static String safeDocId(Object msg) {
        try {
            if (msg == null) return "";
            // Uses reflection to avoid hard coupling; replace with ((IncomingMessage)msg).getDocId() if you prefer.
            var m = msg.getClass().getMethod("getDocId");
            Object v = m.invoke(msg);
            return v == null ? "" : v.toString();
        } catch (Exception ignore) {
            return "";
        }
    }
}


