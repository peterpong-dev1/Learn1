1️⃣ DTO (Calender.java)

Handles conversion between epoch milliseconds (DB format) and yyyy-MM-dd (API format).

package com.example.calendar.dto;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

import java.time.Instant;
import java.time.LocalDate;
import java.time.ZoneId;
import java.time.format.DateTimeFormatter;

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Calender {

    private String id;
    private String calendarDay; // Matches Swagger (yyyy-MM-dd)
    private boolean businessDayFlag;

    public static String convertEpochToDate(long epochMillis) {
        return Instant.ofEpochMilli(epochMillis)
                .atZone(ZoneId.systemDefault())
                .toLocalDate()
                .format(DateTimeFormatter.ISO_LOCAL_DATE);
    }

    public static long convertDateToEpoch(String date) {
        return LocalDate.parse(date, DateTimeFormatter.ISO_LOCAL_DATE)
                .atStartOfDay(ZoneId.systemDefault())
                .toInstant()
                .toEpochMilli();
    }
}

2️⃣ DTO (CalenderSearchConditions.java)

Handles search conditions validation.

package com.example.calendar.dto;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

import javax.validation.constraints.NotNull;
import java.time.LocalDate;

@Data
@NoArgsConstructor
@AllArgsConstructor
public class CalenderSearchConditions {

    private String startDate;
    private String endDate;

    public void validateDates() {
        if (startDate != null && endDate != null) {
            LocalDate start = LocalDate.parse(startDate);
            LocalDate end = LocalDate.parse(endDate);
            if (start.isAfter(end)) {
                throw new IllegalArgumentException("Start date cannot be after end date.");
            }
        }
    }
}

