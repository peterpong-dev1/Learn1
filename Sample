@startuml
skinparam packageStyle rectangle
skinparam linetype ortho
top to bottom direction

' Node definitions
class CommonSearchApplication
package interceptor
package controller
package service
package repository
package entity
package mapper
package dto
package exception
package logging
package utils

' Main flow
CommonSearchApplication --> interceptor
interceptor --> controller
controller --> service
service --> repository
repository --> entity

' Mapper and DTO
service --> mapper
mapper --> dto
controller --> dto

' Exception handling (red dashed)
service ..[#red,dashed]> exception
repository ..[#red,dashed]> exception
exception --> logging

' Utils usage (dotted)
controller ..> utils
service ..> utils

@enduml