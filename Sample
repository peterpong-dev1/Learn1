package jp.co.mycompany.servicing.config;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.context.annotation.Configuration;
import org.springframework.core.io.Resource;
import org.springframework.util.StreamUtils;

import javax.annotation.PostConstruct;
import java.nio.charset.StandardCharsets;
import java.util.Properties;

@Configuration
public class QueryConfig {

    @Value("classpath:queries.properties")
    private Resource queriesResource;

    private Properties queries = new Properties();

    @PostConstruct
    public void loadQueries() throws Exception {
        queries.load(StreamUtils.copyToString(queriesResource.getInputStream(), StandardCharsets.UTF_8)
                .lines()
                .map(line -> line.split("=", 2))
                .collect(Properties::new, (props, pair) -> props.setProperty(pair[0].trim(), pair[1].trim()), Properties::putAll));
    }

    public String getQuery(String key) {
        return queries.getProperty(key);
    }
}

