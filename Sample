public class TransactionProgressMapper {

    public TransactionProgressDTO toDTO(TransactionProgressEntity entity) {
        if (entity == null) return null;

        TransactionProgressDTO dto = new TransactionProgressDTO();

        dto.setId(entity.getId());
        dto.setPolicyId(entity.getPolicyId());
        dto.setPremiumHistoryNumber(entity.getPremiumHistoryNumber());
        dto.setCombinedPremiumHistoryNumber(entity.getCombinedPremiumHistoryNumber());
        dto.setCanceledPremiumHistoryNumber(entity.getCanceledPremiumHistoryNumber());
        dto.setPremiumProcessingDateTime(entity.getPremiumProcessingDateTime());
        dto.setDepositProcessingSettlementSequence(entity.getDepositProcessingSettlementSequence());
        dto.setTotalPremiumDepositAmount(entity.getTotalPremiumDepositAmount());
        dto.setDepositMonthsAndYears(entity.getDepositMonthsAndYears());
        dto.setOperationCode(entity.getOperationCode());
        dto.setAccountJournalCode(entity.getAccountJournalCode());
        dto.setPremiumAmount(entity.getPremiumAmount());
        dto.setUnearnedPremiumAmount(entity.getUnearnedPremiumAmount());
        dto.setClaimProcessingSerialNumber(entity.getClaimProcessingSerialNumber());
        dto.setDepositChannel(entity.getDepositChannel());
        dto.setDepositType(entity.getDepositType());
        dto.setDepositForMonth(entity.getDepositForMonth());
        dto.setDepositMonths(entity.getDepositMonths());
        dto.setDepositAcceptDate(entity.getDepositAcceptDate());
        dto.setDepositProcessingDate(entity.getDepositProcessingDate());
        dto.setAmountPaid(entity.getAmountPaid());
        dto.setAmountReceived(entity.getAmountReceived());
        dto.setTransferFee(entity.getTransferFee());
        dto.setConsumptionTaxEquivalent(entity.getConsumptionTaxEquivalent());
        dto.setNoPostProcessingRequired(entity.isNoPostProcessingRequired());
        dto.setInputPerson(entity.getInputPerson());
        dto.setOnlineBatchIdentifierType(entity.getOnlineBatchIdentifierType());
        dto.setAdministratorAccessLevelType(entity.getAdministratorAccessLevelType());
        dto.setDeductionCertificateYear(entity.getDeductionCertificateYear());
        dto.setDeductionCertificateGeneralPremiumAmount(entity.getDeductionCertificateGeneralPremiumAmount());
        dto.setDeductionCertificateIndividualPensionPremiumAmount(entity.getDeductionCertificateIndividualPensionPremiumAmount());
        dto.setDeductionCertificateLongTermCareMedicinePremiumAmount(entity.getDeductionCertificateLongTermCareMedicinePremiumAmount());
        dto.setDeductionCertificateOtherPremiumAmount(entity.getDeductionCertificateOtherPremiumAmount());
        dto.setDeductionCertificatePremiumAvailability(entity.getDeductionCertificatePremiumAvailability());
        dto.setAccountingCorrectionTemporaryReceiptB2(entity.getAccountingCorrectionTemporaryReceiptB2());
        dto.setAccountingCorrectionOtherTemporaryReceipts(entity.getAccountingCorrectionOtherTemporaryReceipts());
        dto.setAccountingCorrectionRefund(entity.getAccountingCorrectionRefund());
        dto.setAccountingCorrectionFirstPremium(entity.getAccountingCorrectionFirstPremium());

        return dto;
    }
}