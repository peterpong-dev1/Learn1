✅ In Your Azure Function Class

@FunctionName("ProcessChangeFeed")
public void run(
    @CosmosDBTrigger(
        name = "items",
        databaseName = "%COSMOS_DB_NAME%",
        containerName = "%COSMOS_CONTAINER_NAME%",
        leaseContainerName = "%LEASE_CONTAINER%",
        connection = "COSMOS_CONNECTION",
        createLeaseContainerIfNotExists = true
    ) List<ObjectNode> items,
    final ExecutionContext context) {

    String blobConnection = EnvironmentUtil.getSetting("BLOB_CONNECTION");
    String blobContainer = EnvironmentUtil.getSetting("BLOB_CONTAINER_NAME");
    Map<String, List<String>> trackedConfig = EnvironmentUtil.getTrackedFieldConfig();

    TrackedChangeHandler handler = new TrackedChangeHandler(blobConnection, blobContainer, trackedConfig, 3);

    for (ObjectNode doc : items) {
        handler.handle(System.getenv("COSMOS_CONTAINER_NAME"), doc);
    }
}


