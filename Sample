import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import jp.co.mycompany.servicing.dto.FinancialInstitutionDTO;
import jp.co.mycompany.servicing.model.FinancialInstitution;
import jp.co.mycompany.servicing.repository.FinancialInstitutionRepository;
import jp.co.mycompany.servicing.service.FinancialInstitutionService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.List;

class FinancialInstitutionServiceTest {

    @Mock
    private FinancialInstitutionRepository repository;  // Mocked repository

    @InjectMocks
    private FinancialInstitutionService service;  // Service under test

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }

    @Test
    void testSearchInstitutions_ByCode_ReturnsResults() {
        // Mock repository response
        List<FinancialInstitution> mockResults = List.of(new FinancialInstitution("123", "Bank A"));
        when(repository.findByFinancialInstitutionCode("123")).thenReturn(mockResults);

        // Call service method
        List<FinancialInstitutionDTO> results = service.searchInstitutions("123", null, null);

        // Assertions
        assertEquals(1, results.size());
        assertEquals("Bank A", results.get(0).getName());
        
        // Verify correct method was called once
        verify(repository, times(1)).findByFinancialInstitutionCode("123");
    }

    @Test
    void testSearchInstitutions_NoResults_ReturnsEmptyList() {
        when(repository.findByFinancialInstitutionCode(anyString())).thenReturn(List.of());

        List<FinancialInstitutionDTO> results = service.searchInstitutions("999", null, null);

        assertTrue(results.isEmpty());
        verify(repository, times(1)).findByFinancialInstitutionCode("999");
    }

    @Test
    void testSearchInstitutions_ThrowsException() {
        when(repository.findByFinancialInstitutionCode(anyString())).thenThrow(new RuntimeException("Database error"));

        Exception exception = assertThrows(RuntimeException.class, () -> service.searchInstitutions("123", null, null));

        assertEquals("Database error", exception.getMessage());
        verify(repository, times(1)).findByFinancialInstitutionCode("123");
    }

    @Test
    void testSearchInstitutions_AllFieldsEmpty_ThrowsBadRequestException() {
        Exception exception = assertThrows(IllegalArgumentException.class, () -> service.searchInstitutions(null, null, null));

        assertEquals("At least one search field must be provided.", exception.getMessage());
    }
}

