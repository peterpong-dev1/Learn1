public List<FinancialInstitutionDTO> searchInstitutions(FinancialInstitutionSearchConditionsDTO searchCondition) {
    if (searchCondition == null || (
            searchCondition.getFinancialInstitutionCode() == null &&
            searchCondition.getFinancialInstitutionBranchCode() == null &&
            searchCondition.getName() == null &&
            searchCondition.getOrderCode() == null &&
            searchCondition.getNameKana() == null)) {
        throw new IllegalArgumentException("At least one search condition must be provided.");
    }

    List<FinancialInstitutionModel> institutions = financialInstitutionRepository.searchWithDynamicQuery(searchCondition);

    if (institutions.isEmpty()) {
        throw new IllegalArgumentException("No matching financial institutions found."); // Return 400
    }

    return institutions.stream().map(financialInstitutionMapper::toDTO).toList();
}

