2. Updated CalendarRepository with Dynamic Query Logic

This repository dynamically selects and executes the correct query based on the input conditions.

package com.example.calendar.repository;

import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.CosmosClient;
import com.azure.cosmos.CosmosDatabase;
import com.azure.cosmos.models.SqlQuerySpec;
import com.azure.cosmos.models.CosmosQueryRequestOptions;
import com.azure.cosmos.models.SqlParameter;
import com.example.calendar.entity.CalenderEntity;
import com.example.calendar.config.QueryConfig;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Repository;

import java.util.ArrayList;
import java.util.List;

@Repository
@RequiredArgsConstructor
@Slf4j
public class CalendarRepository {

    private final CosmosClient cosmosClient;
    private final QueryConfig queryConfig;

    private static final String DATABASE_NAME = "CalendarDB";
    private static final String CONTAINER_NAME = "CalendarContainer";

    private CosmosContainer getContainer() {
        CosmosDatabase database = cosmosClient.getDatabase(DATABASE_NAME);
        return database.getContainer(CONTAINER_NAME);
    }

    public List<CalenderEntity> findByDateRange(String startDate, String endDate) {
        log.info("Fetching calendar data for startDate: {} and endDate: {}", startDate, endDate);

        String query;
        List<SqlParameter> parameters = new ArrayList<>();

        if (!"0000-01-01".equals(startDate) && !"9999-12-31".equals(endDate)) {
            // Case: Both startDate and endDate provided
            query = queryConfig.getQuery("find_by_date_range");
            parameters.add(new SqlParameter("@startDate", startDate));
            parameters.add(new SqlParameter("@endDate", endDate));
        } else if (!"0000-01-01".equals(startDate)) {
            // Case: Only startDate provided
            query = queryConfig.getQuery("find_by_start_date");
            parameters.add(new SqlParameter("@startDate", startDate));
        } else if (!"9999-12-31".equals(endDate)) {
            // Case: Only endDate provided
            query = queryConfig.getQuery("find_by_end_date");
            parameters.add(new SqlParameter("@endDate", endDate));
        } else {
            // Case: No date provided (Fetch all records)
            query = queryConfig.getQuery("find_all");
        }

        SqlQuerySpec sqlQuerySpec = new SqlQuerySpec(query, parameters);

        CosmosContainer container = getContainer();
        List<CalenderEntity> results = new ArrayList<>();

        container.queryItems(sqlQuerySpec, new CosmosQueryRequestOptions(), CalenderEntity.class)
                .forEach(results::add);

        log.info("Found {} results", results.size());
        return results;
    }
}

3. Explanation of the Dynamic Query Logic

This repository selects the correct query based on the user’s input.

Scenario	Selected Query	Applied Parameters
Start Date & End Date provided	find_by_date_range	@startDate, @endDate
Only Start Date provided	find_by_start_date	@startDate
Only End Date provided	find_by_end_date	@endDate
No Dates provided	find_all	None

4. Updates in CalendarService to Handle Defaults

We ensure defaults for missing start and end dates before calling the repository.

package com.example.calendar.service;

import com.example.calendar.dto.Calender;
import com.example.calendar.dto.CalenderSearchConditions;
import com.example.calendar.mapper.CalendarMapper;
import com.example.calendar.repository.CalendarRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class CalendarService {

    private final CalendarRepository calendarRepository;

    public List<Calender> searchCalendar(String requestId, CalenderSearchConditions searchConditions) {
        log.info("Processing calendar search for requestId: {}", requestId);

        // Validate input dates
        searchConditions.validateDates();

        // Apply default date values
        String startDate = searchConditions.getStartDate() != null ? searchConditions.getStartDate().toString() : "0000-01-01";
        String endDate = searchConditions.getEndDate() != null ? searchConditions.getEndDate().toString() : "9999-12-31";

        List<Calender> calendars = CalendarMapper.toDtoList(
                calendarRepository.findByDateRange(startDate, endDate)
        );

        if (calendars.isEmpty()) {
            log.warn("No calendar data found for requestId: {}", requestId);
        }

        return calendars;
    }
}

5. Error Handling for Validation

Ensuring that invalid inputs return meaningful errors.

package com.example.calendar.exception;

import com.example.calendar.dto.ErrorResponse;
import com.example.calendar.dto.ErrorDetail;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.MethodArgumentNotValidException;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;

import java.util.List;
import java.util.stream.Collectors;

@RestControllerAdvice
public class GlobalExceptionHandler {

    @ExceptionHandler(IllegalArgumentException.class)
    public ResponseEntity<ErrorResponse> handleIllegalArgumentException(IllegalArgumentException ex) {
        ErrorResponse response = new ErrorResponse("400", ex.getMessage(), null);
        return new ResponseEntity<>(response, HttpStatus.BAD_REQUEST);
    }

    @ExceptionHandler(Exception.class)
    public ResponseEntity<ErrorResponse> handleGenericException(Exception ex) {
        ErrorResponse response = new ErrorResponse("500", "Internal server error", null);
        return new ResponseEntity<>(response, HttpStatus.INTERNAL_SERVER_ERROR);
    }
}

