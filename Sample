package jp.co.neofirst.servicing.repository;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.models.CosmosQueryRequestOptions;
import com.azure.cosmos.models.SqlQuerySpec;
import jp.co.neofirst.servicing.config.QueryPropertyFileConfig;
import jp.co.neofirst.servicing.dto.FinancialInstitutionSearchConditionsDTO;
import jp.co.neofirst.servicing.model.FinancialInstitutionModel;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.Collections;
import java.util.List;

@ExtendWith(MockitoExtension.class)
class FinancialInstitutionRepositoryTest {

    @Mock
    private CosmosContainer cosmosContainer;

    @Mock
    private QueryPropertyFileConfig queryConfig;

    @InjectMocks
    private FinancialInstitutionRepository financialInstitutionRepository;

    @BeforeEach
    void setUp() {
        when(queryConfig.getQuery("baseQuery")).thenReturn("SELECT * FROM c WHERE 1=1");
        when(queryConfig.getQuery("filterByCode")).thenReturn("AND c.financialInstitutionCode = @code");
        when(queryConfig.getQuery("filterByBranchCode")).thenReturn("AND c.financialInstitutionBranchCode = @branch");
        when(queryConfig.getQuery("filterByName")).thenReturn("AND c.name = @name");
        when(queryConfig.getQuery("filterByNameKana")).thenReturn("AND c.nameKana = @nameKana");
        when(queryConfig.getQuery("filterByOrder")).thenReturn("AND c.orderCode = @orderCode");
    }

    @Test
    void testSearchWithDynamicQuery_NoResults() {
        // Arrange
        FinancialInstitutionSearchConditionsDTO searchConditions = new FinancialInstitutionSearchConditionsDTO();
        searchConditions.setFinancialInstitutionCode("999");

        // ✅ Instead of `CosmosPagedIterable`, use an empty list that can be streamed
        Iterable<FinancialInstitutionModel> mockIterable = Collections.emptyList();

        when(cosmosContainer.queryItems(any(SqlQuerySpec.class), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class)))
            .thenReturn(mockIterable); // ✅ Correct return type for `queryItems()`

        // Act
        List<FinancialInstitutionModel> result = financialInstitutionRepository.searchWithDynamicQuery(searchConditions);

        // Assert
        assertNotNull(result);
        assertTrue(result.isEmpty());
    }

    @Test
    void testSearchWithDynamicQuery_AllFiltersApplied() {
        // Arrange
        FinancialInstitutionSearchConditionsDTO searchConditions = new FinancialInstitutionSearchConditionsDTO();
        searchConditions.setFinancialInstitutionCode("123");
        searchConditions.setFinancialInstitutionBranchCode("456");
        searchConditions.setName("Test Bank");
        searchConditions.setNameKana("テスト銀行");
        searchConditions.setOrderCode("789");

        // Mock database response
        Iterable<FinancialInstitutionModel> mockIterable = Collections.emptyList();
        when(cosmosContainer.queryItems(any(SqlQuerySpec.class), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class)))
                .thenReturn(mockIterable);

        // Act
        List<FinancialInstitutionModel> result = financialInstitutionRepository.searchWithDynamicQuery(searchConditions);

        // Assert
        assertNotNull(result);
        assertTrue(result.isEmpty());

        // Capture the generated query
        ArgumentCaptor<SqlQuerySpec> queryCaptor = ArgumentCaptor.forClass(SqlQuerySpec.class);
        verify(cosmosContainer).queryItems(queryCaptor.capture(), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class));

        String capturedQuery = queryCaptor.getValue().getQueryText();
        assertTrue(capturedQuery.contains("AND c.financialInstitutionCode = @code"));
        assertTrue(capturedQuery.contains("AND c.financialInstitutionBranchCode = @branch"));
        assertTrue(capturedQuery.contains("AND c.name = @name"));
        assertTrue(capturedQuery.contains("AND c.nameKana = @nameKana"));
        assertTrue(capturedQuery.contains("AND c.orderCode = @orderCode"));
    }

    @Test
    void testSearchWithDynamicQuery_OnlyFinancialInstitutionCode() {
        // Arrange
        FinancialInstitutionSearchConditionsDTO searchConditions = new FinancialInstitutionSearchConditionsDTO();
        searchConditions.setFinancialInstitutionCode("123");

        // Mock database response
        Iterable<FinancialInstitutionModel> mockIterable = Collections.emptyList();
        when(cosmosContainer.queryItems(any(SqlQuerySpec.class), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class)))
                .thenReturn(mockIterable);

        // Act
        List<FinancialInstitutionModel> result = financialInstitutionRepository.searchWithDynamicQuery(searchConditions);

        // Assert
        assertNotNull(result);
        assertTrue(result.isEmpty());

        // Capture query
        ArgumentCaptor<SqlQuerySpec> queryCaptor = ArgumentCaptor.forClass(SqlQuerySpec.class);
        verify(cosmosContainer).queryItems(queryCaptor.capture(), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class));

        String capturedQuery = queryCaptor.getValue().getQueryText();
        assertTrue(capturedQuery.contains("AND c.financialInstitutionCode = @code"));
        assertFalse(capturedQuery.contains("AND c.financialInstitutionBranchCode"));
    }

    @Test
    void testSearchWithDynamicQuery_EmptyRequest_ShouldReturn400() {
        // Arrange
        FinancialInstitutionSearchConditionsDTO searchConditions = new FinancialInstitutionSearchConditionsDTO();

        // Act & Assert
        IllegalArgumentException thrown = assertThrows(IllegalArgumentException.class, () -> {
            financialInstitutionRepository.searchWithDynamicQuery(searchConditions);
        });

        assertEquals("At least one search condition is required", thrown.getMessage());
    }

    @Test
    void testSearchWithDynamicQuery_ExceptionHandling() {
        // Arrange
        FinancialInstitutionSearchConditionsDTO searchConditions = new FinancialInstitutionSearchConditionsDTO();
        searchConditions.setFinancialInstitutionCode("999");

        when(cosmosContainer.queryItems(any(SqlQuerySpec.class), any(CosmosQueryRequestOptions.class), eq(FinancialInstitutionModel.class)))
                .thenThrow(new RuntimeException("Database error"));

        // Act & Assert
        RuntimeException thrown = assertThrows(RuntimeException.class, () -> {
            financialInstitutionRepository.searchWithDynamicQuery(searchConditions);
        });

        assertEquals("Database error", thrown.getMessage());
    }
}

