    String corrId = docId + "|" + evt.id + "|" + when + "|" + context.getInvocationId();

    EventMessage payload = MessageFactory.build(
            evt,
            when,
            cosmosDbContainerName,
            docId,
            newDoc,
            previousETag,           // you already have it
            null,                   // lsn if you have it; else null
            corrId,
            deltas,                 // your tracked-field deltas (empty on CREATE is fine)
            Map.of("function", context.getFunctionName())
    );

    // headers for filtering / analytics
    Map<String,String> headers = Map.of(
            "container", cosmosDbContainerName,
            "eventId",   evt.id,
            "docId",     docId,
            "when",      when
    );

    // If you enabled sessions and want per-doc ordering, pass docId; else null
    String sessionId = Boolean.parseBoolean(System.getenv("ServiceBusUseSessions")) ? docId : null;

    ServiceBusSenderProvider.send(payload, headers, sessionId, context.getLogger());
}


