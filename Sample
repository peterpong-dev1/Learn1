Gotcha—you want a production-style model (getters, no public fields) based on the screenshots, plus a tiny parser you can call from your Function. Here you go.

1) Immutable model: IncomingMessage.java

package com.neo.notification.msgprocessing;

import java.time.OffsetDateTime;
import java.util.List;
import java.util.Map;

import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonIgnoreProperties;
import com.fasterxml.jackson.annotation.JsonProperty;

/**
 * Envelope we put on Service Bus and consume in the Message API Function.
 * Immutable, Jackson-friendly (constructor binding), and accessor-only.
 */
@JsonIgnoreProperties(ignoreUnknown = true)
public final class IncomingMessage {

    // ---------- nested types ----------

    /** Minimal tracked change emitted by the producer. */
    @JsonIgnoreProperties(ignoreUnknown = true)
    public static final class Delta {
        private final String field;   // e.g. "/applicationStatus"
        private final String kind;    // ADDED | REMOVED | MODIFIED
        private final String oldValue;
        private final String newValue;

        @JsonCreator
        public Delta(
            @JsonProperty("field") String field,
            @JsonProperty("kind") String kind,
            @JsonProperty("old")  String oldValue,
            @JsonProperty("new")  String newValue) {
            this.field = field;
            this.kind = kind;
            this.oldValue = oldValue;
            this.newValue = newValue;
        }
        public String getField()    { return field; }
        public String getKind()     { return kind; }
        public String getOldValue() { return oldValue; }
        public String getNewValue() { return newValue; }

        @Override public String toString() {
            return "Delta{field=" + field + ", kind=" + kind +
                   ", old=" + oldValue + ", new=" + newValue + "}";
        }
    }

    /** Optional notification hint carried by producer. */
    @JsonIgnoreProperties(ignoreUnknown = true)
    public static final class NotifyMeta {
        private final String notificationType; // e.g. "unpaid" | "transaction" | "newBusiness"
        private final String triggerType;      // e.g. "notice" | "dunning" | "received"
        @JsonCreator
        public NotifyMeta(
            @JsonProperty("notificationType") String notificationType,
            @JsonProperty("triggerType")      String triggerType) {
            this.notificationType = notificationType;
            this.triggerType = triggerType;
        }
        public String getNotificationType() { return notificationType; }
        public String getTriggerType()      { return triggerType; }
    }

    // ---------- core envelope ----------

    private final String correlationId;
    private final String messageId;
    private final OffsetDateTime createdAtUtc;

    // ---------- producer/event info ----------
    private final String container;
    private final String docId;
    private final String eventId;
    private final String eventName;
    private final String when; // "insert" | "update"

    // ---------- data ----------
    private final List<Delta> deltas;            // may be empty on insert
    private final Map<String,Object> context;    // optional (_etag, _lsn, etc.)
    private final NotifyMeta notify;             // optional
    private final Map<String,String> keys;       // optional (already-resolved keys)

    @JsonCreator
    public IncomingMessage(
        @JsonProperty("correlationId") String correlationId,
        @JsonProperty("messageId")     String messageId,
        @JsonProperty("createdAtUtc")  OffsetDateTime createdAtUtc,

        @JsonProperty("container")     String container,
        @JsonProperty("docId")         String docId,
        @JsonProperty("eventId")       String eventId,
        @JsonProperty("eventName")     String eventName,
        @JsonProperty("when")          String when,

        @JsonProperty("deltas")        List<Delta> deltas,
        @JsonProperty("context")       Map<String,Object> context,
        @JsonProperty("notify")        NotifyMeta notify,
        @JsonProperty("keys")          Map<String,String> keys
    ) {
        this.correlationId = correlationId;
        this.messageId = messageId;
        this.createdAtUtc = createdAtUtc;
        this.container = container;
        this.docId = docId;
        this.eventId = eventId;
        this.eventName = eventName;
        this.when = when;
        this.deltas = deltas;
        this.context = context;
        this.notify = notify;
        this.keys = keys;
    }

    // ---------- getters (no setters) ----------
    public String getCorrelationId() { return correlationId; }
    public String getMessageId()     { return messageId; }
    public OffsetDateTime getCreatedAtUtc() { return createdAtUtc; }

    public String getContainer() { return container; }
    public String getDocId()     { return docId; }
    public String getEventId()   { return eventId; }
    public String getEventName() { return eventName; }
    public String getWhen()      { return when; }

    public List<Delta> getDeltas()          { return deltas; }
    public Map<String,Object> getContext()  { return context; }
    public NotifyMeta getNotify()           { return notify; }
    public Map<String,String> getKeys()     { return keys; }

    @Override public String toString() {
        return "IncomingMessage{eventId=" + eventId +
               ", docId=" + docId + ", container=" + container + "}";
    }
}

2) Small parser utility: ParseService.java

package com.neo.notification.msgprocessing;

import java.nio.charset.StandardCharsets;
import java.time.OffsetDateTime;
import java.util.Map;
import java.util.Objects;

import com.fasterxml.jackson.databind.DeserializationFeature;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.json.JsonMapper;

/**
 * Stateless parser for Service Bus payloads.
 * Safe: never throws; returns null on irrecoverable issues so the caller can dead-letter.
 */
public final class ParseService {
    private ParseService() {}

    private static final ObjectMapper MAPPER = JsonMapper.builder()
        .disable(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES)
        .findAndAddModules()               // for Java time
        .build();

    /**
     * Parse the JSON body into {@link IncomingMessage}, while also echoing SB headers.
     *
     * @param bodyBytes message body as bytes
     * @param headers   SB trigger bindings (MessageId, CorrelationId, DeliveryCount)
     * @return IncomingMessage or null if malformed
     */
    public static IncomingMessage parseSafe(byte[] bodyBytes, Map<String,String> headers) {
        try {
            if (bodyBytes == null || bodyBytes.length == 0) return null;

            // Deserialize JSON body
            IncomingMessage msg = MAPPER.readValue(bodyBytes, IncomingMessage.class);
            if (msg == null) return null;

            // If producer forgot some envelope fields, lightly patch from headers (non-invasive).
            String hMsgId  = headers.getOrDefault("MessageId", null);
            String hCorrId = headers.getOrDefault("CorrelationId", null);

            // If both present in body, keep body; otherwise, re-hydrate using a small re-map.
            String correlationId = (msg.getCorrelationId() != null) ? msg.getCorrelationId() : hCorrId;
            String messageId     = (msg.getMessageId()     != null) ? msg.getMessageId()     : hMsgId;
            OffsetDateTime created = (msg.getCreatedAtUtc() != null) ? msg.getCreatedAtUtc() : OffsetDateTime.now();

            // If nothing core is present, treat as malformed.
            if (isBlank(correlationId) || isBlank(messageId) || isBlank(msg.getDocId()) || isBlank(msg.getEventId())) {
                return null;
            }

            // Rebuild an immutable instance with patched envelope if needed.
            return new IncomingMessage(
                correlationId,
                messageId,
                created,
                msg.getContainer(),
                msg.getDocId(),
                msg.getEventId(),
                msg.getEventName(),
                msg.getWhen(),
                msg.getDeltas(),
                msg.getContext(),
                msg.getNotify(),
                msg.getKeys()
            );
        } catch (Exception ex) {
            return null;
        }
    }

    private static boolean isBlank(String s) {
        return s == null || s.trim().isEmpty();
    }

    /** Convenience overload when you have body as String. */
    public static IncomingMessage parseSafe(String body, Map<String,String> headers) {
        byte[] bytes = (body == null) ? null : body.getBytes(StandardCharsets.UTF_8);
        return parseSafe(bytes, headers);
    }
}

3) How to call it from your Function (concise)

// inside your @ServiceBusQueueTrigger function:
Map<String,String> hdr = Map.of(
    "MessageId",     messageId == null ? "" : messageId,
    "CorrelationId", correlationId == null ? "" : correlationId
);

IncomingMessage in = ParseService.parseSafe(body, hdr);
if (in == null) {
    // log + throw to let Functions retry / DLQ
    log.severe("Malformed or incomplete message; dead-lettering.");
    throw new RuntimeException("Bad message");
}

// use getters everywhere:
log.info("Event=" + in.getEventId() + " doc=" + in.getDocId() + " corr=" + in.getCorrelationId());

Why getters?
	•	Keeps the class immutable and safe.
	•	Jackson can still populate via the constructor.
	•	Your calling code uses in.getCorrelationId() etc., not field access.

This mirrors your earlier shape but is production-ready (no public mutable fields), thread-safe (stateless parser + immutable DTO), and friendly for retries/DLQ.