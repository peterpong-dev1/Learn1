package com.yourpackage.service;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.yourpackage.model.IncomingMessage;
import com.microsoft.azure.functions.ExecutionContext;

import java.util.Map;

/**
 * Responsible for parsing and processing incoming service bus messages.
 */
public class NotificationParser {

    // ObjectMapper is thread-safe after configuration
    private static final ObjectMapper objectMapper = new ObjectMapper();

    /**
     * Parses the raw JSON message and logs relevant details.
     *
     * @param rawJson the JSON string received from Service Bus
     * @param context Azure Functions context for logging
     * @throws Exception if parsing fails or message is invalid
     */
    public static void process(String rawJson, ExecutionContext context) throws Exception {
        IncomingMessage message = objectMapper.readValue(rawJson, IncomingMessage.class);
        logMessage(message, context);
    }

    /**
     * Logs key fields from the parsed message for traceability.
     */
    private static void logMessage(IncomingMessage msg, ExecutionContext context) {
        context.getLogger().info("========== Notification Received ==========");
        context.getLogger().info("Event Name: " + msg.getEventName());
        context.getLogger().info("Document ID: " + msg.getDocId());
        context.getLogger().info("Container: " + msg.getContainer());
        context.getLogger().info("Created At: " + msg.getCreatedAtUtc());
        context.getLogger().info("Message ID: " + msg.getMessageId());

        if (msg.getContext() != null) {
            context.getLogger().info("Context: " + msg.getContext().toString());
        }

        if (msg.getNotify() != null) {
            context.getLogger().info("Notification Type: " + msg.getNotify().getNotificationType());
            context.getLogger().info("Trigger Type: " + msg.getNotify().getTriggerType());
        }

        if (msg.getDeltas() != null && !msg.getDeltas().isEmpty()) {
            for (IncomingMessage.Delta delta : msg.getDeltas()) {
                context.getLogger().info("Delta - Field: " + delta.getField()
                    + ", Kind: " + delta.getKind()
                    + ", Old: " + delta.getOld()
                    + ", New: " + delta.getNew());
            }
        }

        if (msg.getKeys() != null) {
            for (Map.Entry<String, String> entry : msg.getKeys().entrySet()) {
                context.getLogger().info("Key: " + entry.getKey() + " = " + entry.getValue());
            }
        }
        context.getLogger().info("===========================================");
    }
}


