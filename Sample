@Test
void test_NullPaginationValues_UsesDefaults() {
    when(customProperties.getDefaultPage()).thenReturn(1);
    when(customProperties.getDefaultLimit()).thenReturn(20);
    when(customProperties.getDefaultSortBy()).thenReturn("associationRegistrationNumber");
    when(customProperties.getDefaultSortDir()).thenReturn("ASC");

    when(repository.searchWithDynamicQueryAndPagination(eq(1), eq(20), eq("associationRegistrationNumber"), eq("ASC")))
        .thenReturn(new PaginatedResultInternalDTO<>(List.of(mockEntity), null));
    when(mapper.toDTO(mockEntity)).thenReturn(mockDto);

    PaginatedResultInternalDTO<AgencyOfficesResponseDTO> result =
        serviceImpl.getAllAgencyOfficesService(null, null, null, null);

    assertNotNull(result);
    assertEquals(1, result.getItems().size());

    verify(customProperties).getDefaultPage();
    verify(customProperties).getDefaultLimit();
    verify(repository).searchWithDynamicQueryAndPagination(eq(1), eq(20), eq("associationRegistrationNumber"), eq("ASC"));
}

@Test
void test_InvalidPage_ThrowsValidationException() {
    Exception ex = assertThrows(CustomValidationException.class, () ->
        serviceImpl.getAllAgencyOfficesService(-1, 10, "sortBy", "ASC"));

    assertTrue(ex.getMessage().contains("page must be > 0"));
}

@Test
void test_InvalidLimit_ThrowsValidationException() {
    Exception ex = assertThrows(CustomValidationException.class, () ->
        serviceImpl.getAllAgencyOfficesService(1, -5, "sortBy", "ASC"));

    assertTrue(ex.getMessage().contains("pageLimit must be >= 1"));
}

@Test
void test_InvalidSortDir_UsesDefault() {
    String badSortDir = "RANDOM";
    when(customProperties.getDefaultSortDir()).thenReturn("ASC");

    when(repository.searchWithDynamicQueryAndPagination(anyInt(), anyInt(), anyString(), eq("ASC")))
        .thenReturn(new PaginatedResultInternalDTO<>(List.of(mockEntity), null));
    when(mapper.toDTO(mockEntity)).thenReturn(mockDto);

    PaginatedResultInternalDTO<AgencyOfficesResponseDTO> result =
        serviceImpl.getAllAgencyOfficesService(1, 10, "sortBy", badSortDir);

    assertNotNull(result);
    verify(repository).searchWithDynamicQueryAndPagination(anyInt(), anyInt(), anyString(), eq("ASC"));
}

@Test
void test_RepoReturnsNull_ReturnsEmptyList() {
    when(repository.searchWithDynamicQueryAndPagination(anyInt(), anyInt(), anyString(), anyString()))
        .thenReturn(null);

    PaginatedResultInternalDTO<AgencyOfficesResponseDTO> result =
        serviceImpl.getAllAgencyOfficesService(1, 10, "sortBy", "ASC");

    assertNotNull(result);
    assertTrue(result.getItems().isEmpty());
}

