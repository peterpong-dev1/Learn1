@ExceptionHandler(IllegalStateException.class)
public ResponseEntity<ErrorContainerDTO> handleIllegalState(IllegalStateException ex) {
    logger.error("IllegalStateException occurred. requestId: {}, message: {}",
            MDC.get("requestId"), ex.getMessage());

    Map<String, Object> details = new HashMap<>();
    details.put("reason", ex.getMessage());

    return buildErrorResponse(HttpStatus.CONFLICT,  // or BAD_REQUEST if you prefer
            "Illegal state error",
            details);
}