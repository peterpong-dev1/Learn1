1) One-file model: EventConfig.java

package com.neo.notification.config;

import com.fasterxml.jackson.annotation.JsonIgnoreProperties;
import java.util.List;

/**
 * In-memory representation of your event rules JSON.
 *
 * JSON shape this maps to (shortened):
 * {
 *   "version": "1.0",
 *   "container": "appInfoProgressManagement",
 *   "events": [
 *     {
 *       "id": "appInfoProgressManagement_application_submitted",
 *       "name": "Application Submitted",
 *       "when": ["insert","update"],
 *       "conditions": {
 *         "logic": "AND",
 *         "rules": [
 *           { "op": "eq", "field": "applicationStatus", "value": "1" }
 *         ]
 *       }
 *     }
 *   ]
 * }
 *
 * Notes:
 * - Public fields keep it simple; Jackson fills them directly.
 * - @JsonIgnoreProperties keeps the parser tolerant to extra fields.
 */
@JsonIgnoreProperties(ignoreUnknown = true)
public final class EventConfig {
    /** Version string from the JSON. */
    public String version;

    /** Cosmos container these rules apply to. */
    public String container;

    /** The event rules. Never null after successful load. */
    public List<Event> events;

    /** One event definition. */
    @JsonIgnoreProperties(ignoreUnknown = true)
    public static final class Event {
        /** Unique, stable id like "appInfoProgressManagement_application_submitted". */
        public String id;

        /** Human-readable name. */
        public String name;

        /** When to evaluate: "insert", "update" (one or both). */
        public List<String> when;

        /** Conditions to satisfy for this event. */
        public ConditionGroup conditions;
    }

    /** A group of rules with AND/OR logic. */
    @JsonIgnoreProperties(ignoreUnknown = true)
    public static final class ConditionGroup {
        /** "AND" or "OR". Defaults handled by loader if missing. */
        public String logic;
        /** List of rules; empty lists are treated as "no conditions". */
        public List<Rule> rules;
    }

    /** Single condition like eq/changed/changedTo/becameNotNull. */
    @JsonIgnoreProperties(ignoreUnknown = true)
    public static final class Rule {
        /** Operation: "eq" | "changed" | "changedTo" | "becameNotNull". */
        public String op;
        /** Field path in your document (e.g., "applicationStatus"). */
        public String field;
        /** Optional value (required for eq/changedTo). */
        public String value;
    }
}


