import static org.mockito.Mockito.*;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;
import org.springframework.test.web.servlet.setup.MockMvcBuilders;
import java.util.Collections;
import java.util.List;

@ExtendWith(MockitoExtension.class) // ✅ Enables Mockito support
class AgentControllerTest {

    private MockMvc mockMvc; // ✅ Simulates API requests

    @Mock // ✅ Mock the Service Layer (No real DB calls)
    private AgentDetailByAgentIdService agentDetailByAgentIdService;

    @InjectMocks // ✅ Inject the mocked service into the Controller
    private AgentController agentController;

    private final ObjectMapper objectMapper = new ObjectMapper(); // ✅ Converts Java objects to JSON

    @BeforeEach
    void setUp() {
        mockMvc = MockMvcBuilders.standaloneSetup(agentController).build(); // ✅ Initialize MockMvc
    }

    // ✅ 1. Test GET /agents/{agentId} - Success (Valid Agent)
    @Test
    void testGetAgentById_Success() throws Exception {
        // ✅ Mock agent with correct eMail mapping
        List<AgentDTO> mockAgents = List.of(new AgentDTO(
                "123", "456", "CL001", "Admin",
                List.of(new NameDTO("John", "Doe")), true, false, "1990-01-01",
                Gender.MALE, List.of(new PhoneNumberDTO("mobile", "home", "1234567890")),
                List.of(new EmailDTO("john@example.com", true)), // ✅ eMail correctly mapped
                List.of(new DigitalTouchpointDTO("portalSite", "98765")),
                new SolicitorDTO("emp123", "SOL001", "Legal Advisor"),
                new AgencyDTO("AG001", "10010", "Some Agency"),
                new AgencyOfficeDTO("0000", "Main Office")
        ));

        // ✅ Mock service call
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("123"), anyMap())).thenReturn(mockAgents);

        // ✅ Perform GET request and verify response
        mockMvc.perform(get("/agents/123"))
                .andExpect(status().isOk()) // ✅ HTTP 200
                .andExpect(jsonPath("$.size()").value(1))
                .andExpect(jsonPath("$[0].id").value("123"))
                .andExpect(jsonPath("$[0].eMail[0].address").value("john@example.com")) // ✅ eMail validation
                .andExpect(jsonPath("$[0].eMail[0].addressValidated").value(true));

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("123"), anyMap());
    }

    // ✅ 2. Test GET /agents/{agentId} - Not Found (Empty List)
    @Test
    void testGetAgentById_NotFound() throws Exception {
        // ✅ Mock service call to return empty list
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("999"), anyMap())).thenReturn(Collections.emptyList());

        // ✅ Perform GET request and verify response
        mockMvc.perform(get("/agents/999"))
                .andExpect(status().isNotFound()); // ✅ HTTP 404

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("999"), anyMap());
    }

    // ✅ 3. Test GET /agents/{agentId} - Validation Failure (Blank agentId)
    @Test
    void testGetAgentById_BlankAgentId() throws Exception {
        // ✅ Perform GET request with blank agentId
        mockMvc.perform(get("/agents/ "))
                .andExpect(status().isBadRequest()) // ✅ HTTP 400
                .andExpect(jsonPath("$.message").value("Agent ID is required")); // ✅ Matches validation message

        verifyNoInteractions(agentDetailByAgentIdService); // ✅ Ensure service was NOT called
    }

    // ✅ 4. Test GET /agents/{agentId} - Internal Server Error (Service Exception)
    @Test
    void testGetAgentById_ServiceException() throws Exception {
        // ✅ Simulate service throwing an exception
        when(agentDetailByAgentIdService.searchUsingAgentId(eq("123"), anyMap()))
                .thenThrow(new RuntimeException("Database error"));

        // ✅ Perform GET request and verify error response
        mockMvc.perform(get("/agents/123"))
                .andExpect(status().isInternalServerError()) // ✅ HTTP 500
                .andExpect(jsonPath("$.message").value("Internal Server Error"));

        verify(agentDetailByAgentIdService, times(1)).searchUsingAgentId(eq("123"), anyMap());
    }
}