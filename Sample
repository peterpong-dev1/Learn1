Here’s a compact, production-friendly way to POST JSON with RestTemplate, with clear error handling and timeouts (works on Spring Boot 3.4.x, using the RestTemplate bean you already wired).

package jp.co.neofirst.api.common.http;

import org.springframework.http.*;
import org.springframework.stereotype.Service;
import org.springframework.web.client.HttpStatusCodeException;
import org.springframework.web.client.ResourceAccessException;
import org.springframework.web.client.RestTemplate;

import java.util.Map;

/**
 * Minimal HTTP client for POSTing JSON payloads using RestTemplate.
 * - Thread-safe via constructor-injected RestTemplate bean.
 * - Converts non-2xx responses into a checked exception with status & body.
 * - Distinguishes timeouts/connection errors from server errors.
 */
@Service
public class HttpJsonClient {

    private final RestTemplate restTemplate;

    public HttpJsonClient(RestTemplate restTemplate) {
        this.restTemplate = restTemplate;
    }

    /**
     * POSTs a JSON string to a target URL and returns the response body (String).
     *
     * @param url        target endpoint
     * @param jsonBody   request body as a JSON string
     * @param headersMap optional extra headers (e.g., X-Request-Id). May be null.
     * @return response body as String (empty string if none)
     * @throws DownstreamServiceException when any non-2xx or client/network error occurs
     */
    public String postJson(String url, String jsonBody, Map<String, String> headersMap)
            throws DownstreamServiceException {

        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.setAccept(java.util.List.of(MediaType.APPLICATION_JSON));
        if (headersMap != null) {
            headersMap.forEach(headers::set);
        }

        HttpEntity<String> entity = new HttpEntity<>(jsonBody, headers);

        try {
            ResponseEntity<String> resp =
                    restTemplate.exchange(url, HttpMethod.POST, entity, String.class);

            // Accept only 2xx
            if (resp.getStatusCode().is2xxSuccessful()) {
                return resp.getBody() != null ? resp.getBody() : "";
            }
            // Should not reach here because exchange would not throw for 3xx;
            // treat any non-2xx as failure.
            throw new DownstreamServiceException(
                    resp.getStatusCode().value(),
                    "Non-success HTTP status: " + resp.getStatusCode(),
                    resp.getBody()
            );

        } catch (HttpStatusCodeException e) {
            // Server returned 4xx/5xx; capture status + error body for diagnostics
            throw new DownstreamServiceException(
                    e.getRawStatusCode(),
                    "HTTP error while calling downstream: " + e.getStatusText(),
                    e.getResponseBodyAsString(),
                    e
            );
        } catch (ResourceAccessException e) {
            // Timeouts / connection problems
            throw new DownstreamServiceException(
                    504, // represent as gateway-timeout-ish
                    "I/O error (timeout or connection issue) calling downstream",
                    null,
                    e
            );
        } catch (Exception e) {
            // Anything else
            throw new DownstreamServiceException(
                    500,
                    "Unexpected error calling downstream service",
                    null,
                    e
            );
        }
    }
}

Custom exception (simple & informative)

package jp.co.neofirst.api.common.http;

/**
 * Wraps downstream HTTP failures with status code and (optional) response body.
 */
public class DownstreamServiceException extends Exception {
    private final int statusCode;
    private final String responseBody;

    public DownstreamServiceException(int statusCode, String message, String responseBody) {
        super(message);
        this.statusCode = statusCode;
        this.responseBody = responseBody;
    }

    public DownstreamServiceException(int statusCode, String message, String responseBody, Throwable cause) {
        super(message, cause);
        this.statusCode = statusCode;
        this.responseBody = responseBody;
    }

    public int getStatusCode()     { return statusCode; }
    public String getResponseBody(){ return responseBody; }
}

How to use it (example from a service)

@Service
public class NotificationDispatcher {

    private final HttpJsonClient http;

    public NotificationDispatcher(HttpJsonClient http) {
        this.http = http;
    }

    public String sendEmailRequest(String emailApiUrl, String payloadJson, String requestId)
            throws DownstreamServiceException {

        Map<String, String> headers = Map.of(
                "X-Request-Id", requestId,
                "X-Correlation-Id", requestId
        );

        // Will throw DownstreamServiceException on any error; caller can catch and decide (retry / DLQ / etc.)
        return http.postJson(emailApiUrl, payloadJson, headers);
    }
}

Notes:
	•	Timeouts are controlled by your RestTemplate bean (SimpleClientHttpRequestFactory), so this code stays clean.
	•	If you want to treat specific HTTP codes differently (e.g., 400 vs 500), catch DownstreamServiceException and inspect getStatusCode() / getResponseBody().