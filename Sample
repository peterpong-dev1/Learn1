Got it—no custom exception. Here’s a tiny, production-friendly helper that:
	•	POSTs a JSON string with RestTemplate
	•	Returns a Map<String,Object> like: {"ok": true, "statusCode": 200, "body": ""}
	•	Treats any 2xx as success; 400/500 (or any non-2xx) as error (but still returns the map)
	•	Catches timeouts/IO and unexpected errors cleanly

package jp.co.neofirst.api.common.http;

import org.springframework.http.*;
import org.springframework.stereotype.Service;
import org.springframework.web.client.HttpStatusCodeException;
import org.springframework.web.client.ResourceAccessException;
import org.springframework.web.client.RestTemplate;

import java.util.HashMap;
import java.util.Map;

/**
 * Minimal JSON POST client using RestTemplate.
 * Returns a simple result map instead of throwing custom exceptions.
 */
@Service
public class HttpJsonClient {

    private final RestTemplate restTemplate;

    public HttpJsonClient(RestTemplate restTemplate) {
        this.restTemplate = restTemplate; // thread-safe bean you already configured
    }

    /**
     * POST a JSON string and return a compact result map:
     *  - ok: boolean  (true if 2xx)
     *  - statusCode: int
     *  - body: String (response body if present, else "")
     *  - error: String (present only on failures/timeouts/unexpected)
     */
    public Map<String, Object> postJson(String url, String jsonBody, Map<String, String> extraHeaders) {
        Map<String, Object> result = new HashMap<>();

        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.setAccept(java.util.List.of(MediaType.APPLICATION_JSON));
        if (extraHeaders != null) extraHeaders.forEach(headers::set);

        HttpEntity<String> entity = new HttpEntity<>(jsonBody, headers);

        try {
            ResponseEntity<String> resp = restTemplate.exchange(url, HttpMethod.POST, entity, String.class);

            boolean ok = resp.getStatusCode().is2xxSuccessful();
            result.put("ok", ok);
            result.put("statusCode", resp.getStatusCode().value());
            result.put("body", resp.getBody() == null ? "" : resp.getBody());
            return result;

        } catch (HttpStatusCodeException e) {
            // Downstream returned 4xx/5xx
            result.put("ok", false);
            result.put("statusCode", e.getRawStatusCode());
            result.put("body", e.getResponseBodyAsString() == null ? "" : e.getResponseBodyAsString());
            result.put("error", "HTTP " + e.getRawStatusCode() + " " + e.getStatusText());
            return result;

        } catch (ResourceAccessException e) {
            // Timeouts / DNS / connection issues
            result.put("ok", false);
            result.put("statusCode", 504); // represent as timeout-ish
            result.put("body", "");
            result.put("error", "I/O error (timeout/connection): " + e.getMessage());
            return result;

        } catch (Exception e) {
            // Any unexpected error
            result.put("ok", false);
            result.put("statusCode", 500);
            result.put("body", "");
            result.put("error", "Unexpected error: " + e.getMessage());
            return result;
        }
    }
}

How you’d call it

@Service
public class NotificationDispatcher {
    private final HttpJsonClient http;

    public NotificationDispatcher(HttpJsonClient http) {
        this.http = http;
    }

    public void send(String url, String payloadJson, String requestId) {
        Map<String, Object> res = http.postJson(
            url,
            payloadJson,
            Map.of("X-Request-Id", requestId, "X-Correlation-Id", requestId)
        );

        // simple handling
        if (!(Boolean) res.get("ok")) {
            // log + decide retry/DLQ
            System.err.println("Downstream failed: status=" + res.get("statusCode")
                    + " error=" + res.getOrDefault("error","") );
        }
    }
}

This keeps it simple, thread-safe (shared RestTemplate bean), and easy to branch on success vs. error without custom exceptions.