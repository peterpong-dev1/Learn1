package jp.co.mycompany.servicing.controller;

import jp.co.mycompany.servicing.dto.FinancialInstitutionDTO;
import jp.co.mycompany.servicing.dto.SearchConditionsDTO;
import jp.co.mycompany.servicing.dto.ErrorResponseDTO;
import jp.co.mycompany.servicing.service.FinancialInstitutionService;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import javax.validation.Valid;
import java.util.List;

@RestController
@RequestMapping("/common/financialInstitution")
public class FinancialInstitutionController {
    
    @Value("${validation.requireAtLeastOneField}")
    private boolean requireAtLeastOneField;

    private final FinancialInstitutionService financialInstitutionService;

    public FinancialInstitutionController(FinancialInstitutionService financialInstitutionService) {
        this.financialInstitutionService = financialInstitutionService;
    }

    @PostMapping("/search")
    public ResponseEntity<?> searchFinancialInstitutions(@Valid @RequestBody SearchConditionsDTO searchConditions) {

        if (requireAtLeastOneField && searchConditions.allFieldsNull()) {
            return ResponseEntity.badRequest().body(new ErrorResponseDTO("400", "Request cannot be empty", List.of()));
        }

        List<FinancialInstitutionDTO> results = financialInstitutionService.searchInstitutions(
            searchConditions.getFinancialInstitutionCode(),
            searchConditions.getFinancialInstitutionBranchCode(),
            searchConditions.getName()
        );

        if (results.isEmpty()) {
            return ResponseEntity.badRequest().body(new ErrorResponseDTO("40000", "No results found", List.of()));
        }

        return ResponseEntity.ok(results);
    }
}

