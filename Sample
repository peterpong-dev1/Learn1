📄 Main Function

public class FnMessageRouter {
    @FunctionName("FnMessageRouter")
    public void run(
        @ServiceBusQueueTrigger(
            name = "msg",
            queueName = "%ServiceBusQueue%",
            connection = "ServiceBusConnection"
        ) String body,
        final ExecutionContext ctx
    ) {
        Logger log = ctx.getLogger();

        try {
            IncomingMessage msg = ParserService.parse(body, log);
            if (msg == null) return;

            if (!FreshnessService.check(msg, log)) return;
            if (!RecipientService.resolve(msg, log)) return;
            if (!AgencyPolicyService.apply(msg, log)) return;
            if (!PayloadBuilderService.buildAndSend(msg, log)) return;
            if (!ReportingService.record(msg, log)) return;

        } catch (Exception ex) {
            log.severe("Fatal error in FnMessageRouter: " + ex.getMessage());
            throw new RuntimeException(ex); // Functions runtime retries/DLQ
        }
    }
}


