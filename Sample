public static void patchSafe(CosmosContainer container, String corrId, Map<String, Object> fields) {
    if (fields == null || fields.isEmpty()) return;

    // 1) Read current doc to see which parents already exist
    ObjectNode cur = container.readItem(corrId, new PartitionKey(corrId), ObjectNode.class).getItem();

    // Collect parents to create (only if missing) and leaves to set
    Set<String> parentsToCreate = new LinkedHashSet<>();
    List<Map.Entry<String,Object>> leaves = new ArrayList<>();

    for (var e : fields.entrySet()) {
        String leaf = normalizeToPointer(e.getKey());    // "a.b.c" → "/a/b/c"
        leaves.add(Map.entry(leaf, e.getValue()));
        // walk parents like /a, /a/b ...
        String[] parts = leaf.substring(1).split("/");
        String path = "";
        JsonNode probe = cur;
        for (int i = 0; i < parts.length - 1; i++) {
            path += "/" + parts[i];
            JsonNode n = probe.at(path);
            if (n.isMissingNode() || !n.isObject()) {
                parentsToCreate.add(path);               // will create this parent
            } else {
                probe = n;                               // descend for next check
            }
        }
    }

    // Order parents shallow → deep so /a before /a/b
    List<String> orderedParents = new ArrayList<>(parentsToCreate);
    orderedParents.sort(Comparator.comparingInt(p -> p.split("/").length));

    // 2) Build PATCH ops: create missing parents, then set leaves
    CosmosPatchOperations ops = CosmosPatchOperations.create();
    for (String p : orderedParents) ops.set(p, JsonNodeFactory.instance.objectNode());
    for (var e : leaves) ops.set(e.getKey(), new ObjectMapper().valueToTree(e.getValue()));
    ops.set("/lastUpdatedAtUtc", Instant.now().toString());

    // 3) Apply
    container.patchItem(corrId, new PartitionKey(corrId), ops, ObjectNode.class);
}

private static String normalizeToPointer(String raw) {
    String p = raw.trim();
    if (p.startsWith("/")) p = p.substring(1);
    p = p.replace('.', '/');
    while (p.contains("//")) p = p.replace("//", "/");
    return "/" + p;
}