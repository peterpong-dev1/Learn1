package jp.co.neofirst.servicing.repository;

import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.models.SqlQuerySpec;
import com.azure.cosmos.models.SqlParameter;
import jp.co.neofirst.servicing.config.QueryPropertyFileConfig;
import jp.co.neofirst.servicing.model.PolicyHolder;
import lombok.RequiredArgsConstructor;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Repository;

import java.util.Collections;
import java.util.List;
import java.util.Optional;

@Repository
@RequiredArgsConstructor
public class PolicyHolderRepository {

    private static final Logger logger = LoggerFactory.getLogger(PolicyHolderRepository.class);
    private final CosmosContainer cosmosContainer;
    private final QueryPropertyFileConfig queryConfig;

    /**
     * Searches PolicyHolder by Policy ID using dynamic query.
     *
     * @param policyId Policy ID.
     * @return Optional PolicyHolder.
     */
    public Optional<PolicyHolder> searchByPolicyId(String policyId) {
        logger.info("Executing query to find PolicyHolder by Policy ID: {}", policyId);

        String query = queryConfig.getQuery("query.searchByPolicyId");

        SqlQuerySpec querySpec = new SqlQuerySpec(query)
                .setParameters(Collections.singletonList(new SqlParameter("@policyId", policyId)));

        List<PolicyHolder> results = cosmosContainer.queryItems(querySpec, PolicyHolder.class)
                .stream().toList();

        return results.stream().findFirst();
    }
}

✅ Changes made:
	•	Loads query dynamically from queries.properties.
	•	Uses CosmosContainer.queryItems() to fetch data using the query.

