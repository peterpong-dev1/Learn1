3) Call it from your Cosmos DB trigger function

package com.neo.notification.function;

import com.azure.storage.blob.BlobContainerClient;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.microsoft.azure.functions.annotation.*;
import com.microsoft.azure.functions.*;
import com.neo.notification.blob.BlobClientProvider;
import com.neo.notification.core.TrackedChangeHandler;
import com.neo.notification.model.ChangeDelta;
import com.neo.notification.util.NeoGetTrackedFieldsFromBlob;

import java.util.List;

public class NeoNotificationTriggerFunction {

    // Resolve once per function process
    private static final String CONFIG_CONTAINER_NAME = System.getenv("Blob_ContainerName_Config");
    private static final String DATA_CONTAINER_NAME   = System.getenv("Blob_ContainerName_Data");

    // Shared, thread‑safe clients (from your singleton provider)
    private static final BlobContainerClient CONFIG_CONTAINER =
            BlobClientProvider.container(CONFIG_CONTAINER_NAME);
    private static final BlobContainerClient DATA_CONTAINER =
            BlobClientProvider.container(DATA_CONTAINER_NAME);

    @FunctionName("NeoCosmosChangeFeedTrigger")
    public void run(
        @CosmosDBTrigger(
            name = "docs",
            databaseName = "%DatabaseName_1%",
            containerName = "%ContainerNameToTrack_1%",
            leaseContainerName = "%LeaseContainer_1%",
            createLeaseContainerIfNotExists = false,
            connection = "CosmosDBConnection")
        List<ObjectNode> documents,
        final ExecutionContext context) {

        if (documents == null || documents.isEmpty()) return;

        // Which logical Cosmos container are we comparing rules for?
        final String cosmosContainerName = System.getenv("ContainerNameToTrack_1");

        // Load fields-to-track (you already have this util)
        List<String> fieldsToTrack =
            NeoGetTrackedFieldsFromBlob.getTrackedFields(CONFIG_CONTAINER, cosmosContainerName);

        for (ObjectNode newDoc : documents) {
            List<ChangeDelta> deltas = TrackedChangeHandler.detectChanges(
                    cosmosContainerName,
                    newDoc,
                    DATA_CONTAINER,
                    fieldsToTrack,
                    context.getLogger());

            if (deltas.isEmpty()) {
                context.getLogger().info("No tracked changes for id=" +
                        (newDoc.has("id") ? newDoc.get("id").asText() : "<no-id>"));
                continue;
            }

            // >>> Next step: build your Service Bus message from 'deltas' and enqueue
            // prepareAndSendMessage(deltas, newDoc, cosmosContainerName);
        }
    }
}

This gives you:
	•	a clean method signature that returns List<ChangeDelta>,
	•	a caller in your trigger that loads the tracked fields, calls the handler, and then you can use the result to build the Service Bus message in the next step.

