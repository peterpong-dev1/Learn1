        boolean shouldSend = tableService.shouldProcess(docId, rowKey, incomingTime);

        if (shouldSend) {
            int attempt = 0;
            long delay = 1000;

            while (attempt < 3) {
                try {
                    sendToQueue(docId, notificationType, triggerType, recipientType);
                    System.out.println("✅ Message sent successfully.");
                    break;
                } catch (Exception e) {
                    attempt++;
                    if (attempt >= 3) {
                        System.err.println("❌ Failed after retries: " + e.getMessage());
                        // Optionally, log or update status elsewhere
                    } else {
                        try {
                            Thread.sleep(delay);
                        } catch (InterruptedException ignored) {}
                        delay *= 2;
                    }
                }
            }
        } else {
            System.out.println("⏩ Skipping stale message.");
        }
    }

    private void sendToQueue(String docId, String notificationType,
                             String triggerType, String recipientType) {
