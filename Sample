projectName=OrderProcessor
randomPackage=jp.co.neofirst.api.products
mainBaseFolders=src,main
testBaseFolders=src,test
mainLastFolders=templates,generated
testLastFolders=testcases,stubs


package util;

import java.io.File;
import java.util.Properties;

public class FolderBuilder {

    public static void createFolderStructures(String basePath, Properties props) {
        String packageProp = props.getProperty("randomPackage");
        String projectName = props.getProperty("projectName");

        String mainBaseProp = props.getProperty("mainBaseFolders");
        String testBaseProp = props.getProperty("testBaseFolders");
        String mainLast = props.getProperty("mainLastFolders");
        String testLast = props.getProperty("testLastFolders");

        if (packageProp == null || projectName == null ||
            mainBaseProp == null || testBaseProp == null ||
            mainLast == null || testLast == null) {

            System.err.println("❌ Missing one or more required properties.");
            return;
        }

        String[] packageParts = packageProp.split("\\.");
        String[] mainBaseFolders = mainBaseProp.split(",");
        String[] testBaseFolders = testBaseProp.split(",");
        String[] mainLastFolders = mainLast.split(",");
        String[] testLastFolders = testLast.split(",");

        // Build 'main' folder structure
        buildPath(basePath, mainBaseFolders, packageParts, mainLastFolders, projectName);

        // Build 'test' folder structure
        buildPath(basePath, testBaseFolders, packageParts, testLastFolders, projectName);
    }

    private static void buildPath(String basePath, String[] baseFolders, String[] packageParts, String[] lastFolders, String projectName) {
        File base = new File(basePath);

        // Append base folders (e.g., src, main or src, test)
        for (String folder : baseFolders) {
            base = new File(base, folder.trim());
        }

        // Append package folders
        for (String part : packageParts) {
            base = new File(base, part.trim());
        }

        // Create last folders + projectName
        for (String last : lastFolders) {
            File full = new File(base, last.trim() + File.separator + projectName);
            if (full.mkdirs()) {
                System.out.println("✅ Created: " + full.getAbsolutePath());
            } else {
                System.err.println("⚠️ Could not create: " + full.getAbsolutePath());
            }
        }
    }
}