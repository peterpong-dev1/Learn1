✅ 3. Service Layer (Validating Mandatory Fields)

📌 AddressServiceImpl.java

package jp.co.neofirst.servicing.service.impl;

import jp.co.neofirst.servicing.dto.AddressDTO;
import jp.co.neofirst.servicing.dto.AddressSearchConditionsDTO;
import jp.co.neofirst.servicing.mapper.AddressMapper;
import jp.co.neofirst.servicing.model.AddressModel;
import jp.co.neofirst.servicing.repository.AddressRepository;
import jp.co.neofirst.servicing.service.AddressService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.stream.Collectors;

/**
 * Implementation of AddressService for searching addresses.
 */
@Service
public class AddressServiceImpl implements AddressService {

    private static final Logger logger = LoggerFactory.getLogger(AddressServiceImpl.class);
    private final AddressRepository addressRepository;
    private final AddressMapper addressMapper;

    public AddressServiceImpl(AddressRepository addressRepository, AddressMapper addressMapper) {
        this.addressRepository = addressRepository;
        this.addressMapper = addressMapper;
    }

    @Override
    public List<AddressDTO> searchAddress(AddressSearchConditionsDTO searchConditions) {
        logger.info("Searching for addresses with conditions: {}", searchConditions);

        List<AddressModel> addressModels = addressRepository.searchWithDynamicQuery(searchConditions);

        List<AddressDTO> resultList = addressModels.stream()
                .map(addressMapper::toDTO)
                .collect(Collectors.toList());

        // ✅ Validate response before returning
        for (AddressDTO dto : resultList) {
            if (dto.getId() == null || dto.getAddressCode() == null) {
                logger.error("Missing mandatory fields in response: {}", dto);
                throw new IllegalArgumentException("id and addressCode must be present in response.");
            }
        }

        logger.info("Address search returned {} results", resultList.size());
        return resultList;
    }
}

✅ Why?
	•	Uses explicit validation instead of a custom exception.
	•	Throws IllegalArgumentException if mandatory fields are missing.

✅ 4. Global Exception Handling (Ensuring Proper Error Response)

📌 GlobalExceptionHandler.java

package jp.co.neofirst.servicing.exception;

import jp.co.neofirst.servicing.dto.ErrorDTO;
import jp.co.neofirst.servicing.dto.ErrorDetailDTO;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;

import java.util.Collections;

/**
 * Global exception handler for API errors.
 */
@RestControllerAdvice
public class GlobalExceptionHandler {

    /**
     * Handles validation errors when mandatory fields are missing in response.
     */
    @ExceptionHandler(IllegalArgumentException.class)
    public ResponseEntity<ErrorDTO> handleIllegalArgumentException(IllegalArgumentException ex) {
        ErrorDTO error = new ErrorDTO();
        error.setCode("400");
        error.setMessage("Validation Error: Mandatory fields are missing.");
        error.setDetails(Collections.singletonList(new ErrorDetailDTO("Validation", ex.getMessage())));
        return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(error);
    }
}

✅ Why?
	•	Handles IllegalArgumentException instead of using a custom exception.
	•	Returns a 400 Bad Request response with proper error details.

