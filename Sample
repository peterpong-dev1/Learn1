2) Message API HTTP client (singleton, thread‑safe)

package com.neo.notification.bus;

import java.net.URI;
import java.net.http.*;
import java.time.Duration;
import java.util.Map;
import java.util.logging.Logger;

/**
 * Thin HTTP relay to the Message API.
 * - Uses Java 11+ HttpClient (thread-safe).
 * - Adds standard headers (Content-Type, correlation, optional auth).
 * - Respects a configurable timeout.
 */
public final class MessageApiRelay {

    // One HttpClient per process (thread-safe)
    private static final HttpClient CLIENT = HttpClient.newBuilder()
            .connectTimeout(Duration.ofSeconds(timeout("MESSAGE_API_CONNECT_TIMEOUT_SEC", 10)))
            .version(HttpClient.Version.HTTP_1_1)
            .build();

    // Optional auth/env headers
    private static final String AUTH_BEARER = envOrNull("MESSAGE_API_AUTH_BEARER");     // raw token (avoid in plain text if possible)
    private static final String API_KEY     = envOrNull("MESSAGE_API_KEY_VALUE");       // e.g. abc123
    private static final String API_KEY_HDR = envOr("MESSAGE_API_KEY_HEADER", "X-API-Key");
    private static final int REQ_TIMEOUT    = timeout("MESSAGE_API_TIMEOUT_SEC", 15);

    private MessageApiRelay() {}

    /**
     * Forward a JSON string to Message API.
     * @return HttpResponse<String> for status/logging.
     */
    public static HttpResponse<String> send(
            String url, String method, String jsonBody, String correlationId, Logger log) throws Exception {

        HttpRequest.Builder b = HttpRequest.newBuilder(URI.create(url))
                .timeout(Duration.ofSeconds(REQ_TIMEOUT))
                .header("Content-Type", "application/json")
                .header("X-Correlation-Id", correlationId);

        if (AUTH_BEARER != null && !AUTH_BEARER.isBlank()) {
            b.header("Authorization", "Bearer " + AUTH_BEARER);
        }
        if (API_KEY != null && !API_KEY.isBlank()) {
            b.header(API_KEY_HDR, API_KEY);
        }

        // Default POST; support PUT/PATCH if you want later
        String m = (method == null ? "POST" : method.trim().toUpperCase());
        switch (m) {
            case "POST":
                b.POST(HttpRequest.BodyPublishers.ofString(jsonBody));
                break;
            case "PUT":
                b.PUT(HttpRequest.BodyPublishers.ofString(jsonBody));
                break;
            case "PATCH":
                b.method("PATCH", HttpRequest.BodyPublishers.ofString(jsonBody));
                break;
            default:
                // If GET ever needed, you must not send a body
                throw new IllegalArgumentException("Unsupported MESSAGE_API_METHOD: " + m);
        }

        HttpRequest req = b.build();
        log.info("[Relay] Calling Message API " + m + " " + url + " corr=" + correlationId);

        return CLIENT.send(req, HttpResponse.BodyHandlers.ofString());
    }

    /* ------------------- env helpers ------------------- */

    private static String envOr(String k, String def) {
        String v = System.getenv(k);
        return (v == null || v.isBlank()) ? def : v;
    }

    private static String envOrNull(String k) {
        String v = System.getenv(k);
        return (v == null || v.isBlank()) ? null : v;
    }

    private static int timeout(String k, int def) {
        try {
            return Integer.parseInt(envOr(k, String.valueOf(def)));
        } catch (NumberFormatException nfe) {
            return def;
        }
    }
}


