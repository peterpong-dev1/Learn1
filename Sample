int maxRetries = 2; // initial try + 1 retry
for (int attempt = 1; attempt <= maxRetries; attempt++) {
    try {
        // Prepare request with If-Match using priorETag
        var opts = new BlockBlobSimpleUploadOptions(
                new ByteArrayInputStream(payload), payload.length)
            .setHeaders(new BlobHttpHeaders().setContentType("application/json; charset=utf-8"))
            .setRequestConditions(new BlobRequestConditions().setIfMatch(priorETag));

        block.uploadWithResponse(opts, Duration.ofSeconds(30), Context.NONE);
        log.info("Blob updated successfully on attempt " + attempt);
        break; // ✅ success, exit loop

    } catch (BlobStorageException bse) {
        if (bse.getStatusCode() == 412 && attempt < maxRetries) {
            log.warning("ETag mismatch, re-reading blob for retry...");
            // Re-read the blob to get the latest ETag and possibly merge changes
            BlobProperties props = client.getProperties();
            priorETag = props.getETag();
            // Optionally re-download contents & recompute delta
        } else {
            throw bse; // permanent failure or max retries reached
        }
    }
}