// Timezone for “today”
private static final ZoneId BUSINESS_TZ = ZoneId.of("Asia/Tokyo");

// eqDate: compare field's DATE to TODAY / TODAY±N or a literal yyyy-MM-dd
private static boolean eqDate(String path, ObjectNode doc, String expectedSpec) {
    LocalDate expected = parseDateSpec(expectedSpec);           // e.g. TODAY, TODAY+1, 2025-09-23
    if (expected == null) return false;

    JsonNode node = doc.at(jsonPtr(path));
    if (node == null || node.isNull() || !node.isTextual()) return false;
    String raw = node.asText();

    LocalDate actual = parseLocalDateFlexible(raw);
    return expected.equals(actual);
}

// Parse “TODAY”, “TODAY+1”, “TODAY-2”, or literal yyyy-MM-dd
private static LocalDate parseDateSpec(String spec) {
    if (spec == null) return null;
    String s = spec.trim();
    if (s.equalsIgnoreCase("TODAY")) return LocalDate.now(BUSINESS_TZ);
    if (s.toUpperCase().startsWith("TODAY")) {
        try {
            int delta = Integer.parseInt(s.substring(5));       // +N or -N
            return LocalDate.now(BUSINESS_TZ).plusDays(delta);
        } catch (Exception ignore) { return null; }
    }
    try { return LocalDate.parse(s); } catch (Exception e) { return null; }
}

// Accepts "yyyy-MM-dd" OR ISO datetime; converts to BUSINESS_TZ date
private static LocalDate parseLocalDateFlexible(String raw) {
    try {
        if (raw.length() == 10 && raw.charAt(4) == '-' && raw.charAt(7) == '-') {
            return LocalDate.parse(raw);
        }
        // ISO datetime (with zone/offset or 'Z')
        return OffsetDateTime.parse(raw).atZoneSameInstant(BUSINESS_TZ).toLocalDate();
    } catch (Exception e) {
        return null;
    }
}

// Support both "/a/b" and "a.b"
private static String jsonPtr(String field) {
    if (field == null || field.isBlank()) return "/";
    if (field.charAt(0) == '/') return field;
    return "/" + field.replace('.', '/');
}

