@startuml
actor Client
participant "Controller" as C
participant "Service" as S
participant "Repository" as R
database "Cosmos DB" as DB

== First Page Request ==

Client -> C : GET /office?pageSize=10
C -> S : getAllAgencyOffices(null, 10)
S -> R : searchWithPagination(null, 10)
R -> DB : queryItems(..., continuationToken=null)
DB --> R : first 10 items + continuationToken
R --> S : PaginatedResult(data, token)
S -> C : Set headers (X-Continuation-Token)
S --> C : data (List<DTO>)

== Next Page Request ==

Client -> C : GET /office?pageSize=10&continuationToken=abc123
C -> S : getAllAgencyOffices("abc123", 10)
S -> R : searchWithPagination("abc123", 10)
R -> DB : queryItems(..., continuationToken=abc123)
DB --> R : next 10 items + nextToken
R --> S : PaginatedResult(data, nextToken)
S -> C : Set new token in headers
S --> C : data (List<DTO>)
@enduml