public final class DailyCountFormatter {

    /**
     * Convert dailyCounts into a placeholder map that matches template keys
     * like {{countsLine}}, {{newBusinessCounts}}, {{paymentCounts}}.
     */
    public static Map<String,String> formatForTemplate(NotificationRequestDTO dto) {
        Map<String,String> out = new LinkedHashMap<>();
        Map<String, Map<String,Integer>> byCat = dto.getDailyCountsByCategory();
        if (byCat == null || byCat.isEmpty()) return out;

        // for each category, collapse to newline string
        byCat.forEach((cat, perEvent) -> {
            if (perEvent == null || perEvent.isEmpty()) return;
            StringBuilder sb = new StringBuilder();
            perEvent.forEach((event, cnt) -> {
                if (cnt == null || cnt <= 0) return;
                if (sb.length() > 0) sb.append('\n');
                sb.append(event).append(": ").append(cnt);
            });

            if (sb.length() > 0) {
                // map category → template placeholder
                switch (cat) {
                    case "unpaid":
                        out.put("countsLine", sb.toString());
                        break;
                    case "NB":
                        out.put("newBusinessCounts", sb.toString());
                        break;
                    case "TR":
                        out.put("paymentCounts", sb.toString());
                        break;
                    default:
                        // fallback: just keep the same key
                        out.put(cat, sb.toString());
                }
            }
        });

        // add updateDate if present in DTO
        if (dto.getUpdateDate() != null) {
            out.put("updateDate", dto.getUpdateDate().toString());
        }

        return out;
    }
}