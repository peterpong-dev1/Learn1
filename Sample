/**
 * Builds the Service Bus message body and envelope.
 *
 * Example output JSON (payload):
 * {
 *   "correlationId": "12345-abc",
 *   "messageId": "msg-001",
 *   "createdAtUtc": "2025-08-29T10:30:00Z",
 *   "container": "unpaidContractInquiry",
 *   "docId": "POL20250824001",
 *   "eventId": "unpaidContractInquiry_dunning_notice",
 *   "eventName": "Create Dunning Notice",
 *   "when": "update",
 *   "deltas": [
 *     {
 *       "field": "/unpaidStatus",
 *       "kind": "CHANGED",
 *       "old": "PAID",
 *       "new": "UNPAID"
 *     }
 *   ],
 *   "context": {
 *     "user": "system",
 *     "source": "cosmosdb-trigger"
 *   },
 *   "notify": {
 *     "notificationType": "unpaid",
 *     "triggerType": "dunning"
 *   },
 *   "keys": {
 *     "policyId": "POL20250824001",
 *     "applicationNumber": "APP20250824001"
 *   }
 * }
 *
 * Attached as Service Bus Application Properties for filtering/metrics:
 *   container, eventId, docId, when
 *
 * @param container  Cosmos DB container name
 * @param docId      Unique document identifier
 * @param eventId    Configured event ID
 * @param eventName  Human-readable event name
 * @param when       Operation type ("insert" | "update")
 * @param deltas     Changed fields (with old/new values)
 * @param context    Optional metadata context
 * @param notificationType Notification type from event.json (e.g., unpaid, newBusiness)
 * @param triggerType Trigger type from event.json (e.g., dunning, notice)
 * @param keys       Extracted keys from config (e.g., policyId, applicationNumber)
 * @return ServiceBusMessage with payload and headers set
 * @throws Exception if serialization fails
 */