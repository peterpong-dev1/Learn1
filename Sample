package com.yourorg.messageapi;

import com.microsoft.azure.functions.annotation.*;
import com.microsoft.azure.functions.*;
import com.yourorg.messageapi.model.IncomingMessage;
import com.yourorg.messageapi.service.*;
import com.yourorg.messageapi.util.JsonUtil;

import java.util.logging.Logger;

/**
 * Azure Function (Service Bus trigger) that orchestrates the Message API pipeline:
 *   1) Parse & validate message
 *   2) Freshness check (optional)
 *   3) Resolve recipients (Cosmos lookups)
 *   4) Apply agency policy rules
 *   5) Build payload and send to next hop (queue or HTTP)
 *   6) Record/report outcome
 *
 * Keep this class VERY small—business logic lives in services.
 */
public class FnMessageRouter {

    @FunctionName("FnMessageRouter")
    public void run(
        @ServiceBusQueueTrigger(
            name = "msg",
            queueName = "%ServiceBusQueue%",
            connection = "ServiceBusConnection"
        ) String body,
        final ExecutionContext ctx
    ) {
        final Logger log = ctx.getLogger();
        log.info("FnMessageRouter: message received");

        try {
            // 1) Parse & validate
            IncomingMessage msg = ParserService.parse(body, log);
            if (msg == null) {
                log.warning("ParserService returned null (invalid JSON or missing fields). Skipping.");
                return;
            }

            // 2) Freshness gate (skip stale)
            if (!FreshnessService.check(msg, log)) return;

            // 3) Resolve recipients (Cosmos SDK queries, etc.)
            if (!RecipientService.resolve(msg, log)) return;

            // 4) Apply agency business rules
            if (!AgencyPolicyService.apply(msg, log)) return;

            // 5) Build and dispatch (queue or HTTP)
            if (!PayloadBuilderService.buildAndDispatch(msg, log)) return;

            // 6) Reporting / audit trail
            if (!ReportingService.record(msg, log)) {
                log.warning("ReportingService: record() returned false.");
            }

            log.info("FnMessageRouter: completed successfully for correlationId=" + msg.getCorrelationId());

        } catch (Exception ex) {
            // Let Functions retry / DLQ; you can also write an error blob here.
            log.severe("FnMessageRouter fatal error: " + ex.getMessage());
            throw new RuntimeException(ex);
        }
    }
}


