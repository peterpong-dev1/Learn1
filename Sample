@startuml AgentSearch
skinparam linetype ortho
skinparam dpi 300

' ========== Main Class to Controller ==========
NeoAgentSearchApplication --> AgentController : Initializes (Spring Boot)

' ========== Interceptor to Controller ==========
HttpHeaderInterceptor --> AgentController : Intercepts Requests

' ========== Controller to Service ==========
AgentController --> AgentDetailByAgentIdService : Uses
AgentController --> AgentDTO : Returns List<AgentDTO>
AgentController --> LoggerConfig : Logs Requests
AgentController --> GlobalExceptionHandler : Catches and Handles

' ========== Service to Repository & Utils ==========
AgentDetailByAgentIdServiceImpl --> AgentRepository : Uses
AgentDetailByAgentIdServiceImpl --> AgentMapper : Uses (Dependency)
AgentDetailByAgentIdServiceImpl --> LoggerConfig : Logs Information
AgentDetailByAgentIdServiceImpl --> Utils : Calls Static Methods
AgentDetailByAgentIdServiceImpl --> AgentDTO : Returns List<AgentDTO>

' ========== Repository and Mapper Relationships ==========
AgentRepository --> AgentEntity : Fetches Data
AgentMapper --> AgentDTO : Maps Entity to DTO
AgentRepository --> CosmosContainer : Uses (Dependency)
AgentRepository --> QueryPropertyFileConfig : Reads Query Config
AgentRepository --> LoggerConfig : Logs Information
AgentRepository --> CosmosDBConfig : For Connection
CosmosDBConfig --> KeyVaultConfig : Uses (Dependency)

' ========== Global Exception Handling ==========
GlobalExceptionHandler --> CustomDataNotFoundException : Catches
GlobalExceptionHandler --> CustomValidationException : Catches
GlobalExceptionHandler --> ErrorContainerDTO : Returns Error Details
ErrorContainerDTO --> ErrorResponseDTO : Has
ErrorResponseDTO --> ErrorDetailDTO : Uses List<ErrorDetailDTO>

' ========== Service and Repository Exception Throwing ==========
AgentDetailByAgentIdServiceImpl --> CustomValidationException : Throws
AgentDetailByAgentIdServiceImpl --> CustomDataNotFoundException : Throws

' ========== DTO Relationships ==========
AgentDTO --> NameDTO : Uses
AgentDTO --> PhoneNumberDTO : Uses
AgentDTO --> EmailDTO : Uses
AgentDTO --> DigitalTouchpointDTO : Uses
AgentDTO --> SolicitorDTO : Uses
AgentDTO --> AgencyDTO : Uses
AgentDTO --> AgencyOfficeDTO : Uses

' ========== Entity Relationships ==========
AgentEntity --> NameEntity : Uses
AgentEntity --> PhoneNumberEntity : Uses
AgentEntity --> EmailEntity : Uses
AgentEntity --> DigitalTouchpointEntity : Uses
AgentEntity --> SolicitorEntity : Uses
AgentEntity --> AgencyEntity : Uses
AgentEntity --> AgencyOfficeEntity : Uses

' ========== Enum Relationships ==========
NameEntity --> CharacterSetType : Uses
DigitalTouchpointEntity --> DigitalTouchPointType : Uses
PhoneNumberEntity --> ContactType : Uses
PhoneNumberEntity --> PhoneType : Uses
AgentEntity --> Gender : Uses

@enduml