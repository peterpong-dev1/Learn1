import com.azure.core.util.Context;
import com.azure.storage.blob.BlobContainerClient;
import com.azure.storage.blob.specialized.BlockBlobClient;
import com.azure.storage.blob.models.*;
import java.io.ByteArrayInputStream;
import java.nio.charset.StandardCharsets;
import java.time.OffsetDateTime;
import java.time.format.DateTimeFormatter;
import java.time.Duration;
import java.util.HashMap;
import java.util.Map;

public final class CreateBlob {

  /**
   * Creates the baseline snapshot if it doesn't exist.
   * Returns true if created, false if it already existed.
   * Throws RuntimeException on transient storage errors so Azure Functions can retry.
   */
  public static boolean createBaselineIfAbsent(
      BlobContainerClient dataContainer,
      String logicalContainer,
      String docId,
      com.fasterxml.jackson.databind.node.ObjectNode newDoc,
      java.util.logging.Logger log) {

    // 1) Build the blob path (your helper that forms "containerName/docId/<docId>.json")
    final String blobPath = BlobPaths.baseline(logicalContainer, docId);

    // 2) Serialize content (store full doc, or a slimmed snapshot if you prefer)
    byte[] payload = newDoc.toString().getBytes(StandardCharsets.UTF_8);

    // 3) Build index tags
    Map<String, String> tags = new HashMap<>();
    tags.put("logicalContainer", logicalContainer);
    tags.put("docId", docId);
    tags.put("isLatest", "true");
    tags.put("versionTs", OffsetDateTime.now().format(DateTimeFormatter.ISO_INSTANT));

    // 4) Idempotent create: If-None-Match: "*" (create only if doesn't exist)
    BlobRequestConditions cond = new BlobRequestConditions().setIfNoneMatch("*");

    BlockBlobClient block = dataContainer.getBlobClient(blobPath).getBlockBlobClient();

    try {
      BlockBlobSimpleUploadOptions opts =
          new BlockBlobSimpleUploadOptions(new ByteArrayInputStream(payload), payload.length)
              .setRequestConditions(cond)
              .setTags(tags)
              .setContentType("application/json; charset=utf-8");

      block.uploadWithResponse(opts, Duration.ofSeconds(30), Context.NONE);

      log.info("Created baseline snapshot: " + blobPath);
      return true;

    } catch (BlobStorageException bse) {
      // If two instances race, the loser gets BLOB_ALREADY_EXISTS → treat as success (false)
      if (bse.getErrorCode() == BlobErrorCode.BLOB_ALREADY_EXISTS) {
        log.info("Baseline already exists (idempotent create): " + blobPath);
        return false;
      }
      log.severe("BlobStorageException creating baseline for id=" + docId + ": "
          + bse.getErrorCode() + " / " + bse.getMessage());
      throw new RuntimeException(bse);

    } catch (Exception ex) {
      log.severe("Unexpected error creating baseline for id=" + docId + ": " + ex.getMessage());
      throw new RuntimeException(ex);
    }
  }
}