import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import java.util.List;
import java.util.Map;

@Service
public class AddressService {

    private final AddressRepository addressRepository;

    public AddressService(AddressRepository addressRepository) {
        this.addressRepository = addressRepository;
    }

    public ResponseEntity<?> search(AddressSearchConditionsDTO request, Map<String, Object> inputFields) {
        // ✅ Validation Error (400)
        if (request.getAddressCode() == null || request.getAddressCode().isEmpty()) {
            throw new ValidationException("Validation failed", inputFields);
        }

        List<AddressDTO> results = addressRepository.findAddress(request);

        // ✅ Data Not Found Error (400)
        if (results.isEmpty()) {
            throw new DataNotFoundException("No matching data found", inputFields);
        }

        return ResponseEntity.ok(results);
    }
}

