1) EventConfig.java

Make sure your Event has a when list and add two helpers.

// imports near the top
import com.fasterxml.jackson.annotation.JsonIgnoreProperties;
import com.fasterxml.jackson.annotation.JsonIgnore;
import java.util.List;

public final class EventConfig {
  public List<Event> events;

  @JsonIgnoreProperties(ignoreUnknown = true)
  public static final class Event {
    public String id;
    public String name;

    /** Allowed moments to evaluate: "insert", "update" (one or both). */
    public List<String> when;

    public ConditionGroup conditions;

    // ---- tiny helpers ----
    @JsonIgnore public boolean allowInsert() {
      return when != null && when.contains("insert");
    }
    @JsonIgnore public boolean allowUpdate() {
      return when != null && when.contains("update");
    }
  }

  @JsonIgnoreProperties(ignoreUnknown = true)
  public static final class ConditionGroup {
    public String logic;     // "AND" | "OR"
    public List<Rule> rules;
    public boolean isAnd() { return "AND".equalsIgnoreCase(logic); }
    public boolean isOr()  { return "OR".equalsIgnoreCase(logic);  }
  }

  @JsonIgnoreProperties(ignoreUnknown = true)
  public static final class Rule {
    public String op;     // "changed" | "changedTo" | "becameNotNull" | "becameNull" | "eq" | "ne"
    public String field;  // dotted path
    public String value;  // optional for eq/changedTo
  }
}

✔️ If you already have these classes, just add the when field and the two helper methods.

