package com.neo.utils;

import com.azure.storage.blob.*;
import com.azure.storage.blob.specialized.BlobLeaseClient;
import com.azure.storage.blob.specialized.BlobLeaseClientBuilder;
import com.azure.storage.blob.specialized.BlockBlobClient;

public class BlobClientProvider {

    private static final String CONNECTION_STRING = System.getenv("BlobConnection");

    private static final BlobServiceClient blobServiceClient = new BlobServiceClientBuilder()
            .connectionString(CONNECTION_STRING)
            .buildClient();

    /**
     * Returns a BlobContainerClient for the given container name.
     */
    public static BlobContainerClient getContainerClient(String containerName) {
        return blobServiceClient.getBlobContainerClient(containerName);
    }

    /**
     * Returns a BlockBlobClient for the given container and blob name.
     */
    public static BlockBlobClient getBlockBlobClient(String containerName, String blobName) {
        BlobContainerClient containerClient = getContainerClient(containerName);
        return containerClient.getBlobClient(blobName).getBlockBlobClient();
    }

    /**
     * Returns a LeaseClient for the given container and blob name.
     */
    public static BlobLeaseClient getBlobLeaseClient(String containerName, String blobName) {
        BlockBlobClient blockBlobClient = getBlockBlobClient(containerName, blobName);
        return new BlobLeaseClientBuilder()
                .blobClient(blockBlobClient)
                .buildClient();
    }
}