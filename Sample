1) Function: Service Bus → Message API relay

package com.neo.notification.bus;

import com.microsoft.azure.functions.*;
import com.microsoft.azure.functions.annotation.*;
import java.util.Optional;
import java.util.logging.Logger;

/**
 * Service Bus triggered function that relays the message payload to the Message API.
 * All business logic stays in the Message API; this function only forwards.
 */
public class MessageRelayFunction {

    // App settings (set in local.settings.json / Function App → Configuration)
    private static final String API_URL      = getenvReq("MESSAGE_API_URL");         // e.g. https://my.api/notify
    private static final String API_METHOD   = getenvOr("MESSAGE_API_METHOD", "POST");
    private static final boolean FAIL_ON_4XX = Boolean.parseBoolean(
            getenvOr("FAIL_ON_4XX", "false")); // true => retry on 4xx too (usually not recommended)

    @FunctionName("Neo_MessageRelay")
    public void run(
        @ServiceBusQueueTrigger(
            name        = "msg",
            queueName   = "%ServiceBusEntity%",          // app setting: ServiceBusEntity
            connection  = "ServiceBusConnection")        // app setting: ServiceBusConnection
        String body,

        // optional broker props (null-safe if not bound)
        @BindingName("MessageId")      String messageId,
        @BindingName("CorrelationId")  String correlationId,
        @BindingName("DeliveryCount")  Integer deliveryCount,

        final ExecutionContext context
    ) {
        final Logger log = context.getLogger();
        final String invocationId = context.getInvocationId();

        // Guard: empty body
        if (body == null || body.isBlank()) {
            log.warning("[Relay] Empty Service Bus body; completing. invocationId=" + invocationId);
            return; // nothing to forward
        }

        // Build a safe correlation (prefer SB correlationId, fallback to messageId, else invocationId)
        final String corr =
                firstNonBlank(correlationId, messageId, invocationId);

        try {
            // Forward to Message API
            var result = MessageApiRelay.send(API_URL, API_METHOD, body, corr, log);

            // Decide retry vs complete
            int status = result.statusCode();
            if (status >= 200 && status < 300) {
                log.info(String.format("[Relay] OK %d, corr=%s, msgId=%s, attempt=%s",
                        status, corr, nullSafe(messageId), nullSafe(deliveryCount)));
                return;
            }

            // Retry on transient conditions
            if (status == 408 || status == 429 || status >= 500) {
                throw new RuntimeException("Transient HTTP " + status + " from Message API");
            }

            // 4xx (besides 408/429): usually client/input; choose whether to fail
            if (FAIL_ON_4XX) {
                throw new RuntimeException("Client HTTP " + status + " from Message API");
            } else {
                log.warning(String.format("[Relay] Non‑retryable HTTP %d, completing. corr=%s", status, corr));
                return;
            }

        } catch (Exception ex) {
            // Throwing lets Functions retry and eventually dead‑letter (per queue MaxDeliveryCount)
            log.severe("[Relay] Exception forwarding to Message API: " + ex.getMessage()
                    + " | corr=" + corr + " | attempt=" + nullSafe(deliveryCount));
            throw (ex instanceof RuntimeException) ? (RuntimeException) ex : new RuntimeException(ex);
        }
    }

    /* ------------------- tiny helpers ------------------- */

    private static String getenvReq(String key) {
        String v = System.getenv(key);
        if (v == null || v.isBlank()) {
            throw new IllegalStateException("Missing required app setting: " + key);
        }
        return v;
    }

    private static String getenvOr(String key, String def) {
        String v = System.getenv(key);
        return (v == null || v.isBlank()) ? def : v;
    }

    private static String firstNonBlank(String... xs) {
        for (String x : xs) if (x != null && !x.isBlank()) return x;
        return "";
    }

    private static String nullSafe(Object x) {
        return (x == null) ? "null" : String.valueOf(x);
    }
}


