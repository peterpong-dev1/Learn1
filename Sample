Example Usage

import java.util.*;

public class TestEmailPayload {
    public static void main(String[] args) throws Exception {
        // Example recipient
        Map<String, Object> rec = new HashMap<>();
        rec.put("Customer.synergyid", 1);
        rec.put("Customer.mailaddress", "foo@example.com");
        rec.put("Customer.name", "山田 太郎");

        List<Map<String, Object>> recipients = List.of(rec);

        String payload = EmailPayloadBuilder.buildEmailPayload(
                UUID.randomUUID().toString(),      // requestId
                "support@example.com",             // from
                "カスタマーサポート",                 // fromName
                "reply@example.com",               // reply
                "ご契約成立のお知らせ",                // subject
                "お客様の契約が成立しました。",          // bodyText
                null,                              // bodyHtml (optional)
                "Customer.mailaddress",            // deliveryMailAddressPropertyName
                recipients,
                true                               // oneClickUnsubscriptionReady
        );

        System.out.println(payload);
    }
}


