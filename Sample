/**
 * Minimal holder for the previously-stored snapshot you will compare against.
 * Keeps the source so your caller can branch (NONE / BASELINE / LATEST).
 */
public static final class OldSnapshot {
    public enum Source { LATEST, BASELINE, NONE }
    private final Source source;
    private final com.fasterxml.jackson.databind.node.ObjectNode json;  // null if NONE
    public OldSnapshot(Source source, com.fasterxml.jackson.databind.node.ObjectNode json) {
        this.source = source; this.json = json;
    }
    public Source source() { return source; }
    public com.fasterxml.jackson.databind.node.ObjectNode json() { return json; }
}

/**
 * Resolve and load the "old" JSON snapshot for a doc, handling:
 * 1) LATEST (by Blob Index tags: docId + container + latest=true)
 * 2) BASELINE (first-time file: <container>/<docId>/<docId>.json, no tags)
 * 3) NONE    (no prior snapshot exists)
 *
 * Thread-safety: stateless (method-local variables only).
 *
 * @param serviceClient   shared BlobServiceClient (singleton)
 * @param dataContainer   blob container where snapshots live (e.g., "tracked-data")
 * @param logicalContainer logical Cosmos container name used in your blob paths/tags (e.g., "Customer")
 * @param docId           document id from newDoc.get("id")
 * @param log             Azure Functions logger
 * @return OldSnapshot with source + JSON (json==null when source==NONE)
 */
public static OldSnapshot getOldSnapshot(
        com.azure.storage.blob.BlobServiceClient serviceClient,
        com.azure.storage.blob.BlobContainerClient dataContainer,
        String logicalContainer,
        String docId,
        java.util.logging.Logger log) {

    // ----- 1) Try current LATEST via Blob Index tags -----
    // Query: @docId = '<docId>' AND @container = '<logicalContainer>' AND @latest = 'true'
    String d = docId.replace("'", "''");
    String c = logicalContainer.replace("'", "''");
    String query = "@docId = '" + d + "' AND @container = '" + c + "' AND @latest = 'true'";

    com.azure.core.http.rest.PagedIterable<com.azure.storage.blob.models.TaggedBlobItem> hits =
            serviceClient.findBlobsByTags(query);
    com.azure.storage.blob.models.TaggedBlobItem hit =
            hits.stream().findFirst().orElse(null);

    if (hit != null) {
        var client = serviceClient
                .getBlobContainerClient(hit.getContainerName())
                .getBlobClient(hit.getBlobName());
        var json = readJsonObject(client, log);
        return new OldSnapshot(OldSnapshot.Source.LATEST, json);
    }

    // ----- 2) Fallback to first-time BASELINE file (no tags) -----
    // You said baseline naming is "<container>/<docId>/<docId>.json"
    String baselinePath = logicalContainer + "/" + safePath(docId) + "/" + docId + ".json";
    var baseline = dataContainer.getBlobClient(baselinePath);
    if (baseline.exists()) {
        var json = readJsonObject(baseline, log);
        return new OldSnapshot(OldSnapshot.Source.BASELINE, json);
    }

    // ----- 3) Nothing there yet → NONE -----
    log.info(() -> "No prior snapshot found for container=" + logicalContainer + ", docId=" + docId);
    return new OldSnapshot(OldSnapshot.Source.NONE, null);
}

/* ---------- helpers (private) ---------- */

/**
 * Download a blob to JSON using non-deprecated APIs.
 * Uses downloadContent() with a stream fallback for maximum compatibility.
 */
private static com.fasterxml.jackson.databind.node.ObjectNode readJsonObject(
        com.azure.storage.blob.BlobClient client,
        java.util.logging.Logger log) {
    try {
        String json = client.downloadContent().toString(); // BinaryData -> String (UTF-8)
        return (com.fasterxml.jackson.databind.node.ObjectNode)
                new com.fasterxml.jackson.databind.ObjectMapper().readTree(json);
    } catch (Exception fastPathFail) {
        try (var out = new java.io.ByteArrayOutputStream(4096)) {
            client.downloadStream(out);
            String json = out.toString(java.nio.charset.StandardCharsets.UTF_8);
            return (com.fasterxml.jackson.databind.node.ObjectNode)
                    new com.fasterxml.jackson.databind.ObjectMapper().readTree(json);
        } catch (Exception e) {
            log.severe("Blob read failed: " + client.getBlobUrl() + " - " + e.getMessage());
            throw new RuntimeException("Blob read failed: " + client.getBlobUrl(), e);
        }
    }
}

/** Minimal path sanitizer — replace '/' to keep blob names valid. */
private static String safePath(String id) {
    return id.replace("/", "_");
}


