package util;

import java.io.File;
import java.util.Properties;

public class FolderBuilder {

    public static File createFolderStructure(String basePath, Properties props) {
        String lastFoldersProp = props.getProperty("lastFolders");
        String packageProp = props.getProperty("randomPackage");
        String baseFoldersProp = props.getProperty("baseFolders");
        String projectName = props.getProperty("projectName");

        if (lastFoldersProp == null || packageProp == null || baseFoldersProp == null || projectName == null) {
            System.err.println("Missing one or more required properties: projectName, baseFolders, randomPackage, lastFolders");
            return null;
        }

        String[] baseFolders = baseFoldersProp.split(",");
        String[] packageParts = packageProp.split("\\.");
        String[] lastFolders = lastFoldersProp.split(",");

        // Start with basePath
        File folder = new File(basePath);

        // Append base folders: e.g., src/main
        for (String base : baseFolders) {
            folder = new File(folder, base.trim());
        }

        // Append package folders: e.g., jp/co/neofirst/api/salesname
        for (String part : packageParts) {
            folder = new File(folder, part.trim());
        }

        boolean allCreated = true;
        File finalTarget = null;

        // Append last folders and project name
        for (String last : lastFolders) {
            File fullPath = new File(folder, last.trim() + File.separator + projectName);
            if (!fullPath.mkdirs()) {
                System.err.println("Failed to create: " + fullPath.getAbsolutePath());
                allCreated = false;
                break;
            }
            finalTarget = fullPath;
        }

        if (allCreated && finalTarget != null) {
            System.out.println("✅ Folder structure created under: " + folder.getAbsolutePath());
            return finalTarget;
        } else {
            System.err.println("❌ Failed to create full structure.");
            return null;
        }
    }
}