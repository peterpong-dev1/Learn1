import com.azure.cosmos.CosmosClient;
import com.azure.cosmos.CosmosClientBuilder;
import org.springframework.stereotype.Repository;
import javax.annotation.PreDestroy;

@Repository
public class CosmosDBRepository {

    private static volatile CosmosClient cosmosClient; // Thread-safe singleton

    /**
     * Gets the singleton Cosmos DB client.
     * Uses double-checked locking to ensure only one instance is created.
     */
    public CosmosClient getCosmosClient() {
        if (cosmosClient == null) { // First check (no lock)
            synchronized (CosmosDBRepository.class) {
                if (cosmosClient == null) { // Second check (inside lock)
                    cosmosClient = new CosmosClientBuilder()
                            .endpoint(System.getenv("COSMOS_DB_ENDPOINT"))  // Use environment variable
                            .key(System.getenv("COSMOS_DB_KEY"))  // Use environment variable
                            .gatewayMode()  // Use directMode() if low latency is needed
                            .buildClient();
                    System.out.println("✅ Cosmos DB Client Initialized.");
                }
            }
        }
        return cosmosClient;
    }

    /**
     * Closes the Cosmos DB connection when the application shuts down.
     */
    @PreDestroy
    public void close() {
        if (cosmosClient != null) {
            cosmosClient.close();
            System.out.println("✅ Cosmos DB Connection closed.");
        }
    }
}