Absolutely—you can treat Service Bus just like your Blob clients: create one sender once, reuse it across all invocations, and do not open/close per message. Closing isn’t required per run; the SDK keeps one HTTP/AMQP connection and the Functions host tears it down on process shutdown. If you still want an explicit close, expose a closeAll() you can call from a shutdown hook or a maintenance path.

Below is a tight, production‑ready setup that:
	•	Reuses a single sender (thread‑safe).
	•	Gives you one call from your Function: MessageBus.sendEvent(...).
	•	Centralizes error handling (writes your ErrorWriter blob and rethrows so Functions retries).
	•	Builds a compact JSON payload (no schemaVersion) with event id/name, when, deltas, and context.

1) Reusable sender (singleton cache)

package com.neo.notification.bus;

import com.azure.messaging.servicebus.*;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.ConcurrentMap;

/** Thread-safe factory/cache for Service Bus senders (queues). */
public final class ServiceBusClientHolder {
    private static final String CONNECTION = System.getenv("ServiceBusConnection");
    private static final ConcurrentMap<String, ServiceBusSenderClient> SENDERS = new ConcurrentHashMap<>();

    private ServiceBusClientHolder() {}

    /** Get (or create once) a sender for the given queue. */
    public static ServiceBusSenderClient senderForQueue(String queueName) {
        if (queueName == null || queueName.isBlank()) {
            throw new IllegalStateException("Missing app setting ServiceBusEntity (queue name).");
        }
        return SENDERS.computeIfAbsent(queueName, q ->
            new ServiceBusClientBuilder()
                .connectionString(CONNECTION)
                .sender()
                .queueName(q)
                .buildClient()
        );
    }

    /** Optional: call if you ever want to close explicitly. */
    public static void closeAll() {
        SENDERS.values().forEach(c -> { try { c.close(); } catch (Exception ignored) {} });
        SENDERS.clear();
    }
}

2) Message factory (builds the JSON & ServiceBusMessage)

package com.neo.notification.bus;

import com.azure.core.util.BinaryData;
import com.azure.messaging.servicebus.ServiceBusMessage;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.time.OffsetDateTime;
import java.util.*;
import java.util.stream.Collectors;

/** Builds a compact, consistent message payload for Service Bus. */
public final class MessageFactory {
    private static final ObjectMapper M = new ObjectMapper();

    private MessageFactory() {}

    /**
     * Build a ServiceBusMessage with a compact JSON body.
     * Body fields:
     *  - correlationId, messageId, createdAtUtc
     *  - container, docId, eventId, eventName, when
     *  - deltas: [{field, kind, old, new}]
     *  - context: free-form (e.g., _etag, _lsn)
     */
    public static ServiceBusMessage buildBodyAndEnvelope(
            String correlationId,
            String messageId,
            String container,
            String docId,
            String eventId,
            String eventName,
            String when,                            // "insert" | "update"
            List<ChangeInfo> deltas,                // your existing ChangeInfo list
            Map<String, Object> context,
            String sessionIdOrNull                  // set only if your queue requires sessions
    ) throws Exception {

        ObjectNode root = M.createObjectNode();
        root.put("correlationId", correlationId);
        root.put("messageId", messageId);
        root.put("createdAtUtc", OffsetDateTime.now().toString());
        root.put("container", container);
        root.put("docId", docId);
        root.put("eventId", eventId);
        root.put("eventName", eventName);
        root.put("when", when);

        // Convert deltas to small JSON objects
        var small = (deltas == null ? List.<Map<String,Object>>of() :
            deltas.stream().map(MessageFactory::toSmall).collect(Collectors.toList()));
        root.set("deltas", M.valueToTree(small));

        if (context != null && !context.isEmpty()) {
            root.set("context", M.valueToTree(context));
        }

        byte[] payload = M.writeValueAsBytes(root);

        ServiceBusMessage msg = new ServiceBusMessage(BinaryData.fromBytes(payload))
                .setMessageId(messageId)
                .setContentType("application/json")
                .setCorrelationId(correlationId);

        // helpful headers for filtering/metrics
        msg.getApplicationProperties().put("container", container);
        msg.getApplicationProperties().put("eventId", eventId);
        msg.getApplicationProperties().put("docId", docId);
        msg.getApplicationProperties().put("when", when);

        if (sessionIdOrNull != null && !sessionIdOrNull.isBlank()) {
            msg.setSessionId(sessionIdOrNull);
        }
        return msg;
    }

    private static Map<String,Object> toSmall(ChangeInfo c) {
        Map<String,Object> m = new LinkedHashMap<>();
        m.put("field", c.getFieldPath());
        m.put("kind",  c.getKind().name()); // ADDED|REMOVED|MODIFIED
        m.put("old",   c.getOldValue() == null ? null : c.getOldValue().asText());
        m.put("new",   c.getNewValue() == null ? null : c.getNewValue().asText());
        return m;
    }

    /** Minimal view of your existing ChangeInfo, adapt if your getters differ. */
    public interface ChangeInfo {
        String getFieldPath();
        com.fasterxml.jackson.databind.JsonNode getOldValue();
        com.fasterxml.jackson.databind.JsonNode getNewValue();
        Kind getKind();
        enum Kind { ADDED, REMOVED, MODIFIED }
    }
}

3) Single call from your Function

package com.neo.notification.bus;

import com.azure.messaging.servicebus.*;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.neo.notification.util.ErrorWriter;

import java.util.*;
import java.util.logging.Logger;
import java.util.UUID;

/**
 * One public method to send an event message.
 * Handles: id generation, headers, sessions (optional), error logging, and retries via Functions.
 */
public final class MessageBus {
    private MessageBus() {}

    /**
     * Send one event to a Service Bus **queue**.
     *
     * @param container         Cosmos container name (for headers)
     * @param docId             Document id
     * @param eventId           Stable id from your config (e.g., "appInfo..._application_cancelled")
     * @param eventName         Human label
     * @param when              "insert" or "update"
     * @param deltas            List of tracked-field changes
     * @param context           Extra diagnostics (e.g., _etag, _lsn, readAtUtc)
     * @param sessionIdOrNull   Set ONLY if your queue is session-enabled; else pass null
     * @param newDoc            New document (for ErrorWriter on failure)
     * @param errorContainer    Blob container for error logs
     * @param log               Function logger
     */
    public static void sendEvent(
            String container,
            String docId,
            String eventId,
            String eventName,
            String when,
            List<MessageFactory.ChangeInfo> deltas,
            Map<String,Object> context,
            String sessionIdOrNull,
            ObjectNode newDoc,
            com.azure.storage.blob.BlobContainerClient errorContainer,
            Logger log) {

        String queue = System.getenv("ServiceBusEntity"); // queue name
        String correlationId = docId + "|" + eventId + "|" + when;
        String messageId = UUID.randomUUID().toString();

        try {
            // Build payload
            ServiceBusMessage msg = MessageFactory.buildBodyAndEnvelope(
                    correlationId, messageId,
                    container, docId,
                    eventId, eventName, when,
                    deltas, context, sessionIdOrNull);

            // Reused sender (thread-safe)
            ServiceBusSenderClient sender = ServiceBusClientHolder.senderForQueue(queue);

            // Send
            sender.sendMessage(msg);

            log.info("SB SENT: queue=" + queue +
                    " msgId=" + messageId +
                    " corrId=" + correlationId +
                    " docId=" + docId +
                    " event=" + eventId +
                    " when=" + when);

        } catch (Exception ex) {
            // Centralized error path - write the prepared context + doc for diagnostics
            ErrorWriter.writeError(
                errorContainer,
                container,
                docId,
                "ServiceBusSendError",
                "Failed to send to Service Bus: " + ex.getMessage(),
                when.equals("insert") ? "CREATE" : "MODIFY",
                newDoc,
                (context == null) ? "" : String.valueOf(context.getOrDefault("_etag", "")),
                // if you have invocation id/name at call site, pass them instead of blanks
                "", "", log
            );
            // Surface to Functions so built-in retry kicks in
            throw new RuntimeException("Service Bus send failed", ex);
        }
    }
}

4) How your Function calls it (single line per fired event)

Where you currently build events and have eventsFired:

// Example context you already have around this point
