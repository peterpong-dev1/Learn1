import org.springframework.stereotype.Service;
import org.springframework.data.domain.Pageable;
import jp.co.mycompany.servicing.dto.FinancialInstitutionDTO;
import jp.co.mycompany.servicing.model.FinancialInstitution;
import jp.co.mycompany.servicing.repository.FinancialInstitutionRepository;
import java.util.List;
import java.util.stream.Collectors;

/**
 * Service layer for financial institution operations.
 * Handles business logic for retrieving financial institution details.
 */
@Service
public class FinancialInstitutionService {

    private final FinancialInstitutionRepository repository;

    /**
     * Constructs FinancialInstitutionService with required dependencies.
     *
     * @param repository The financial institution repository.
     */
    public FinancialInstitutionService(FinancialInstitutionRepository repository) {
        this.repository = repository;
    }

    /**
     * Searches for financial institutions based on provided criteria.
     *
     * @param financialInstitutionCode The institution code to filter by.
     * @param pageable Pagination details (page number, size, sorting).
     * @return A list of financial institutions matching the criteria.
     */
    public List<FinancialInstitutionDTO> searchInstitutions(String financialInstitutionCode, Pageable pageable) {
        return repository.findByFinancialInstitutionCode(financialInstitutionCode, pageable)
                .stream().map(FinancialInstitutionDTO::fromEntity).collect(Collectors.toList());
    }
}

