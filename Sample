// ============ Builder + Serializer ============

package com.yourco.notification.payload;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.*;
import java.util.logging.Logger;

/**
 * Stateless, thread-safe builder for NotificationRequest.
 * - Pulls fixed fields from parsed message and/or context.
 * - Builds dynamic placeholders from:
 *   (1) a Map under key "placeholders" in context, and/or
 *   (2) any context entries whose key starts with "ph." (prefix is stripped).
 */
public final class NotificationPayloadBuilder {
    private static final ObjectMapper M = new ObjectMapper();

    private NotificationPayloadBuilder() {}

    /**
     * Build the NotificationRequest object.
     *
     * @param context map produced by your lookup executor (String -> Object)
     * @param notificationType value from parsed message (e.g., "newBusiness")
     * @param triggerType value from parsed message (e.g., "established")
     * @param messageType channel ("email" / "line" / etc.)
     * @param language ISO code (e.g., "ja")
     * @param applicationId nullable
     * @param policyId nullable
     * @param log logger
     */
    public static NotificationRequest build(
            Map<String,Object> context,
            String notificationType,
            String triggerType,
            String messageType,
            String language,
            String applicationId,
            String policyId,
            Logger log
    ) {
        Objects.requireNonNull(context, "context");

        NotificationRequest req = new NotificationRequest();
        req.setNotificationType(notificationType);
        req.setTriggerType(triggerType);
        req.setMessageType(messageType);
        req.setLanguage(language);
        req.setApplicationId(applicationId);
        req.setPolicyId(policyId);

        // Recipient (safely pull from context)
        Recipient rcpt = new Recipient();
        rcpt.setName(str(context.get("recipient.name")));
        rcpt.setEmail(str(context.get("recipient.email")));
        rcpt.setPhone(str(context.get("recipient.phone")));
        rcpt.setLineId(str(context.get("recipient.lineId")));
        // If everything is null/blank, leave recipient null
        if (anyNonBlank(rcpt.getName(), rcpt.getEmail(), rcpt.getPhone(), rcpt.getLineId())) {
            req.setRecipient(rcpt);
        }

        // Agency
        Agency agency = new Agency();
        agency.setAgencyId(str(context.get("agency.agencyId")));
        agency.setAgencyName(str(context.get("agency.agencyName")));
        if (anyNonBlank(agency.getAgencyId(), agency.getAgencyName())) {
            req.setAgency(agency);
        }

        // Dynamic placeholders:
        // 1) If context contains a Map under key "placeholders", copy it.
        Map<String,Object> placeholders = new LinkedHashMap<>();
        Object phObj = context.get("placeholders");
        if (phObj instanceof Map<?,?> m) {
            for (Map.Entry<?,?> e : m.entrySet()) {
                if (e.getKey() != null) placeholders.put(e.getKey().toString(), e.getValue());
            }
        }
        // 2) Also collect all context entries with key prefix "ph."
        for (Map.Entry<String,Object> e : context.entrySet()) {
            String k = e.getKey();
            if (k != null && k.startsWith("ph.")) {
                placeholders.put(k.substring(3), e.getValue()); // strip "ph."
            }
        }
        if (!placeholders.isEmpty()) {
            req.setPlaceholders(placeholders);
        }

        // Basic mandatory checks (customize as needed)
        if (isBlank(req.getNotificationType()) || isBlank(req.getTriggerType()) || isBlank(req.getMessageType())) {
            throw new IllegalArgumentException("Missing mandatory fields: notificationType/triggerType/messageType");
        }

        log.info("Notification payload built.");
        return req;
    }

    /** Serialize to JSON string. */
    public static String toJson(NotificationRequest req) {
        try {
            return M.writeValueAsString(req);
        } catch (JsonProcessingException e) {
            throw new RuntimeException("Failed to serialize NotificationRequest", e);
        }
    }

    // ---- helpers ----
    private static String str(Object o) { return o == null ? null : String.valueOf(o); }
    private static boolean isBlank(String s) { return s == null || s.isBlank(); }
    private static boolean anyNonBlank(String... vals) {
        for (String v : vals) if (!isBlank(v)) return true;
        return false;
    }
}


