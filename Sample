✅ 1. Updated PolicyHolder.java (No JPA, Now Cosmos DB)

package com.example.project.model;

import com.azure.spring.data.cosmos.core.mapping.Container;
import com.azure.spring.data.cosmos.core.mapping.PartitionKey;
import com.example.project.model.enums.*;
import lombok.*;

import java.util.List;

@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
@Container(containerName = "policyHolder") // ✅ Cosmos DB container annotation
public class PolicyHolder {

    private String id;

    @PartitionKey // ✅ Needed for Cosmos DB partitioning
    private String policyId;

    private CustomerType customerType;
    private String customerId;
    private PartyType partyType;

    private List<NameDetails> name;
    private List<AddressDetails> address;
    private List<PhoneNumber> phone;
    private List<Contact> contact;
    private List<DigitalContact> digitalContact;

    private ReceiptOfNotices receiptOfNotices;
}



