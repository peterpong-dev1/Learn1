✅ 2. Consumer-Side Azure Function (Service Bus Trigger)

This function receives messages, checks Azure Table, and only proceeds if the message is the latest.

ConsumerFunction.java

package com.example.functions;

import com.azure.data.tables.TableClient;
import com.azure.data.tables.TableClientBuilder;
import com.azure.data.tables.models.TableEntity;
import com.azure.data.tables.models.TableServiceException;
import com.azure.messaging.servicebus.ServiceBusReceivedMessage;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.time.Instant;
import java.util.Map;

/**
 * Azure Function triggered by Service Bus message.
 * Validates timestamp using Azure Table, then proceeds with Notification API call.
 */
public class ConsumerFunction {

    private static final String CONNECTION_STRING = System.getenv("AzureWebJobsStorage");
    private static final String TABLE_NAME = "MessageTracker";
    private final TableClient tableClient;
    private final ObjectMapper mapper = new ObjectMapper();

    public ConsumerFunction() {
        this.tableClient = new TableClientBuilder()
                .connectionString(CONNECTION_STRING)
                .tableName(TABLE_NAME)
                .buildClient();
    }

    /**
     * Handles an incoming message from the queue.
     *
     * @param message The received Service Bus message
     */
    public void handle(ServiceBusReceivedMessage message) {
        try {
            String body = message.getBody().toString();
            Map<String, Object> msg = mapper.readValue(body, Map.class);

            String docId = msg.get("docId").toString();
            String notificationType = msg.get("notificationType").toString();
            String triggerType = msg.get("triggerType").toString();
            String recipientType = msg.get("recipientType").toString();
            String messageTime = msg.get("lastUpdatedTime").toString(); // from message
            Instant incomingTime = Instant.parse(messageTime);

            String rowKey = notificationType + "|" + triggerType + "|" + recipientType;

            TableEntity entity = tableClient.getEntity(docId, rowKey);
            String storedTime = entity.getProperty("LastUpdatedTime").toString();
            Instant latestTime = Instant.parse(storedTime);

            if (!incomingTime.equals(latestTime)) {
                System.out.println("⏩ Stale message. Skipping.");
                return;
            }

            // Proceed to call notification API
            sendNotification(msg);

        } catch (TableServiceException e) {
            System.err.println("⚠️ Azure Table error: " + e.getMessage());
        } catch (Exception e) {
            System.err.println("❌ Failed to process message: " + e.getMessage());
            e.printStackTrace();
        }
    }

    /**
     * Simulated call to Notification API.
     *
     * @param msg The message contents
     */
    private void sendNotification(Map<String, Object> msg) {
        // TODO: replace this with actual HTTP POST call to notification API
        System.out.println("📨 Sending to Notification API: " + msg);
    }
}


