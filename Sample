import com.azure.cosmos.CosmosClient;
import com.azure.cosmos.CosmosClientBuilder;
import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.CosmosDatabase;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Repository;

import javax.annotation.PreDestroy;

/**
 * Repository class responsible for managing the connection to Azure Cosmos DB.
 * 
 * <p>
 * This class initializes a single shared instance of {@link CosmosClient}, 
 * {@link CosmosDatabase}, and {@link CosmosContainer} for efficient querying. 
 * It is optimized for **read-heavy workloads** and ensures proper cleanup 
 * when the application stops.
 * </p>
 * 
 * <h3>Implementation Details:</h3>
 * <ul>
 *     <li>Uses a **static shared** `CosmosClient` to avoid multiple connections.</li>
 *     <li>Initializes the connection **once at startup** using a **static block**.</li>
 *     <li>Closes the connection **gracefully** using `@PreDestroy`.</li>
 * </ul>
 * 
 * <h3>Best Practices Followed:</h3>
 * <ul>
 *     <li>Uses **Gateway Mode** for optimal query performance.</li>
 *     <li>Ensures **thread safety** and avoids connection leaks.</li>
 *     <li>Logs key events like connection initialization and shutdown.</li>
 * </ul>
 * 
 * <h3>Usage:</h3>
 * <pre>
 *     CosmosDBRepository repository = new CosmosDBRepository();
 *     CosmosContainer container = repository.getContainer();
 * </pre>
 * 
 * @author [Your Name]
 * @version 1.0
 * @since 2024
 */
@Repository
public class CosmosDBRepository {
    
    /** Logger instance for tracking database operations. */
    private static final Logger logger = LoggerFactory.getLogger(CosmosDBRepository.class);

    /** Shared Cosmos DB client instance for all requests. */
    private static CosmosClient cosmosClient;

    /** Reference to the Cosmos DB database instance. */
    private static CosmosDatabase cosmosDatabase;

    /** Reference to the Cosmos DB container instance. */
    private static CosmosContainer cosmosContainer;

    /**
     * Static block to initialize the Cosmos DB connection **only once** at startup.
     * 
     * <p>
     * The connection is established in a **thread-safe manner** and shared across
     * all requests to minimize resource consumption.
     * </p>
     */
    static {
        try {
            logger.info("Initializing Cosmos DB connection...");

            cosmosClient = new CosmosClientBuilder()
                    .endpoint("your-endpoint") // Replace with actual configuration
                    .key("your-key")           // Replace with actual configuration
                    .gatewayMode()             // Recommended for read-heavy workloads
                    .buildClient();

            cosmosDatabase = cosmosClient.getDatabase("your-database-name"); // Replace with actual database name
            cosmosContainer = cosmosDatabase.getContainer("your-container-name"); // Replace with actual container name

            logger.info("✅ Cosmos DB connection established successfully.");
        } catch (Exception e) {
            logger.error("❌ Failed to initialize Cosmos DB client: ", e);
        }
    }

    /**
     * Retrieves the shared Cosmos DB container instance.
     * 
     * <p>
     * This method allows service classes to execute queries against the 
     * configured Cosmos DB container.
     * </p>
     * 
     * @return the active {@link CosmosContainer} instance.
     */
    public CosmosContainer getContainer() {
        return cosmosContainer;
    }

    /**
     * Closes the Cosmos DB connection when the application is shutting down.
     * 
     * <p>
     * This method is automatically called before the application exits, ensuring 
     * that all database connections are released properly.
     * </p>
     */
    @PreDestroy
    public void close() {
        if (cosmosClient != null) {
            cosmosClient.close();
            logger.info("✅ Cosmos DB connection closed.");
        }
    }
}

