/**
 * Orchestrates the full email-delivery flow against the external Email API.
 * <ol>
 *   <li>Obtains an OAuth access token via {@link TokenService} (uses cache if enabled).</li>
 *   <li>POSTs the email payload to the “deliveries” endpoint and retrieves a deliveryTaskId.</li>
 *   <li>Polls the delivery-status endpoint until it reaches COMPLETED/ERROR or times out.</li>
 * </ol>
 *
 * Thread-safety: stateless; safe to call concurrently.
 *
 * @param userName          path segment required by the Email API (tenant/user/agent id).
 * @param emailPayloadJson  JSON payload to send to the Email API.
 * @param customProperties  configuration object that provides base URLs and timing.
 * @param tokenService      service used to fetch/cached OAuth bearer token.
 * @param restTemplate      HTTP client used for all calls.
 * @return result map with keys:
 *         <ul>
 *           <li><b>ok</b> (Boolean): overall success (true only if polling reached COMPLETED).</li>
 *           <li><b>stage</b> (String): "send" on send failure, "done" after polling.</li>
 *           <li><b>statusCode</b> (Integer): last HTTP status observed.</li>
 *           <li><b>deliveryTaskId</b> (Integer): task id when available.</li>
 *           <li><b>finalStatus</b> (String): COMPLETED | ERROR | TIMEOUT (when polled).</li>
 *           <li><b>error</b> (String): error message when <b>ok</b> is false.</li>
 *           <li><b>lastBody</b> (Map): last response body from status polling (when available).</li>
 *         </ul>
 */

/**
 * Sends an email by calling:
 * <pre>
 *   POST {mailBaseUrl}/e/tymail/v1/{userPathSegment}/mail/deliveries
 * </pre>
 * Requires a valid Bearer token. Does not retry internally (caller handles 401→token refresh).
 *
 * @param mailBaseUrl       Email API base URL (e.g., https://mail.paas.crmstyle.com).
 * @param userPathSegment   path segment (tenant/user/agent id).
 * @param bearerToken       OAuth access token (with or without "Bearer " prefix).
 * @param emailPayloadJson  JSON body per provider spec.
 * @param deliveryUrl       format string for the deliveries URL (e.g., "/e/tymail/v1/%s/mail/deliveries").
 * @param rest              RestTemplate to use.
 * @return map with keys:
 *         <ul>
 *           <li><b>ok</b> (Boolean): true if 2xx and deliveryTaskId present.</li>
 *           <li><b>statusCode</b> (Integer): HTTP status.</li>
 *           <li><b>deliveryTaskId</b> (Integer): task id when successful.</li>
 *           <li><b>raw</b> (Map): raw response body on success.</li>
 *           <li><b>error</b> (String): error description on failure.</li>
 *         </ul>
 */

/**
