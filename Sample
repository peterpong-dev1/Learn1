package com.example.lookup;

import com.azure.cosmos.*;
import com.azure.cosmos.models.*;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.util.*;

/**
 * Executes a sequence of Cosmos DB queries defined in a LookupRule,
 * populating and enriching a shared context map with output values.
 */
public class LookupExecutor {

    private static final ObjectMapper OBJECT_MAPPER = new ObjectMapper();

    // You can inject or manage this via DI or factory
    private final CosmosClient cosmosClient;

    public LookupExecutor(CosmosClient cosmosClient) {
        this.cosmosClient = cosmosClient;
    }

    /**
     * Executes all lookup entities defined in the given rule using the context map for parameter resolution.
     *
     * @param context     Shared data map containing both inputs and outputs between query steps.
     * @param lookupRule  Rule defining the sequence of Cosmos DB lookups to perform.
     * @throws RuntimeException if any query or mapping fails.
     */
    public void executeLookupSteps(Map<String, Object> context, LookupRule lookupRule) {
        for (LookupEntity entity : lookupRule.getEntities()) {
            try {
                CosmosDatabase database = cosmosClient.getDatabase(entity.getDatabase());
                CosmosContainer container = database.getContainer(entity.getContainer());

                // Resolve parameters using context
                SqlParameterList sqlParams = resolveParams(entity.getParams(), context);
                SqlQuerySpec querySpec = new SqlQuerySpec(entity.getQuery(), sqlParams);

                CosmosPagedIterable<JsonNode> response = container.queryItems(querySpec, new CosmosQueryRequestOptions(), JsonNode.class);

                Optional<JsonNode> firstResult = response.stream().findFirst();
                if (firstResult.isEmpty()) {
                    throw new NoSuchElementException("No result found for entity: " + entity.getName());
                }

                JsonNode resultNode = firstResult.get();

                // Extract and populate outputs into context
                extractOutputs(resultNode, entity.getOutputs(), context);

            } catch (Exception e) {
                throw new RuntimeException("Failed to process entity: " + entity.getName(), e);
            }
        }
    }

    /**
     * Resolves parameters by looking up their values in the shared context map.
     *
     * @param paramDefs Map of parameter names to context keys.
     * @param context   Context map to resolve values from.
     * @return SqlParameterList containing resolved parameters.
     */
    private SqlParameterList resolveParams(Map<String, String> paramDefs, Map<String, Object> context) {
        SqlParameterList params = new SqlParameterList();
        for (Map.Entry<String, String> entry : paramDefs.entrySet()) {
            String paramName = entry.getKey();
            String contextKey = entry.getValue();
            Object value = context.get(contextKey);
            if (value == null) {
                throw new IllegalArgumentException("Missing parameter in context: " + contextKey);
            }
            params.add(new SqlParameter("@" + paramName, value));
        }
        return params;
    }

    /**
     * Extracts output fields from a JSON result node and adds them to the context map.
     *
     * @param resultNode JSON document returned from query.
     * @param outputs    Map of document paths to context keys.
     * @param context    Context map to populate.
     */
    private void extractOutputs(JsonNode resultNode, Map<String, String> outputs, Map<String, Object> context) {
        for (Map.Entry<String, String> entry : outputs.entrySet()) {
            String docPath = entry.getKey();
            String contextKey = entry.getValue();

            JsonNode valueNode = resolveJsonPath(resultNode, docPath);
            if (valueNode != null && !valueNode.isNull()) {
                context.put(contextKey, valueNode.isValueNode() ? valueNode.asText() : valueNode.toString());
            }
        }
    }

    /**
     * Resolves dot-notation JSON path from a JsonNode.
     * Supports basic array index resolution like "agency[0].name".
     *
     * @param node  JSON root node.
     * @param path  Dot-notation path like "agency[0].name".
     * @return Resolved JsonNode or null.
     */
    private JsonNode resolveJsonPath(JsonNode node, String path) {
        try {
            String[] parts = path.split("\\.");
            JsonNode current = node;
            for (String part : parts) {
                if (part.contains("[") && part.endsWith("]")) {
                    String field = part.substring(0, part.indexOf("["));
                    int index = Integer.parseInt(part.substring(part.indexOf("[") + 1, part.indexOf("]")));
                    current = current.get(field);
                    if (current == null || !current.isArray() || current.size() <= index) return null;
                    current = current.get(index);
                } else {
                    current = current.get(part);
                    if (current == null) return null;
                }
            }
            return current;
        } catch (Exception e) {
            return null;
        }
    }
}


