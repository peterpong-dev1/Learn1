import com.azure.cosmos.*;
import com.azure.cosmos.models.*;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.fasterxml.jackson.databind.node.JsonNodeFactory;

import java.time.Instant;
import java.util.Map;

public final class CosmosReportingUtil {

    private CosmosReportingUtil() {}

    /**
     * Create minimal doc if not exists.
     * If doc exists (by correlationId), returns existing doc.
     * If not, inserts a new one with given fields.
     *
     * @param container     Cosmos DB container
     * @param correlationId correlation id (used for id and partition key)
     * @param fields        map of fields to insert on first creation
     * @return ObjectNode   created or existing document
     */
    public static ObjectNode createIfNotExists(CosmosContainer container, 
                                               String correlationId,
                                               Map<String, Object> fields) {
        try {
            // Try to read the existing doc
            return container.readItem(correlationId, new PartitionKey(correlationId), ObjectNode.class)
                            .getItem();
        } catch (CosmosException e) {
            if (e.getStatusCode() != 404) {
                throw e; // rethrow if it's not "Not Found"
            }
        }

        // Create a new document with dynamic fields
        ObjectNode doc = JsonNodeFactory.instance.objectNode();
        doc.put("id", correlationId);
        doc.put("correlationId", correlationId);

        // Add user-specified fields dynamically
        if (fields != null) {
            fields.forEach((k, v) -> {
                if (v != null) {
                    if (v instanceof String) {
                        doc.put(k, (String) v);
                    } else if (v instanceof Integer) {
                        doc.put(k, (Integer) v);
                    } else if (v instanceof Long) {
                        doc.put(k, (Long) v);
                    } else if (v instanceof Boolean) {
                        doc.put(k, (Boolean) v);
                    } else {
                        doc.putPOJO(k, v); // fallback for objects
                    }
                }
            });
        }

        // Always add createdAt timestamp
        doc.put("createdAt", Instant.now().toString());

        // Insert document
        return container.createItem(doc, new PartitionKey(correlationId), new CosmosItemRequestOptions())
                        .getItem();
    }
}