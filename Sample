for (Map.Entry<String, String> e : event.extractedFields.entrySet()) {
    final String baseName = e.getKey();
    if (baseName.endsWith(".itemField")) continue;

    final String path = e.getValue();
    if (path == null || path.isBlank() || path.charAt(0) != '/') continue;

    final JsonNode node = newDoc.at(path);
    if (node == null || node.isMissingNode() || node.isNull()) continue;

    ArrayNode out = M.createArrayNode();   // always output array
    Set<String> seen = new HashSet<>();

    if (node.isArray()) {
        // --- existing logic for arrays ---
        final String itemFieldKey  = baseName + ".itemField";
        final String itemFieldConf = event.extractedFields.get(itemFieldKey);
        final boolean itemIsPointer =
                (itemFieldConf != null && !itemFieldConf.isBlank() && itemFieldConf.startsWith("/"));

        for (JsonNode item : node) {
            String val;
            if (itemFieldConf == null || itemFieldConf.isBlank()) {
                val = item.asText(null);
            } else {
                val = (itemIsPointer
                        ? item.at(itemFieldConf).asText(null)
                        : item.path(itemFieldConf).asText(null));
            }
            if (val == null || val.isBlank()) continue;
            if (!seen.add(val)) continue;
            out.add(val);
        }
    } else {
        // --- NEW: handle object or scalar ---
        if (node.isValueNode()) {
            // plain scalar → wrap in array
            String val = node.asText(null);
            if (val != null && !val.isBlank() && seen.add(val)) {
                out.add(val);
            }
        } else if (node.isObject()) {
            // object → keep whole JSON object string
            // (or pick a field if you want)
            String val = node.toString();
            if (val != null && !val.isBlank() && seen.add(val)) {
                out.add(val);
            }
        }
    }

    if (out.size() > 0) {
        extractedFieldsNode.set(baseName, out);
    }
}