    @PartitionKey
    private String agentId;
    private String clerkNumber;
    private String roles;
    private List<Name> name;
    private LocalDate birthDate;
    private Gender gender;
    private List<PhoneNumber> phoneNumber;
    private List<Email> email;
    private List<DigitalTouchpoint> digitalTouchpoint;
    private Solicitor solicitor;
    private Agency agency;
    private AgencyOffice agencyOffice;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Name {
    private CharacterSetType characterSetType;
    private String lastName;
    private String firstName;
    private boolean namePictoricKanjiFlag;
    private boolean nameNonStandardKanjiFlag;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class PhoneNumber {
    private PhoneType type;
    private ContactType contactType;
    private String number1;
    private String number2;
    private String number3;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Email {
    private String address;
    private boolean addressValidated;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class DigitalTouchpoint {
    private DigitalType type;
    private String digitalId;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Solicitor {
    private String employeeId;
    private String employeeNumber;
    private String name;
    private String phoneNumber1;
    private String phoneNumber2;
    private String phoneNumber3;
    private String emailAddress;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class Agency {
    private String associationRegistrationNumber;
    private String agencyNumber;
    private String name;
}

@Data
@NoArgsConstructor
@AllArgsConstructor
public class AgencyOffice {
    private String officeNumber;
    private String name;
}

// Enum Implementations
import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonValue;

public enum CharacterSetType {
    KANJI("kanji"),
    KANA("kana"),
    ALFABET("alfabet");

    private final String value;

    CharacterSetType(String value) {
        this.value = value;
    }

    @JsonValue
    public String getValue() {
        return value;
    }

    @JsonCreator
    public static CharacterSetType fromValue(String value) {
        for (CharacterSetType type : CharacterSetType.values()) {
            if (type.value.equalsIgnoreCase(value)) {
                return type;
            }
        }
        throw new IllegalArgumentException("Invalid CharacterSetType: " + value);
    }
}

