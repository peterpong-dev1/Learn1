package com.neo.handler;

import com.azure.storage.blob.*;
import com.azure.storage.blob.models.*;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.io.ByteArrayInputStream;
import java.io.InputStream;
import java.nio.charset.StandardCharsets;
import java.time.OffsetDateTime;
import java.util.*;

public class TrackedChangeHandler {

    private final BlobContainerClient containerClient;
    private final Map<String, List<String>> trackedFieldsPerContainer;
    private final ObjectMapper mapper = new ObjectMapper();
    private final int maxRetries;

    public TrackedChangeHandler(String connectionString, String containerName, Map<String, List<String>> trackedFieldsPerContainer, int maxRetries) {
        BlobServiceClient blobServiceClient = new BlobServiceClientBuilder()
                .connectionString(connectionString)
                .buildClient();
        this.containerClient = blobServiceClient.getBlobContainerClient(containerName);
        this.trackedFieldsPerContainer = trackedFieldsPerContainer;
        this.maxRetries = maxRetries;
    }

    public void handle(String cosmosContainerName, ObjectNode newDoc) {
        try {
            String docId = newDoc.get("id").asText();
            List<String> trackedFields = trackedFieldsPerContainer.getOrDefault(cosmosContainerName, Collections.emptyList());

            String blobPrefix = cosmosContainerName + "/" + docId;
            String latestBlobName = blobPrefix + "/latest.json";
            BlobClient latestBlob = containerClient.getBlobClient(latestBlobName);

            boolean isFirstTime = !latestBlob.exists();
            JsonNode oldTrackedData = null;
            String oldEtag = null;

            if (!isFirstTime) {
                BlobDownloadResult download = latestBlob.downloadContent();
                oldTrackedData = mapper.readTree(download.getContent().toBytes());
                oldEtag = download.getDeserializedHeaders().getETag();
            }

            ObjectNode newTrackedData = mapper.createObjectNode();
            for (String field : trackedFields) {
                JsonNode val = newDoc.get(field);
                if (val != null) newTrackedData.set(field, val);
            }

            boolean hasChanged = isFirstTime || !newTrackedData.equals(oldTrackedData);

            if (hasChanged) {
                // Version the blob
                String versionName = blobPrefix + "/" + OffsetDateTime.now() + ".json";
                BlobClient versionBlob = containerClient.getBlobClient(versionName);
                versionBlob.upload(BinaryData.fromObject(newTrackedData));

                // Update latest.json using ETag
                updateLatestBlob(latestBlob, newTrackedData, oldEtag);
            }

        } catch (Exception ex) {
            System.err.println("Error processing document: " + ex.getMessage());
            ex.printStackTrace();
        }
    }

    private void updateLatestBlob(BlobClient blobClient, ObjectNode content, String oldEtag) throws Exception {
        byte[] data = content.toString().getBytes(StandardCharsets.UTF_8);
        InputStream stream = new ByteArrayInputStream(data);
        BlobRequestConditions conditions = (oldEtag != null) ? new BlobRequestConditions().setIfMatch(oldEtag) : new BlobRequestConditions();

        for (int attempt = 1; attempt <= maxRetries; attempt++) {
            try {
                blobClient.uploadWithResponse(
                        new BlobParallelUploadOptions(stream, data.length).setRequestConditions(conditions).setOverwrite(true),
                        null, null);
                // Add "latest" tag
                Map<String, String> tags = new HashMap<>();
                tags.put("latest", "true");
                blobClient.setTags(tags);
                return;
            } catch (BlobStorageException ex) {
                if (ex.getStatusCode() == 412 && attempt < maxRetries) {
                    Thread.sleep(200); // small backoff
                    continue;
                }
                throw ex;
            }
        }
    }
}


