3) Factory to build the JSON payload

package com.neo.notification.bus;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.neo.notification.change.ChangeInfo;
import com.neo.notification.config.EventConfig;

import java.time.OffsetDateTime;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

public final class MessageFactory {
    private static final ObjectMapper M = new ObjectMapper();

    private MessageFactory() {}

    public static EventMessage build(EventConfig.Event evt,
                                     String when,                    // "insert" or "update"
                                     String container,
                                     String docId,
                                     ObjectNode newDoc,
                                     String etag,
                                     Long lsnOrNull,
                                     String correlationId,
                                     List<ChangeInfo> deltas,
                                     Map<String,String> extraTags) {

        EventMessage m = EventMessage.newEmpty();
        m.correlationId = correlationId;
        m.when = when;

        // event section
        EventMessage.Event e = new EventMessage.Event();
        e.container = container;
        e.docId = docId;
        e.eventId = evt.id;
        e.eventName = evt.name;
        e.changes = (deltas == null) ? null : deltas.stream().map(d -> {
            EventMessage.Change c = new EventMessage.Change();
            c.field = d.getFieldPath();
            c.kind = d.getKind().name();
            c.oldValue = nodeToScalar(d.getOldValue());
            c.newValue = nodeToScalar(d.getNewValue());
            return c;
        }).collect(Collectors.toList());
        m.event = e;

        // context
        EventMessage.Context ctx = new EventMessage.Context();
        ctx.etag = etag;
        ctx.lsn  = lsnOrNull;
        ctx.readAtUtc = OffsetDateTime.now().toString();
        ctx.tags = extraTags;
        m.context = ctx;

        return m;
    }

    private static Object nodeToScalar(com.fasterxml.jackson.databind.JsonNode n) {
        if (n == null || n.isNull()) return null;
        if (n.isTextual()) return n.asText();
        if (n.isNumber())  return n.numberValue();
        if (n.isBoolean()) return n.booleanValue();
        // fall back to compact JSON for objects/arrays
        try { return M.writeValueAsString(n); } catch (Exception ignore) { return n.toString(); }
    }
}


