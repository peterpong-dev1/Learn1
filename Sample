  control.createEntity(new TableEntity(controlPk, "summary")
     .addProperty("claimedAtUtc", Instant.now().toString()));
  // first writer → enqueue {agentId, day, summaryType}
} catch (TableServiceException ex) {
  if (ex.getResponse().getStatusCode() == 409) { /* already scheduled → skip */ }
  else throw ex;
}

Notification counts (by summaryType):

Map<String,Integer> counts = new HashMap<>();
for (TableEntity e : table.listEntities(new ListEntitiesOptions().setFilter(filter), null, null)) {
    String rk = e.getRowKey();   // summaryType#eventKey#docId
    int p1 = rk.indexOf('#');            // after summaryType
    int p2 = rk.indexOf('#', p1 + 1);    // after eventKey
    if (p1 > 0 && p2 > p1) {
        String eventKey = rk.substring(p1 + 1, p2);
        counts.merge(eventKey, 1, Integer::sum);
    }
}
