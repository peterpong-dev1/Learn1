Here you go—production-ready, concise Java to get per-event counts for one agent on one Tokyo day from your DailyAgentEventDocs table:

Utility

import com.azure.data.tables.*;
import com.azure.data.tables.models.*;
import java.util.*;

public final class AgentDailyCountsUtil {

    /** Table shape: PK = yyyyMMdd#agentId, RK = eventKey#docId */
    public static Map<String,Integer> getCountsByEventForAgentDay(
            TableClient table, String dayYyyymmdd, String agentId) {

        String pk = dayYyyymmdd + "#" + agentId;

        // Scan all rows in this partition; aggregate by eventKey via RK prefix before first '#'
        String filter = "PartitionKey eq '" + escape(pk) + "'";
        PagedIterable<TableEntity> rows = table.listEntities(
                new ListEntitiesOptions().setFilter(filter), null, null);

        Map<String,Integer> counts = new HashMap<>();
        for (TableEntity e : rows) {
            String rk = e.getRowKey();                 // eventKey#docId
            int hash = rk.indexOf('#');
            if (hash <= 0) continue;
            String eventKey = rk.substring(0, hash);
            counts.merge(eventKey, 1, Integer::sum);
        }
        return counts;
    }

    private static String escape(String s){ return s.replace("'", "''"); }
}

