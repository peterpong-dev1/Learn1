package your.pkg;

import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.CosmosException;
import com.azure.cosmos.models.CosmosItemRequestOptions;
import com.azure.cosmos.models.CosmosPatchOperations;
import com.azure.cosmos.models.PartitionKey;
import com.fasterxml.jackson.databind.node.JsonNodeFactory;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.time.Instant;
import java.util.Map;

public final class ReportingStore {

  private static final JsonNodeFactory F = JsonNodeFactory.instance;

  private ReportingStore() {}

  /** Create minimal skeleton if missing; returns existing if present. */
  public static ObjectNode createIfNotExists(CosmosContainer container,
                                             String correlationId,
                                             Map<String, Object> baseFields) {
    try {
      return container.readItem(correlationId, new PartitionKey(correlationId), ObjectNode.class).getItem();
    } catch (CosmosException e) {
      if (e.getStatusCode() != 404) throw e;
    }

    // --- skeleton (parents pre-seeded so PATCH never complains about missing paths)
    ObjectNode doc = F.objectNode();
    doc.put("id", correlationId);
    doc.put("correlationId", correlationId);

    // top-level
    doc.put("docId", (String) null);
    doc.put("function", (String) null);
    doc.put("container", (String) null);
    doc.put("status", "IN_PROGRESS");                 // overall workflow status

    // classification
    doc.put("notificationType", (String) null);
    doc.put("triggerType", (String) null);
    doc.put("recipientType", (String) null);

    // email block
    ObjectNode email = F.objectNode();
    email.put("subject", (String) null);
    email.put("body", (String) null);
    doc.set("email", email);

    // stages buckets (empty objects so nested PATCH works)
    ObjectNode stages = F.objectNode();
    stages.set("cosmosdbtrigger",          F.objectNode());
    stages.set("sbmsgqueuetrigger",        F.objectNode());
    stages.set("sbnotificationqueuetrigger", F.objectNode());
    stages.set("notificationapi",          F.objectNode());
    doc.set("stages", stages);

    // error + timestamps
    doc.put("errorMessage", (String) null);
    doc.put("createdAt", Instant.now().toString());
    doc.put("lastUpdatedAtUtc", Instant.now().toString());

    // optional base fields on first create (dot or / paths)
    if (baseFields != null && !baseFields.isEmpty()) {
      mergeIntoObject(doc, baseFields);
    }

    return container.createItem(doc, new PartitionKey(correlationId), new CosmosItemRequestOptions()).getItem();
  }

  /**
   * PATCH fields server-side. Keys may be "a.b.c" or "/a/b/c".
   * Assumes parent objects (like /stages/*) exist (created by createIfNotExists).
   */
  public static ObjectNode patchFields(CosmosContainer container,
                                       String correlationId,
                                       Map<String, Object> fields) {
    if (fields == null || fields.isEmpty()) return read(container, correlationId);

    CosmosPatchOperations ops = CosmosPatchOperations.create();
    for (Map.Entry<String, Object> e : fields.entrySet()) {
      ops.set(toPointer(e.getKey()), e.getValue());
    }
    ops.set("/lastUpdatedAtUtc", Instant.now().toString());

    return container.patchItem(correlationId, new PartitionKey(correlationId), ops, ObjectNode.class).getItem();
  }

  /**
   * Convenience: try PATCH; if the item does not exist (404), create skeleton (with optional base fields) then PATCH.
   */
  public static ObjectNode patchOrCreate(CosmosContainer container,
                                         String correlationId,
                                         Map<String, Object> patchFields,
                                         Map<String, Object> baseOnCreate) {
    try {
      return patchFields(container, correlationId, patchFields);
    } catch (CosmosException e) {
      if (e.getStatusCode() != 404) throw e;
      createIfNotExists(container, correlationId, baseOnCreate);
      return patchFields(container, correlationId, patchFields);
    }
  }

  /** Read helper (id==pk). */
  public static ObjectNode read(CosmosContainer container, String correlationId) {
    return container.readItem(correlationId, new PartitionKey(correlationId), ObjectNode.class).getItem();
  }

  // ---------- in-memory merge for initial create ----------

  /** Merge a map of paths (dot or /) into an ObjectNode, creating parents as needed. */
  private static void mergeIntoObject(ObjectNode root, Map<String, Object> fields) {
    for (Map.Entry<String, Object> e : fields.entrySet()) {
      setNested(root, toPointer(e.getKey()), e.getValue());
    }
    root.put("lastUpdatedAtUtc", Instant.now().toString());
  }

  /** Convert "a.b.c", "a/b/c", or "/a/b/c" → "/a/b/c". */
  private static String toPointer(String raw) {
    String p = raw == null ? "" : raw.trim();
    if (p.isEmpty()) throw new IllegalArgumentException("Empty path");
    if (!p.startsWith("/")) p = p.replace('.', '/');
    if (!p.startsWith("/")) p = "/" + p;
    while (p.contains("//")) p = p.replace("//", "/");
    return p;
  }

  /** Create parents inside an ObjectNode and set the leaf value. */
  private static void setNested(ObjectNode root, String pointer, Object value) {
    String[] parts = pointer.substring(1).split("/");
    ObjectNode cur = root;
    for (int i = 0; i < parts.length - 1; i++) {
      String key = parts[i];
      var next = cur.get(key);
      if (!(next instanceof ObjectNode)) {
        ObjectNode created = F.objectNode();
        cur.set(key, created);
        cur = created;
      } else {
        cur = (ObjectNode) next;
      }
    }
    String leaf = parts[parts.length - 1];

    if (value == null) {
      cur.putNull(leaf);
    } else if (value instanceof Boolean b) {
      cur.put(leaf, b);
    } else if (value instanceof Number n) {
      cur.put(leaf, n.doubleValue());           // keeps it numeric; change if you need specific types
    } else if (value instanceof ObjectNode on) {
      cur.set(leaf, on);
    } else {
      cur.put(leaf, value.toString());
    }
  }
}