2) Message schema (small, explicit, versioned)

package com.neo.notification.bus;

import com.fasterxml.jackson.annotation.JsonInclude;
import java.time.OffsetDateTime;
import java.util.List;
import java.util.Map;
import java.util.UUID;

@JsonInclude(JsonInclude.Include.NON_NULL)
public final class EventMessage {
    public String schemaVersion = "1.0";
    public String messageId;          // set by factory (UUID)
    public String correlationId;      // your composite id
    public String when;               // "insert" | "update"
    public Event event;
    public Context context;

    @JsonInclude(JsonInclude.Include.NON_NULL)
    public static final class Event {
        public String container;
        public String docId;
        public String eventId;        // from your config
        public String eventName;      // from your config
        public List<Change> changes;  // tracked changes only
    }

    @JsonInclude(JsonInclude.Include.NON_NULL)
    public static final class Change {
        public String field;
        public String kind;           // ADDED | REMOVED | MODIFIED
        public Object oldValue;
        public Object newValue;
    }

    @JsonInclude(JsonInclude.Include.NON_NULL)
    public static final class Context {
        public String etag;
        public Long lsn;
        public String readAtUtc;
        public Map<String, String> tags; // free‑form (container, functionName, etc.)
    }

    public static EventMessage newEmpty() {
        EventMessage m = new EventMessage();
        m.messageId = UUID.randomUUID().toString();
        return m;
    }
}


