2) Publisher (send JSON with headers)

package com.yourco.sb;

import com.azure.core.util.BinaryData;
import com.azure.messaging.servicebus.ServiceBusMessage;
import com.azure.messaging.servicebus.ServiceBusSenderClient;

import java.util.Map;
import java.util.logging.Level;
import java.util.logging.Logger;

/** Sends JSON payloads to a Service Bus queue. */
public final class QueuePublisher {
    private QueuePublisher() {}

    public static void sendJson(ServiceBusSenderClient sender,
                                String json,
                                String messageId,
                                String correlationId,
                                Map<String, Object> appProps,
                                Logger log) {
        try {
            ServiceBusMessage msg = new ServiceBusMessage(BinaryData.fromString(json));
            msg.setContentType("application/json");
            if (messageId != null && !messageId.isBlank())   msg.setMessageId(messageId);
            if (correlationId != null && !correlationId.isBlank()) msg.setCorrelationId(correlationId);
            if (appProps != null) {
                appProps.forEach((k, v) -> {
                    if (k != null && !k.isBlank() && v != null) {
                        msg.getApplicationProperties().put(k, v);
                    }
                });
            }
            sender.sendMessage(msg);
            if (log != null) log.fine("Sent to SB: " + sender.getEntityPath() + " bytes=" + json.length());
        } catch (Exception e) {
            if (log != null) log.log(Level.SEVERE, "Failed to send to Service Bus", e);
            // rethrow so Functions retry/DLQ can handle transient failures
            throw e;
        }
    }
}


