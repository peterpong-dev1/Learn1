public PaginatedResult<AgencyOfficesResponseEntity> searchWithDynamicQueryAndPaginated(
        String continuationToken,
        int pageSize) {

    logger.info("(QUERY START) Searching to get ALL Agency Offices");

    StringBuilder queryBuilder = new StringBuilder(BASE_QUERY); // e.g. SELECT * FROM c WHERE ...
    List<SqlParameter> parameters = new ArrayList<>();

    PaginatedResult<AgencyOfficesResponseEntity> result;

    long queryStartTime = System.currentTimeMillis();
    logger.info("Query to be executed: {}", queryBuilder);

    try {
        // Build SQL query spec
        SqlQuerySpec querySpec = new SqlQuerySpec(queryBuilder.toString(), parameters);
        logger.info("Executing query: {}", querySpec.getQueryText());

        // Cosmos options
        CosmosQueryRequestOptions options = new CosmosQueryRequestOptions();

        // Execute paginated query
        CosmosPagedIterable<AgencyOfficesResponseEntity> pagedIterable =
                cosmosContainer.queryItems(querySpec, options, AgencyOfficesResponseEntity.class);

        Iterator<FeedResponse<AgencyOfficesResponseEntity>> iterator =
                pagedIterable.iterableByPage(continuationToken, pageSize).iterator();

        if (!iterator.hasNext()) {
            logger.info("No results for token '{}'", continuationToken);
            return new PaginatedResult<>(Collections.emptyList(), null);
        }

        FeedResponse<AgencyOfficesResponseEntity> page = iterator.next();
        List<AgencyOfficesResponseEntity> entities = page.getResults();
        String nextToken = page.getContinuationToken();

        logger.info("Query returned {} results, next token: {}", entities.size(), nextToken);
        Utils.printListAsJson(entities, "Entity results in Repository");

        result = new PaginatedResult<>(entities, nextToken);

    } catch (Exception e) {
        logger.error("Unexpected error during query execution: {}", e.getMessage(), e);
        throw e;
    }

    logger.info("(QUERY END) Results: {}, Time: {}ms",
            result.getItems().size(), System.currentTimeMillis() - queryStartTime);

    logger.debug("Raw database response: {}", result.getItems());

    return result;
}