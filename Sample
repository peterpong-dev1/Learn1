try {
    rules = EventConfigLoader.loadFromBlob(
            CONFIG_CONTAINER,                  // your config container client
            cosmosDbContainerName,             // "appInfoProgressManagement"
            context.getLogger());
} catch (Exception ex) {
    // Already writing ErrorWriter in your code; keep that and move on
    ErrorWriter.writeError(ERROR_CONTAINER,
            cosmosDbContainerName, "", "LoadEventsFromConfigError",
            "Failed to load EventConfig: " + ex.getMessage(),
            "UNKNOWN", null, "", context.getInvocationId(), context.getFunctionName(), context.getLogger());
    throw new RuntimeException("CUSTOM ERROR: cannot load EventConfig", ex);
}

if (rules == null || rules.events == null || rules.events.isEmpty()) {
    ErrorWriter.writeError(ERROR_CONTAINER,
            cosmosDbContainerName, "", "ConfigEmpty",
            "No events configured for container " + cosmosDbContainerName,
            "UNKNOWN", null, "", context.getInvocationId(), context.getFunctionName(), context.getLogger());
