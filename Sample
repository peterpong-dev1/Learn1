✅ 1. DTO Layer (Updated with Lombok Best Practices)

📌 AddressDTO.java (Response)

package jp.co.neofirst.servicing.dto;

import com.fasterxml.jackson.annotation.JsonInclude;
import jakarta.validation.constraints.NotNull;
import lombok.Builder;
import lombok.Getter;
import lombok.Setter;

import java.time.LocalDate;
import java.util.List;

/**
 * Data Transfer Object for Address response.
 */
@Getter
@Setter
@Builder
@JsonInclude(JsonInclude.Include.NON_NULL) // ✅ Excludes null fields from JSON
public class AddressDTO {

    @NotNull(message = "id must not be null") // ✅ Ensures id is mandatory
    private String id;

    @NotNull(message = "addressCode must not be null") // ✅ Ensures addressCode is mandatory
    private String addressCode;

    private List<AddressDetailsDTO> address;
    private LocalDate effectiveDate;
    private LocalDate terminationDate;
}

✅ Why?
	•	Uses @Getter and @Setter instead of @Data to avoid unnecessary equals() and hashCode().
	•	@Builder helps create immutable DTOs easily.
	•	@NotNull ensures mandatory fields (id, addressCode).
	•	@JsonInclude(JsonInclude.Include.NON_NULL) prevents returning null fields.

