1..3 | ForEach-Object {
    Start-Job -ScriptBlock {
        $randomRequestId = [guid]::NewGuid().ToString()  # Generate unique request ID
        Invoke-RestMethod -Uri "https://api.example.com/financialInstitution/search" `
          -Method Post `
          -Headers @{
              "Content-Type"="application/json"
              "Request-Id"=$randomRequestId
          } `
          -Body '{"financialInstitutionCode": "0001","financialInstitutionBranchCode": "333"}'
    }
}