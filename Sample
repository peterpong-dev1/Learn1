public final class MessageFactory {
  private static final ObjectMapper M = new ObjectMapper();

  public static ServiceBusMessage buildBodyAndEnvelope(
      EventConfig.Event evt,
      ObjectNode newDoc,
      Map<String, Object> envelope,     // correlationId, messageId, container, docId, eventId, eventName, when, etc.
      List<ChangeInfo> deltas,
      String sessionIdOrNull
  ) throws Exception {

    ObjectNode root = M.createObjectNode();

    // envelope
    envelope.forEach((k,v) -> root.set(k, M.valueToTree(v)));
    root.put("createdAtUtc", OffsetDateTime.now().toString());

    // pass notificationType/triggerType if present
    if (evt.notificationType != null || evt.triggerType != null) {
      ObjectNode notify = M.createObjectNode();
      if (evt.notificationType != null) notify.put("notificationType", evt.notificationType);
      if (evt.triggerType != null)      notify.put("triggerType",      evt.triggerType);
      root.set("notify", notify);
    }

    // dynamic keys (name -> JSON Pointer path)
    if (evt.keys != null && !evt.keys.isEmpty()) {
      ObjectNode keysNode = M.createObjectNode();
      for (Map.Entry<String,String> e : evt.keys.entrySet()) {
        String name = safe(e.getKey());
        String ptr  = safe(e.getValue());
        if (name.isEmpty() || ptr.isEmpty() || ptr.charAt(0) != '/') continue; // must be a JSON Pointer
        JsonNode v = newDoc.at(ptr);                      // null-safe lookup
        if (v != null && !v.isMissingNode() && !v.isNull()) {
          // use text if scalar, else embed as JSON
          keysNode.set(name, v.isValueNode() ? M.valueToTree(v.asText()) : v);
        }
      }
      if (keysNode.size() > 0) root.set("keys", keysNode);
    }

    // shrink your deltas if you want (optional)
    if (deltas != null && !deltas.isEmpty()) {
      root.set("deltas", M.valueToTree(deltas.stream().map(ChangeInfo::toSmall).toList()));
    }

    byte[] payload = M.writeValueAsBytes(root);

    ServiceBusMessage msg = new ServiceBusMessage(BinaryData.fromBytes(payload))
        .setContentType("application/json");

    // set broker props from envelope if present
    if (envelope.containsKey("messageId"))    msg.setMessageId(String.valueOf(envelope.get("messageId")));
    if (envelope.containsKey("correlationId"))msg.setCorrelationId(String.valueOf(envelope.get("correlationId")));
    if (sessionIdOrNull != null)              msg.setSessionId(sessionIdOrNull);

    // optional application properties for quick filtering
    if (envelope.containsKey("container")) msg.getApplicationProperties().put("container", envelope.get("container"));
    if (envelope.containsKey("eventId"))   msg.getApplicationProperties().put("eventId",   envelope.get("eventId"));
    if (envelope.containsKey("docId"))     msg.getApplicationProperties().put("docId",     envelope.get("docId"));
    if (envelope.containsKey("when"))      msg.getApplicationProperties().put("when",      envelope.get("when"));

    return msg;
  }

  private static String safe(String s) { return s == null ? "" : s.trim(); }
}