private static final ObjectMapper M = new ObjectMapper();

/** Upsert-like PATCH: creates missing parents for each JSON-Pointer, retries on ETag. */
public static ObjectNode patchFieldsCreatingParents(
    CosmosContainer container,
    String correlationId,
    Map<String, ?> fields) {

  if (fields == null || fields.isEmpty()) return read(container, correlationId);

  final int maxAttempts = 6;
  long backoff = 100;

  for (int attempt = 1; attempt <= maxAttempts; attempt++) {
    ObjectNode doc = read(container, correlationId);
    String etag = null;

    if (doc == null) {
      // minimal skeleton so later PATCHes can rely on parents
      doc = M.createObjectNode();
      doc.put("id", correlationId);
      doc.set("stages", M.createObjectNode());
      doc.set("agentProcessing", M.createObjectNode());
      doc.put("createdAt", Instant.now().toString());
      upsert(container, doc); // first create (no ETag)
    } else {
      etag = doc.path("_etag").asText(null); // optimistic concurrency
    }

    // apply all paths
    for (Map.Entry<String, ?> e : fields.entrySet()) {
      final String pointer = e.getKey();               // e.g. "/agentProcessing/agentsById/A1/state"
      final JsonNode value = toJsonNode(e.getValue()); // String, number, boolean, JsonNode, etc.
      deepPut(doc, pointer, value);                    // creates parents then sets value
    }
    doc.put("lastUpdatedAtUtc", Instant.now().toString());

    try {
      CosmosItemRequestOptions opts = new CosmosItemRequestOptions();
      if (etag != null) opts.setIfMatchETag(etag);     // fail if concurrent writer won
      return container
          .replaceItem(doc, correlationId, new PartitionKey(correlationId), opts)
          .getItem();
    } catch (CosmosException ex) {
      final int code = ex.getStatusCode();
      // retry on common transient/conflict statuses
      if (code == 412 || code == 404 || code == 409 || code == 429 || code >= 500) {
        try {
          long jitter = ThreadLocalRandom.current().nextLong(0, 60);
          Thread.sleep(Math.min(1200, backoff) + jitter);
        } catch (InterruptedException ie) {
          Thread.currentThread().interrupt();
        }
        backoff *= 2;
        continue; // next attempt
      }
      throw ex; // non-retryable
    }
  }

  // give back whatever is latest if we exhausted retries
  return read(container, correlationId);
}

/* ---------- helpers ---------- */

private static ObjectNode read(CosmosContainer c, String id) {
  try {
    return c.readItem(id, new PartitionKey(id), ObjectNode.class).getItem();
  } catch (CosmosException ex) {
    if (ex.getStatusCode() == 404) return null;
    throw ex;
  }
}

private static void upsert(CosmosContainer c, ObjectNode doc) {
  c.upsertItem(doc, new PartitionKey(doc.get("id").asText()), new CosmosItemRequestOptions());
}

/** Create parents for a JSON-Pointer path ("/a/b/c") and set value at the final segment. */
private static void deepPut(ObjectNode root, String pointer, JsonNode value) {
  if (pointer == null || pointer.isBlank() || pointer.charAt(0) != '/')
    throw new IllegalArgumentException("Path must start with '/': " + pointer);

  String[] parts = pointer.split("/", -1); // first element is ""
  ObjectNode cur = root;
  for (int i = 1; i < parts.length; i++) {
    String key = unescape(parts[i]);
    boolean last = (i == parts.length - 1);
    if (last) {
      cur.set(key, value == null ? NullNode.instance : value);
    } else {
      JsonNode next = cur.get(key);
      if (!(next instanceof ObjectNode)) {
        next = M.createObjectNode();
        cur.set(key, next);
      }
      cur = (ObjectNode) next;
    }
  }
}

/** JSON Pointer unescape: "~1" => "/", "~0" => "~" */
private static String unescape(String s) {
  return s.replace("~1", "/").replace("~0", "~");
}

private static JsonNode toJsonNode(Object v) {
  if (v == null) return NullNode.instance;
  if (v instanceof JsonNode) return (JsonNode) v;
  if (v instanceof CharSequence) return TextNode.valueOf(v.toString());
  if (v instanceof Boolean) return BooleanNode.valueOf((Boolean) v);
  if (v instanceof Integer) return IntNode.valueOf((Integer) v);
  if (v instanceof Long) return LongNode.valueOf((Long) v);
  if (v instanceof Double) return DoubleNode.valueOf((Double) v);
  return M.valueToTree(v); // maps, lists, POJOs
}

