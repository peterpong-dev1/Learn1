package com.yourorg.messageapi.service;

import com.yourorg.messageapi.model.IncomingMessage;

import java.time.Instant;
import java.util.logging.Logger;

/**
 * Reject clearly stale items (fast gate).
 * You can also query Cosmos here to ensure message applies to the current state.
 */
public final class FreshnessService {
    private FreshnessService(){}

    public static boolean check(IncomingMessage msg, Logger log) {
        try {
            // Example: drop if produced > 2 days ago
            long ageMs = Math.abs(Instant.now().toEpochMilli() - msg.getProducedAtEpochMs());
            long maxAgeMs = 2L * 24 * 60 * 60 * 1000; // 2 days
            if (msg.getProducedAtEpochMs() > 0 && ageMs > maxAgeMs) {
                log.info("FreshnessService: stale message, skipping. correlationId=" + msg.getCorrelationId());
                return false;
            }
            return true;
        } catch (Exception e) {
            log.warning("FreshnessService error: " + e.getMessage());
            return false;
        }
    }
}


