package com.neo.notification.consumer;

import com.azure.data.tables.TableClient;
import com.azure.data.tables.TableEntity;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.microsoft.azure.functions.*;
import com.microsoft.azure.functions.annotation.*;

import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.time.Duration;
import java.time.Instant;
import java.util.Optional;
import java.util.logging.Logger;

/**
 * Azure Function that consumes messages from Service Bus.
 * - Immediate messages: forwarded directly to Notification API
 * - Scheduled messages: validated against Azure Table (deduplication)
 */
public class ScheduledMessageConsumerFn {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    // Thread-safe reusable HTTP client
    private static final HttpClient HTTP = HttpClient.newBuilder()
            .connectTimeout(Duration.ofSeconds(5))
            .build();

    // Configuration from environment (local.settings.json or App Settings in Azure)
    private static final String TABLE_NAME =
            System.getenv().getOrDefault("MESSAGE_TRACKING_TABLE", "MessageTracking");
    private static final String STORAGE_CONN = System.getenv("Blob_Connection");
    private static final String NOTIFY_API_URL =
            System.getenv().getOrDefault("NOTIFICATION_API_URL", "http://localhost:8080/notify");

    @FunctionName("ScheduledMessageConsumer")
    public void run(
            @ServiceBusQueueTrigger(
                    name = "msg",
                    queueName = "%ServiceBusQueueForMsgAPI%",
                    connection = "ServiceBusConnection",
                    isSessionsEnabled = true // set based on your SB config
            ) String body,
            final ExecutionContext context) {

        Logger log = context.getLogger();
        log.info("Consumer received message from queue.");

        try {
            JsonNode root = MAPPER.readTree(body);

            // Extract identifiers
            String docId         = optText(root, "metadata", "docId").orElseThrow();
            String notification  = optText(root, "notificationType").orElse(null);
            String trigger       = optText(root, "triggerType").orElse(null);
            String recipientType = optText(root, "recipient", "type").orElse(null);

            // Scheduled or not: presence of msgScheduleAt
            boolean isScheduled  = optText(root, "metadata", "msgScheduleAt").isPresent();

            // preparedAt (createdAtUtc from producer) must be present
            Instant preparedAt = optText(root, "metadata", "createdAtUtc")
                    .map(Instant::parse)
                    .orElseThrow(() -> new IllegalArgumentException("metadata.createdAtUtc missing"));

            if (!isScheduled) {
                // NOW message → no table check
                log.info("Immediate message → sending directly to Notification API.");
                callNotificationApi(body, log);
                return;
            }

            // SCHEDULED message → check table
            TableClient table = new com.azure.data.tables.TableClientBuilder()
                    .connectionString(STORAGE_CONN)
                    .tableName(TABLE_NAME)
                    .buildClient();

            String rowKey = String.join("|",
                    nz(notification), nz(trigger), nz(recipientType));

            Optional<TableEntity> entityOpt = tryGet(table, docId, rowKey);

            if (entityOpt.isEmpty()) {
                log.warning("Scheduled msg: no table row found → sending anyway.");
                callNotificationApi(body, log);
                return;
            }

            TableEntity entity = entityOpt.get();
            Instant tableLastUpdated = Optional.ofNullable(entity.getProperty("LastUpdatedTime"))
                    .map(Object::toString)
                    .map(Instant::parse)
                    .orElseThrow(() -> new IllegalStateException("Table row missing LastUpdatedTime"));

            if (preparedAt.equals(tableLastUpdated) || preparedAt.isAfter(tableLastUpdated)) {
                log.info("Scheduled msg is latest → sending.");
                callNotificationApi(body, log);
            } else {
                log.info("Scheduled msg is stale (preparedAt < table) → SKIPPED.");
            }

        } catch (Exception ex) {
            log.severe("Consumer failed: " + ex.getMessage());
            throw new RuntimeException(ex);
        }
    }

    // ---- Helpers ----

    private static Optional<TableEntity> tryGet(TableClient client, String partitionKey, String rowKey) {
        try {
            return Optional.of(client.getEntity(partitionKey, rowKey));
        } catch (Exception e) {
            return Optional.empty();
        }
    }

    private static Optional<String> optText(JsonNode n, String... path) {
        JsonNode cur = n;
        for (String p : path) {
            if (cur == null) return Optional.empty();
            cur = cur.get(p);
        }
        return (cur != null && cur.isTextual()) ? Optional.of(cur.asText()) : Optional.empty();
    }

    private static String nz(String s) {
        return (s == null || s.isBlank()) ? "-" : s;
    }

    private static void callNotificationApi(String jsonPayload, Logger log) throws Exception {
        HttpRequest req = HttpRequest.newBuilder()
                .uri(URI.create(NOTIFY_API_URL))
                .header("Content-Type", "application/json")
                .POST(HttpRequest.BodyPublishers.ofString(jsonPayload))
                .timeout(Duration.ofSeconds(10))
                .build();

        HttpResponse<String> res = HTTP.send(req, HttpResponse.BodyHandlers.ofString());
        if (res.statusCode() / 100 != 2) {
            log.severe("Notification API failed: " + res.statusCode() + " body=" + res.body());
            throw new RuntimeException("Notification API call failed");
        } else {
            log.info("Notification API success: " + res.statusCode());
        }
    }
}


