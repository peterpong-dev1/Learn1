case "afterdaysfromtoday": {
    int days = evt.schedule.days == null ? 0 : Math.max(0, evt.schedule.days);
    ZoneId zone = zoneOrDefault(evt.schedule.tz);               // your helper
    LocalTime t = parseTimeOrDefault(evt.schedule.time, LocalTime.of(9, 0));

    // “today” = midnight of the current day in the target zone
    ZonedDateTime today = ZonedDateTime.now(zone)
                                       .withHour(0).withMinute(0)
                                       .withSecond(0).withNano(0);

    ZonedDateTime candidate = today.plusDays(days)
                                   .withHour(t.getHour())
                                   .withMinute(t.getMinute())
                                   .withSecond(0)
                                   .withNano(0);

    // If you want “today + 0 days” but the time already passed, move to tomorrow
    if (days == 0 && !candidate.isAfter(ZonedDateTime.now(zone))) {
        candidate = candidate.plusDays(1);
    }

    if (Boolean.TRUE.equals(evt.schedule.businessDays)) {
        candidate = bumpToNextBusinessDay(candidate);
    }

    return candidate.toOffsetDateTime();
}