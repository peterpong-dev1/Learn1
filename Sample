4️⃣ Mapper (CalendarMapper.java)

Handles DTO ↔ Entity conversion.

package com.example.calendar.mapper;

import com.example.calendar.dto.Calender;
import com.example.calendar.entity.CalenderEntity;
import java.util.List;
import java.util.stream.Collectors;

public class CalendarMapper {

    public static CalenderEntity toEntity(Calender dto) {
        return new CalenderEntity(dto.getId(), 
                Calender.convertDateToEpoch(dto.getCalendarDay()), 
                dto.isBusinessDayFlag());
    }

    public static Calender toDto(CalenderEntity entity) {
        return new Calender(entity.getId(), 
                Calender.convertEpochToDate(entity.getCalendarDay()), 
                entity.isBusinessDayFlag());
    }

    public static List<Calender> toDtoList(List<CalenderEntity> entities) {
        return entities.stream().map(CalendarMapper::toDto).collect(Collectors.toList());
    }
}

5️⃣ Controller (CalendarController.java)

Handles API requests.

package com.example.calendar.controller;

import com.example.calendar.dto.CalenderSearchConditions;
import com.example.calendar.dto.Calender;
import com.example.calendar.service.CalendarService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.validation.annotation.Validated;
import org.springframework.web.bind.annotation.*;

import javax.validation.Valid;
import javax.validation.constraints.NotBlank;
import java.util.List;

@RestController
@RequestMapping("/common/calendar")
@RequiredArgsConstructor
@Slf4j
@Validated
public class CalendarController {

    private final CalendarService calendarService;

    @PostMapping("/search")
    public ResponseEntity<List<Calender>> searchCalendar(
            @RequestHeader("x-request-id") @NotBlank String requestId,
            @Valid @RequestBody CalenderSearchConditions searchConditions) {
        
        log.info("Received request to search calendar with requestId: {}", requestId);
        
        List<Calender> calendars = calendarService.searchCalendar(requestId, searchConditions);
        return ResponseEntity.ok(calendars);
    }
}

6️⃣ Service (CalendarService.java)

Handles date validation and conversion.

package com.example.calendar.service;

import com.example.calendar.dto.Calender;
import com.example.calendar.dto.CalenderSearchConditions;
import com.example.calendar.mapper.CalendarMapper;
import com.example.calendar.repository.CalendarRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class CalendarService {

    private final CalendarRepository calendarRepository;

    public List<Calender> searchCalendar(String requestId, CalenderSearchConditions searchConditions) {
        log.info("Processing calendar search for requestId: {}", requestId);

        searchConditions.validateDates();

        Long startEpoch = searchConditions.getStartDate() != null
                ? Calender.convertDateToEpoch(searchConditions.getStartDate())
                : null;

        Long endEpoch = searchConditions.getEndDate() != null
                ? Calender.convertDateToEpoch(searchConditions.getEndDate())
                : null;

        List<Calender> calendars = CalendarMapper.toDtoList(
                calendarRepository.findByDateRange(startEpoch, endEpoch)
        );

        if (calendars.isEmpty()) {
            log.warn("No calendar data found for requestId: {}", requestId);
        }

        return calendars;
    }
}

7️⃣ Repository (CalendarRepository.java)

Executes Cosmos DB queries dynamically.

package com.example.calendar.repository;

import com.azure.cosmos.CosmosContainer;
import com.azure.cosmos.CosmosClient;
import com.azure.cosmos.CosmosDatabase;
import com.azure.cosmos.models.SqlQuerySpec;
import com.azure.cosmos.models.CosmosQueryRequestOptions;
import com.azure.cosmos.models.SqlParameter;
import com.example.calendar.entity.CalenderEntity;
import com.example.calendar.config.QueryConfig;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Repository;

import java.util.ArrayList;
import java.util.List;

@Repository
@RequiredArgsConstructor
@Slf4j
public class CalendarRepository {

    private final CosmosClient cosmosClient;
    private final QueryConfig queryConfig;

    private static final String DATABASE_NAME = "CalendarDB";
    private static final String CONTAINER_NAME = "CalendarContainer";

    private CosmosContainer getContainer() {
        CosmosDatabase database = cosmosClient.getDatabase(DATABASE_NAME);
        return database.getContainer(CONTAINER_NAME);
    }

    public List<CalenderEntity> findByDateRange(Long startEpoch, Long endEpoch) {
        log.info("Fetching calendar data between {} and {}", startEpoch, endEpoch);

        String query;
        List<SqlParameter> parameters = new ArrayList<>();

        if (startEpoch != null && endEpoch != null) {
            query = queryConfig.getQuery("find_by_epoch_range");
            parameters.add(new SqlParameter("@startEpoch", startEpoch));
            parameters.add(new SqlParameter("@endEpoch", endEpoch));
        } else if (startEpoch != null) {
            query = queryConfig.getQuery("find_by_start_epoch");
            parameters.add(new SqlParameter("@startEpoch", startEpoch));
        } else if (endEpoch != null) {
            query = queryConfig.getQuery("find_by_end_epoch");
            parameters.add(new SqlParameter("@endEpoch", endEpoch));
        } else {
            query = queryConfig.getQuery("find_all");
        }

        SqlQuerySpec sqlQuerySpec = new SqlQuerySpec(query, parameters);
        List<CalenderEntity> results = new ArrayList<>();

        getContainer().queryItems(sqlQuerySpec, new CosmosQueryRequestOptions(), CalenderEntity.class)
                .forEach(results::add);

        return results;
    }
}

8️⃣ queries.properties

find_all=SELECT * FROM c
find_by_start_epoch=SELECT * FROM c WHERE c.calendarDay >= @startEpoch
find_by_end_epoch=SELECT * FROM c WHERE c.calendarDay <= @endEpoch
find_by_epoch_range=SELECT * FROM c WHERE c.calendarDay BETWEEN @startEpoch AND @endEpoch

