3) Sender helper (tiny wrapper)

package com.neo.bus;

import com.azure.messaging.servicebus.ServiceBusSenderClient;
import com.azure.messaging.servicebus.ServiceBusMessage;

import java.util.logging.Logger;

/** Minimal send helper with logging. */
public final class BusSender {
    private BusSender() {}

    public static void send(ServiceBusMessage msg, Logger log) {
        ServiceBusSenderClient sender = ServiceBusSenderProvider.sender();
        sender.sendMessage(msg);
        if (log != null) {
            log.info("Sent to Service Bus: messageId=" + msg.getMessageId()
                    + " corrId=" + msg.getCorrelationId()
                    + " sessionId=" + msg.getSessionId());
        }
    }
}


