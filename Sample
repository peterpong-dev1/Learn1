package com.neo.util;

import java.util.Arrays;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class EnvironmentUtil {
    public static String getSetting(String key) {
        return System.getenv().getOrDefault(key, System.getProperty(key));
    }

    public static Map<String, List<String>> getTrackedFieldConfig() {
        // Ideally this would read from a blob or config file
        // For now using hardcoded fallback
        Map<String, List<String>> config = new HashMap<>();
        config.put("container1", Arrays.asList("status", "type"));
        config.put("container2", Arrays.asList("priority", "owner"));
        return config;
    }
}


