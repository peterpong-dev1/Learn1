public List<AddressModel> searchWithDynamicQuery(AddressSearchConditionsDTO searchConditions) {
    List<AddressModel> results = new ArrayList<>();
    logger.info("[QUERY START] Searching addresses");

    StringBuilder queryBuilder = new StringBuilder(queryConfig.getQuery("baseQuery"));
    List<SqlParameter> parameters = new ArrayList<>();

    if (searchConditions.getAddressCode() != null) {
        queryBuilder.append(" ").append(queryConfig.getQuery("filterByAddressCode"));
        parameters.add(new SqlParameter("@addressCode", searchConditions.getAddressCode()));
        logger.debug("Added filter: addressCode = {}", searchConditions.getAddressCode());
    }

    if (searchConditions.getAddress() != null) {
        AddressDetailsDTO address = searchConditions.getAddress();

        if (address.getCharacterSetType() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByCharacterSetType"));
            parameters.add(new SqlParameter("@characterSetType", address.getCharacterSetType().getValue()));
            logger.debug("Added filter: characterSetType = {}", address.getCharacterSetType().getValue());
        }

        if (address.getPostalCode() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByPostalCode"));
            parameters.add(new SqlParameter("@postalCode", address.getPostalCode()));
            logger.debug("Added filter: postalCode = {}", address.getPostalCode());
        }

        if (address.getCountry() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByCountry"));
            parameters.add(new SqlParameter("@country", address.getCountry()));
            logger.debug("Added filter: country = {}", address.getCountry());
        }

        if (address.getPrefecture() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByPrefecture"));
            parameters.add(new SqlParameter("@prefecture", address.getPrefecture()));
            logger.debug("Added filter: prefecture = {}", address.getPrefecture());
        }

        if (address.getCity() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByCity"));
            parameters.add(new SqlParameter("@city", address.getCity()));
            logger.debug("Added filter: city = {}", address.getCity());
        }

        if (address.getTown() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByTown"));
            parameters.add(new SqlParameter("@town", address.getTown()));
            logger.debug("Added filter: town = {}", address.getTown());
        }

        if (address.getLane() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByLane"));
            parameters.add(new SqlParameter("@lane", address.getLane()));
            logger.debug("Added filter: lane = {}", address.getLane());
        }

        if (address.getEffectiveDate() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByEffectiveDate"));
            parameters.add(new SqlParameter("@effectiveDate", address.getEffectiveDate().toString()));
            logger.debug("Added filter: effectiveDate = {}", address.getEffectiveDate());
        }

        if (address.getTerminationDate() != null) {
            queryBuilder.append(" ").append(queryConfig.getQuery("filterByTerminationDate"));
            parameters.add(new SqlParameter("@terminationDate", address.getTerminationDate().toString()));
            logger.debug("Added filter: terminationDate = {}", address.getTerminationDate());
        }
    }

    long queryStartTime = System.currentTimeMillis();
    SqlQuerySpec querySpec = new SqlQuerySpec(queryBuilder.toString(), parameters);
    
    results = cosmosContainer.queryItems(querySpec, new CosmosQueryRequestOptions(), AddressModel.class)
            .stream()
            .collect(Collectors.toList());

    logger.info("[QUERY END] Query executed. Results found: {}, Processing time: {} ms",
            results.size(), System.currentTimeMillis() - queryStartTime);
    logger.debug("Raw database response: {}", results);

    return results;
}

