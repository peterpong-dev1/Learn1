1) Rule engine that uses deltas

package com.neo.notification.rules;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.node.ObjectNode;
import com.neo.notification.change.ChangeInfo;
import com.neo.notification.config.EventConfig;

import java.util.*;

/**
 * Evaluates EventConfig rules using already-computed tracked-field deltas.
 * Thread-safe & stateless.
 */
public final class RuleEngineDelta {

    private RuleEngineDelta() {}

    /**
     * Return true if the event should fire for this document.
     *
     * @param evt        event spec (AND/OR + rules)
     * @param isCreate   true when document is newly created
     * @param newDoc     current version from change feed
     * @param baseline   previous snapshot (may be null on create)
     * @param deltas     tracked-field changes for this doc (empty on create)
     */
    public static boolean evaluate(EventConfig.Event evt,
                                   boolean isCreate,
                                   ObjectNode newDoc,
                                   ObjectNode baseline,
                                   List<ChangeInfo> deltas) {

        // Fast path: build an index "fieldPath -> last ChangeInfo for that field"
        Map<String, ChangeInfo> idx = indexByFieldPath(deltas);

        boolean hasAny = false;
        boolean allOk = true;

        for (EventConfig.Rule r : evt.conditions.rules) {
            boolean hit = evalRule(r, isCreate, newDoc, baseline, idx);
            hasAny |= hit;
            allOk  &= hit;
            if (evt.conditions.isOr() && hit)    return true;   // OR short‑circuit
            if (evt.conditions.isAnd() && !hit)  return false;  // AND short‑circuit
        }

        // If there were no rules, treat as "no match"
        if (evt.conditions.rules == null || evt.conditions.rules.isEmpty()) return false;

        return evt.conditions.isAnd() ? allOk : hasAny;
    }

    private static boolean evalRule(EventConfig.Rule r,
                                    boolean isCreate,
                                    ObjectNode newDoc,
                                    ObjectNode baseline,
                                    Map<String, ChangeInfo> idx) {

        final String op   = safe(r.op);
        final String path = safe(r.field);

        switch (op) {
            case "changed":
                // any change on this field
                return changed(idx.get(path));

            case "changedTo":
                // changed and new value equals r.value
                return changedTo(idx.get(path), r.value);

            case "becameNotNull":
                // changed from missing/null to present (CREATE also OK if present)
                return becameNotNull(isCreate, path, newDoc, baseline, idx.get(path));

            case "becameNull":
                // changed from present to missing/null
                return becameNull(isCreate, path, newDoc, baseline, idx.get(path));

            case "eq":
                // compare current value only
                return equalsNow(path, newDoc, r.value);

            case "ne":
                return !equalsNow(path, newDoc, r.value);

            default:
                // unknown op => do not match
                return false;
        }
    }

    // ---------- delta-based predicates ----------

    private static boolean changed(ChangeInfo c) {
        return c != null; // your ChangeInfo exists only when field changed (ADDED/REMOVED/MODIFIED)
    }

    private static boolean changedTo(ChangeInfo c, String expected) {
        if (c == null) return false;
        JsonNode nv = c.getNewValue();
        return nv != null && expected != null && expected.equals(nv.asText());
    }

    private static boolean becameNotNull(boolean isCreate, String path,
                                         ObjectNode newDoc, ObjectNode baseline, ChangeInfo c) {
        if (isCreate) {
            // treat as becameNotNull if present now
            return present(newDoc.at(jsonPointer(path)));
        }
        if (c == null) return false;
        // ADDED or MODIFIED-from-null to something
        return present(c.getNewValue()) && !present(c.getOldValue());
    }

    private static boolean becameNull(boolean isCreate, String path,
                                      ObjectNode newDoc, ObjectNode baseline, ChangeInfo c) {
        if (isCreate) return false; // on create we don't consider "becameNull"
        if (c == null) return false;
        // REMOVED or MODIFIED-to-null
        return !present(c.getNewValue()) && present(c.getOldValue());
    }

    // ---------- current-value predicates ----------

    private static boolean equalsNow(String path, ObjectNode doc, String expected) {
        JsonNode v = doc.at(jsonPointer(path));
        if (!present(v)) return expected == null || expected.isBlank();
        return expected != null && expected.equals(v.asText());
    }

    // ---------- helpers ----------

    private static String safe(String s) { return s == null ? "" : s.trim(); }

    private static boolean present(JsonNode n) {
        return n != null && !n.isNull() && !(n.isTextual() && n.asText().isBlank());
    }

    /** Convert dotted path ("a.b[0].c") to a JSON Pointer. Simple support for [idx]. */
    private static String jsonPointer(String dotted) {
        if (dotted == null || dotted.isBlank()) return "";
        String[] parts = dotted.split("\\.");
        StringBuilder p = new StringBuilder();
        for (String part : parts) {
            int arr = part.indexOf('[');
            if (arr < 0) {
                p.append('/').append(part);
            } else {
                String name = part.substring(0, arr);
                p.append('/').append(name);
                String rest = part.substring(arr);
                // handle one level like [0][1]...
                int i = 0;
                while (i < rest.length()) {
                    int l = rest.indexOf('[', i);
                    int r = rest.indexOf(']', l + 1);
                    if (l < 0 || r < 0) break;
                    String idx = rest.substring(l + 1, r);
                    p.append('/').append(idx);
                    i = r + 1;
                }
            }
        }
        return p.toString();
    }

    private static Map<String, ChangeInfo> indexByFieldPath(List<ChangeInfo> deltas) {
        if (deltas == null || deltas.isEmpty()) return Collections.emptyMap();
        Map<String, ChangeInfo> m = new HashMap<>(deltas.size() * 2);
        for (ChangeInfo c : deltas) {
            if (c != null && c.getFieldPath() != null) {
                m.put(c.getFieldPath(), c); // last wins; good enough for tracked fields
            }
        }
        return m;
    }
}

Assumptions
• Your ChangeInfo has getFieldPath(), getOldValue(), getNewValue(), and an enum describing kind—exactly like your screenshot.
• Your EventConfig is the single‑file model we aligned on earlier (events[] with conditions.logic and rules[] containing op, field, value).

