package com.yourorg.messageapi.util;

import com.azure.cosmos.*;

/**
 * Singleton CosmosClient provider (thread-safe).
 * Reads endpoint/key from Function App settings:
 *   CosmosEndpoint, CosmosKey
 */
public final class CosmosClientProvider {
    private static final String EP  = System.getenv("CosmosEndpoint");
    private static final String KEY = System.getenv("CosmosKey");

    private static class Holder {
        static final CosmosClient CLIENT = new CosmosClientBuilder()
                .endpoint(EP)
                .key(KEY)
                .consistencyLevel(ConsistencyLevel.EVENTUAL)
                .gatewayMode() // or .directMode() if allowed
                .buildClient();
    }
    private CosmosClientProvider(){}

    public static CosmosClient client() {
        return Holder.CLIENT;
    }
}


