The current filter only extracts top-level fields from the request body. If you need to extract specific fields inside nested objects (e.g., address.postalCode), we need to modify the logic to handle nested JSON structures dynamically.

✅ Updated Code: Extract Nested Fields from Objects (Like address.postalCode)

We will:
	1.	Check if a field is nested (e.g., address.postalCode).
	2.	Recursively extract values from nested objects.
	3.	Store only non-null values.

import jakarta.servlet.Filter;
import jakarta.servlet.FilterChain;
import jakarta.servlet.ServletException;
import jakarta.servlet.ServletRequest;
import jakarta.servlet.ServletResponse;
import jakarta.servlet.http.HttpServletRequest;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.io.IOException;
import java.util.*;

@Component
public class RequestInputFilter implements Filter {

    private final ObjectMapper objectMapper = new ObjectMapper();

    // Load allowed fields from config (supports nested fields like "address.postalCode")
    @Value("#{'${logging.allowedFields}'.split(',')}")
    private List<String> allowedFields;

    @Override
    public void doFilter(ServletRequest request, ServletResponse response, FilterChain chain)
            throws IOException, ServletException {

        if (request instanceof HttpServletRequest) {
            HttpServletRequest httpRequest = (HttpServletRequest) request;

            // Extract Request ID
            String requestId = httpRequest.getHeader("X-Request-ID");
            if (requestId == null || requestId.isEmpty()) {
                requestId = UUID.randomUUID().toString();
            }
            request.setAttribute("requestId", requestId);

            // Read request body
            byte[] bodyBytes = request.getInputStream().readAllBytes();
            if (bodyBytes.length > 0) {
                String requestBody = new String(bodyBytes, httpRequest.getCharacterEncoding());
                Map<String, Object> inputParams = objectMapper.readValue(requestBody, Map.class);

                // Extract only allowed fields (including nested ones)
                Map<String, Object> filteredInputs = extractAllowedFields(inputParams, allowedFields);

                // Store selected fields in request attributes
                request.setAttribute("requestInputs", filteredInputs);
            }
        }

        chain.doFilter(request, response);
    }

    /**
     * Extracts allowed fields (including nested ones) from a given JSON map.
     */
    private Map<String, Object> extractAllowedFields(Map<String, Object> inputParams, List<String> allowedFields) {
        Map<String, Object> filteredInputs = new HashMap<>();

        for (String field : allowedFields) {
            if (field.contains(".")) { // Handle nested fields
                String[] fieldParts = field.split("\\.");
                Object value = extractNestedValue(inputParams, fieldParts, 0);
                if (value != null) {
                    filteredInputs.put(field, value);
                }
            } else { // Handle top-level fields
                if (inputParams.containsKey(field) && inputParams.get(field) != null) {
                    filteredInputs.put(field, inputParams.get(field));
                }
            }
        }

        return filteredInputs;
    }

    /**
     * Recursively extracts a nested value from a JSON map based on field path.
     */
    private Object extractNestedValue(Map<String, Object> json, String[] fieldParts, int index) {
        if (index >= fieldParts.length || json == null) {
            return null;
        }

        Object value = json.get(fieldParts[index]);

        if (index == fieldParts.length - 1) {
            return value; // Found the final value
        }

        if (value instanceof Map) {
            return extractNestedValue((Map<String, Object>) value, fieldParts, index + 1);
        }

        return null;
    }
}

✅ Configurable Nested Fields in application.properties

Now, you can specify nested fields dynamically.

logging.allowedFields=addressCode,characterSetType,address.postalCode,address.city

📌 Example Request JSON

{
  "addressCode": "12345",
  "characterSetType": "KANJI",
  "address": {
    "postalCode": "98765",
    "city": "Tokyo",
    "country": "Japan"
  },
  "otherField1": "Not Needed",
  "otherField2": "Ignore This"
}

🚨 Extracted Fields in Request Attributes

{
  "requestId": "b5c8a2d3-6789-12ef-abcd-1234567890ff",
  "requestInputs": {
    "addressCode": "12345",
    "characterSetType": "KANJI",
    "address.postalCode": "98765",
    "address.city": "Tokyo"
  }
}

🚀 Key Features

✅ Handles both top-level and nested fields dynamically
✅ Extracts only non-null values
✅ Configurable allowed fields from application.properties
✅ Prevents unnecessary logging of irrelevant fields

