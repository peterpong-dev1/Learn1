🚀 1. PolicyHolderMapper.java (Main Mapper Class)

package com.example.project.mapper;

import com.example.project.dto.*;
import com.example.project.model.*;
import org.springframework.stereotype.Component;
import java.util.List;
import java.util.stream.Collectors;

@Component
public class PolicyHolderMapper {

    // Convert DTO to Model (For Saving to Cosmos DB)
    public PolicyHolder toModel(PolicyHolderDTO dto) {
        if (dto == null) {
            return null;
        }
        return new PolicyHolder(
                dto.getId(),
                dto.getPolicyId(),
                dto.getCustomerType(),
                dto.getCustomerId(),
                dto.getPartyType(),
                toNameDetailsModelList(dto.getName()),
                toAddressDetailsModelList(dto.getAddress()),
                toPhoneNumberModelList(dto.getPhone()),
                toContactModelList(dto.getContact()),
                toDigitalContactModelList(dto.getDigitalContact()),
                dto.getReceiptOfNotices()
        );
    }

    // Convert Model to DTO (For Returning API Response)
    public PolicyHolderDTO toDTO(PolicyHolder model) {
        if (model == null) {
            return null;
        }
        return new PolicyHolderDTO(
                model.getId(),
                model.getPolicyId(),
                model.getCustomerType(),
                model.getCustomerId(),
                model.getPartyType(),
                toNameDetailsDTOList(model.getName()),
                toAddressDetailsDTOList(model.getAddress()),
                toPhoneNumberDTOList(model.getPhone()),
                toContactDTOList(model.getContact()),
                toDigitalContactDTOList(model.getDigitalContact()),
                model.getReceiptOfNotices()
        );
    }

    // Helper Methods for Nested Objects
    private List<NameDetails> toNameDetailsModelList(List<NameDetailsDTO> dtos) {
        return dtos == null ? null : dtos.stream()
                .map(dto -> new NameDetails(dto.getCharacterSetType(), dto.getFullName(), dto.getLastName(), dto.getFirstName()))
                .collect(Collectors.toList());
    }

    private List<NameDetailsDTO> toNameDetailsDTOList(List<NameDetails> models) {
        return models == null ? null : models.stream()
                .map(model -> new NameDetailsDTO(model.getCharacterSetType(), model.getFullName(), model.getLastName(), model.getFirstName()))
                .collect(Collectors.toList());
    }

    private List<AddressDetails> toAddressDetailsModelList(List<AddressDetailsDTO> dtos) {
        return dtos == null ? null : dtos.stream()
                .map(dto -> new AddressDetails(dto.getAddressType(), dto.getPostalCode(), dto.getCountry(),
                        dto.getState(), dto.getCity(), dto.getStreet(), dto.getEffectiveDate(), dto.getTerminationDate()))
                .collect(Collectors.toList());
    }

    private List<AddressDetailsDTO> toAddressDetailsDTOList(List<AddressDetails> models) {
        return models == null ? null : models.stream()
                .map(model -> new AddressDetailsDTO(model.getAddressType(), model.getPostalCode(), model.getCountry(),
                        model.getState(), model.getCity(), model.getStreet(), model.getEffectiveDate(), model.getTerminationDate()))
                .collect(Collectors.toList());
    }

    private List<PhoneNumber> toPhoneNumberModelList(List<PhoneNumberDTO> dtos) {
        return dtos == null ? null : dtos.stream()
                .map(dto -> new PhoneNumber(dto.getPhoneType(), dto.getPhoneNumber()))
                .collect(Collectors.toList());
    }

    private List<PhoneNumberDTO> toPhoneNumberDTOList(List<PhoneNumber> models) {
        return models == null ? null : models.stream()
                .map(model -> new PhoneNumberDTO(model.getPhoneType(), model.getPhoneNumber()))
                .collect(Collectors.toList());
    }

    private List<Contact> toContactModelList(List<ContactDTO> dtos) {
        return dtos == null ? null : dtos.stream()
                .map(dto -> new Contact(dto.getContactType(), dto.getContactDetails()))
                .collect(Collectors.toList());
    }

    private List<ContactDTO> toContactDTOList(List<Contact> models) {
        return models == null ? null : models.stream()
                .map(model -> new ContactDTO(model.getContactType(), model.getContactDetails()))
                .collect(Collectors.toList());
    }

    private List<DigitalContact> toDigitalContactModelList(List<DigitalContactDTO> dtos) {
        return dtos == null ? null : dtos.stream()
                .map(dto -> new DigitalContact(dto.getDigitalType(), dto.getDigitalContactDetails()))
                .collect(Collectors.toList());
    }

    private List<DigitalContactDTO> toDigitalContactDTOList(List<DigitalContact> models) {
        return models == null ? null : models.stream()
                .map(model -> new DigitalContactDTO(model.getDigitalType(), model.getDigitalContactDetails()))
                .collect(Collectors.toList());
    }
}



