final String docId = newDoc.get("id").asText();
ObjectNode baseline = null;
boolean isCreate;

try {
    // 1) Read snapshot to decide CREATE vs MODIFY
    baseline = GetSnapshotFromBlob.getSnapshotFromBlobStorage(
        DATA_CONTAINER, cosmosContainerName, docId, log);
    isCreate = (baseline == null);
} catch (IOException io) {
    // Storage hiccup -> let Azure Functions retry so we don't send a message yet
    log.severe("Snapshot read error for id=" + docId + ": " + io.getMessage());
    throw new RuntimeException(io);
}

// 2) Build message (include deltas only if modify)
String eventType = isCreate ? "CREATE" : "MODIFY";
ServiceBusMessage msg = MessageFactory.build(newDoc, baseline, eventType, cosmosContainerName);

// 3) Send first (so we never persist a state the world didn't hear about)
try {
    busSender.sendMessage(msg);
    log.info("Service Bus message sent for id=" + docId + ", type=" + eventType);
} catch (Exception sendEx) {
    // Fail fast so Functions will retry the whole invocation
    log.severe("Failed to send message for id=" + docId + ": " + sendEx.getMessage());
    throw new RuntimeException(sendEx);
}

// 4) Persist snapshot AFTER successful send
try {
    if (isCreate) {
        // Idempotent: uses If-None-Match "*" and will return false if someone else already created it
        boolean created = CreateBlob.createBaselineIfAbsent(
            DATA_CONTAINER, cosmosContainerName, docId, newDoc, log);
        log.info(created
            ? "Baseline created for id=" + docId
            : "Baseline already existed (idempotent) for id=" + docId);
    } else {
        // Write new version + flip latest tag (or overwrite latest per your strategy)
        UpdateBlob.writeVersionAndFlipLatest(
            DATA_CONTAINER, cosmosContainerName, docId, baseline, newDoc, log);
        log.info("Snapshot updated for id=" + docId);
    }
} catch (Exception persistEx) {
    // Persist failed but message was sent; surface error so you can alert/replay if needed
    log.severe("Post-send snapshot persist failed for id=" + docId + ": " + persistEx.getMessage());
    throw new RuntimeException(persistEx);
}