{
  "version": "1.0",
  "container": "transactionProgress",
  "events": [
    {
      "id": "transactionProgress_request_submitted",
      "name": "Transaction Request Submitted",
      "when": ["insert", "update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "becameNotNull", "field": "transferRequestStatusRegistrationDate" },
          { "op": "changedTo",     "field": "transferRequestStatus", "value": "01" }
        ]
      }
    },
    {
      "id": "transactionProgress_request_amended",
      "name": "Transaction Request Amended",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "becameNotNull", "field": "transferRequestStatusUpdateDate" }
        ]
      }
    },
    {
      "id": "transactionProgress_request_cancelled",
      "name": "Transaction Request Cancelled",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "changedTo", "field": "transferRequestStatus", "value": "99" }
        ]
      }
    },
    {
      "id": "transactionProgress_status_updated",
      "name": "Status Updated",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "changed", "field": "transferRequestStatus" }
        ]
      }
    },
    {
      "id": "transactionProgress_deficiency_detected",
      "name": "Deficiency Notification Sent",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "changedTo",     "field": "inadequacy",     "value": "true" },
          { "op": "becameNotNull", "field": "inadequacyContents" },
          { "op": "changedTo",     "field": "FUBI_STATUS",    "value": "01" }
        ]
      }
    },
    {
      "id": "transactionProgress_deficiency_resolved",
      "name": "Deficiency Resolved",
      "when": ["update"],
      "conditions": {
        "logic": "OR",
        "rules": [
          { "op": "changedTo", "field": "inadequacy",  "value": "false" },
          { "op": "changedTo", "field": "FUBI_STATUS", "value": "00" }
        ]
      }
    },
    {
      "id": "transactionProgress_decision_made",
      "name": "Decision Notification Sent",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "changedTo", "field": "transferRequestStatus", "value": "10" }
        ]
      }
    },
    {
      "id": "transactionProgress_completed",
      "name": "Transaction Completed",
      "when": ["update"],
      "conditions": {
        "logic": "AND",
        "rules": [
          { "op": "becameNotNull", "field": "lastProcessingDate" }
        ]
      }
    }
  ]
}