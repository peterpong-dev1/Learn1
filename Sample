2) Loader: EventConfigLoader.java

package com.neo.notification.config;

import com.azure.storage.blob.BlobContainerClient;
import com.azure.storage.blob.specialized.BlobInputStream;
import com.fasterxml.jackson.databind.DeserializationFeature;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.io.ByteArrayOutputStream;
import java.nio.charset.StandardCharsets;
import java.util.List;
import java.util.Objects;
import java.util.logging.Logger;

/**
 * Loads the event-rules JSON from Azure Blob Storage (or from a raw String).
 * Stateless & thread-safe; ObjectMapper is thread-safe after configuration.
 */
public final class EventConfigLoader {
    private static final ObjectMapper MAPPER = new ObjectMapper()
            .configure(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES, false);

    private EventConfigLoader() {}

    /**
     * Load config from a blob (e.g., "<container>_events.json").
     *
     * @param configContainer Blob container that holds your config files.
     * @param blobName        The blob name to read.
     * @param log             Logger (never null).
     * @return a fully-populated EventConfig, or null if missing/invalid.
     */
    public static EventConfig loadFromBlob(BlobContainerClient configContainer,
                                           String blobName,
                                           Logger log) {
        Objects.requireNonNull(configContainer, "configContainer");
        Objects.requireNonNull(blobName, "blobName");
        Objects.requireNonNull(log, "log");

        try {
            var blobClient = configContainer.getBlobClient(blobName);
            if (!blobClient.exists()) {
                log.severe("Config blob not found: " + blobName);
                return null;
            }

            try (BlobInputStream in = blobClient.openInputStream();
                 ByteArrayOutputStream out = new ByteArrayOutputStream()) {
                in.transferTo(out);
                String json = out.toString(StandardCharsets.UTF_8);
                return loadFromString(json, log);
            }
        } catch (Exception e) {
            log.severe("Failed to read config blob '" + blobName + "': " + e.getMessage());
            return null;
        }
    }

    /**
     * Load config from a JSON string (handy for tests or local overrides).
     *
     * @param json The JSON document.
     * @param log  Logger (never null).
     * @return a validated EventConfig, or null if invalid.
     */
    public static EventConfig loadFromString(String json, Logger log) {
        try {
            EventConfig cfg = MAPPER.readValue(json, EventConfig.class);
            // Minimal, non-intrusive checks (you asked for simple validation).
            if (cfg == null || cfg.container == null || cfg.container.isBlank()) {
                log.severe("Config missing required 'container'.");
                return null;
            }
            if (cfg.events == null || cfg.events.isEmpty()) {
                log.severe("Config has no events.");
                return null;
            }
            // Gentle normalization (does not mutate the source JSON on disk).
            for (EventConfig.Event e : cfg.events) {
                if (e.conditions != null) {
                    if (e.conditions.logic == null || e.conditions.logic.isBlank()) {
                        e.conditions.logic = "AND";
                    }
                    if (e.conditions.rules == null) {
                        e.conditions.rules = List.of();
                    }
                }
            }
            return cfg;
        } catch (Exception e) {
            log.severe("Failed to parse config JSON: " + e.getMessage());
            return null;
        }
    }
}


