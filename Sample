Perfect—let’s switch everything to strongly‑typed deltas.

Below is a clean version of both classes so your pipeline returns List<ChangeDelta> end‑to‑end.
It replaces the old Map<String,Object> helpers and also makes compareScalarFields return a list.

// ---------------- ChangeDelta.java ----------------
public final class ChangeDelta {
    public enum Kind { ADDED, REMOVED, MODIFIED }

    private final String fieldPath;  // e.g., "address.city" or "items[0].price.amount"
    private final String oldValue;   // compact scalar (null if missing)
    private final String newValue;   // compact scalar (null if missing)
    private final Kind   kind;

    public ChangeDelta(String fieldPath, String oldValue, String newValue, Kind kind) {
        this.fieldPath = fieldPath;
        this.oldValue  = oldValue;
        this.newValue  = newValue;
        this.kind      = kind;
    }

    public String getFieldPath() { return fieldPath; }
    public String getOldValue()  { return oldValue; }
    public String getNewValue()  { return newValue; }
    public Kind   getKind()      { return kind; }

    @Override public String toString() {
        return "ChangeDelta{path=" + fieldPath + ", kind=" + kind +
               ", old=" + oldValue + ", new=" + newValue + "}";
    }
}

// ---------------- TrackedDelta.java ----------------
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.node.ObjectNode;
import java.util.*;

public final class TrackedDelta {
    private TrackedDelta() {}

    /** Compute delta for scalar tracked fields only (ADDED / REMOVED / MODIFIED). */
    public static List<ChangeDelta> computeDelta(ObjectNode snapshotOld,
                                                 ObjectNode newDoc,
                                                 List<String> trackedFields) {
        List<ChangeDelta> changes = new ArrayList<>();
        if (newDoc == null || trackedFields == null || trackedFields.isEmpty()) {
            return changes;
        }
        changes.addAll(compareScalarFields(snapshotOld, newDoc, trackedFields));
        return changes;
    }

    /** Compares only scalar fields between old and new documents. */
    private static List<ChangeDelta> compareScalarFields(ObjectNode oldDoc,
                                                         ObjectNode newDoc,
                                                         List<String> trackedFields) {
        List<ChangeDelta> results = new ArrayList<>();

        for (String fieldPath : trackedFields) {
            if (fieldPath == null || fieldPath.isBlank()) continue;

            JsonNode oldVal = getValueByPath(oldDoc, fieldPath);
            JsonNode newVal = getValueByPath(newDoc, fieldPath);

            boolean oldPresent = oldVal != null && !oldVal.isMissingNode();
            boolean newPresent = newVal != null && !newVal.isMissingNode();

            if (oldPresent && newPresent) {
                if (!safeEqualsScalar(oldVal, newVal)) {
                    results.add(changeRecord(fieldPath, ChangeDelta.Kind.MODIFIED, oldVal, newVal));
                }
            } else if (!oldPresent && newPresent) {
                results.add(changeRecord(fieldPath, ChangeDelta.Kind.ADDED, null, newVal));
            } else if (oldPresent && !newPresent) {
                results.add(changeRecord(fieldPath, ChangeDelta.Kind.REMOVED, oldVal, null));
            }
            // else both missing -> no change
        }

        return results;
    }

    /** Navigate a dot-separated path like "item.address.phone"; returns null if missing. */
    private static JsonNode getValueByPath(JsonNode node, String fieldPath) {
        if (node == null || fieldPath == null || fieldPath.isBlank()) return null;
        String[] parts = fieldPath.split("\\.");
        JsonNode current = node;
        for (String part : parts) {
            if (current == null || current.isMissingNode()) return null;
            current = current.get(part);
        }
        return current;
    }

    /** Compare two scalar JsonNodes safely (treat nulls correctly). */
    private static boolean safeEqualsScalar(JsonNode oldVal, JsonNode newVal) {
        if (oldVal == null && newVal == null) return true;
        if (oldVal == null || newVal == null) return false;
        if (!oldVal.isValueNode() || !newVal.isValueNode()) return false; // only scalars here
        String a = toScalarString(oldVal);
        String b = toScalarString(newVal);
        return Objects.equals(a, b);
    }

    /** Convert a scalar JsonNode to a compact String (or null). */
    private static String toScalarString(JsonNode val) {
        if (val == null || val.isNull()) return null;
        if (val.isTextual())  return val.asText();
        if (val.isNumber())   return val.numberValue().toString();
        if (val.isBoolean())  return Boolean.toString(val.asBoolean());
        return val.asText(); // fallback
    }

    /** Build a ChangeDelta object (replaces old Map<String,Object> version). */
    private static ChangeDelta changeRecord(String path, ChangeDelta.Kind kind,
                                            JsonNode oldVal, JsonNode newVal) {
        String oldS = (oldVal != null && !oldVal.isMissingNode()) ? toScalarString(oldVal) : null;
        String newS = (newVal != null && !newVal.isMissingNode()) ? toScalarString(newVal) : null;
        return new ChangeDelta(path, oldS, newS, kind);
    }
}

