public void processChange(ObjectNode newDoc, ExecutionContext ctx) {
    final Logger log = ctx.getLogger();
    final String docId = newDoc.path("id").asText(null);

    try {
        // 1) Load tracked fields (throw if missing/error)
        List<String> tracked = loadTrackedFieldsOrThrow();

        // 2) Load snapshot (null = create; I/O/parsing error = throw)
        ObjectNode snapshot = loadSnapshotOrThrow(docId);

        // 3) CREATE path: seed baseline/latest, then return
        if (snapshot == null) {
            seedInitialSnapshotOrThrow(docId, newDoc);
            log.info("CREATE seeded for id=" + docId);
            return;
        }

        // 4) Compute delta (throw on unexpected errors)
        List<Map<String,Object>> delta = computeDelta(snapshot, newDoc, tracked);

        // 5) If no changes, exit
        if (delta.isEmpty()) {
            log.info("No tracked changes for id=" + docId);
            return;
        }

        // 6) Send to Service Bus (throw if send fails)
        sendToServiceBusOrThrow(docId, delta);

        // 7) Persist snapshot/version/tags (throw if you prefer to fail & retry)
        updateSnapshotVersionOrThrow(docId, newDoc);

    } catch (Exception e) {
        // Make retries visible and safe
        log.severe("PROCESSING FAILED for id=" + docId + ": " + e.getMessage());
        // Optional: log stacktrace
        // e.printStackTrace();
        // Rethrow to trigger retry by Functions
        throw (e instanceof RuntimeException) ? (RuntimeException) e : new RuntimeException(e);
    }
}

