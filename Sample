@startuml

' Define Controller
class AddressController {
    + searchAddress(policyId: String): ResponseEntity<AddressResponseDTO>
}

' Define Service
class AddressService {
    + searchAddress(policyId: String): AddressResponseDTO
}

' Define Repository
class AddressRepository {
    + findByPolicyId(policyId: String): Optional<Address>
}

' Define Filter
class RequestFilter {
    + doFilter(request, response, filterChain): void
}

' Define Exception Handler
class GlobalExceptionHandler {
    + handleBadRequestException(exception: BadRequestException): ResponseEntity<ErrorResponseDTO>
    + handleDataNotFoundException(exception: DataNotFoundException): ResponseEntity<ErrorResponseDTO>
}

' Define DTOs
class AddressRequestDTO <<DTO>> {
    + String street
    + String city
    + String country
    + String postalCode
}

class AddressResponseDTO <<DTO>> {
    + String id
    + String street
    + String city
    + String country
    + String postalCode
    + LocalDate effectiveDate
}

class AddressSummaryDTO <<DTO>> {
    + String id
    + String city
    + String country
}

' Define Model (Database Entity)
class Address {
    + String id
    + String street
    + String city
    + String country
    + String postalCode
    + LocalDate effectiveDate
}

' Define Enum
enum AddressType {
    HOME
    OFFICE
}

' Relationships
AddressController --> AddressService : calls
AddressService --> AddressRepository : calls
RequestFilter ..> AddressController : applies filter
GlobalExceptionHandler --> ErrorResponseDTO : returns
AddressResponseDTO --> "*" AddressSummaryDTO : contains
AddressRepository --> Address : returns data from DB
AddressResponseDTO --> Address : maps to
Address --> AddressType : uses

@enduml



