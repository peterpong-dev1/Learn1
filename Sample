public class CosmosProperties {
    private String endpoint;
    private String key;
    private String database;
    private String container;

    // Getters and Setters
}

🔹 CosmosConfig.java

@Configuration
public class CosmosConfig {

    @Bean
    public CosmosClient cosmosClient(CosmosProperties properties) {
        return new CosmosClientBuilder()
                .endpoint(properties.getEndpoint())
                .key(properties.getKey())
                .consistencyLevel(ConsistencyLevel.EVENTUAL)
                .buildClient();
    }

    @Bean
    public CosmosDatabase cosmosDatabase(CosmosClient cosmosClient, CosmosProperties properties) {
        return cosmosClient.getDatabase(properties.getDatabase());
    }

    @Bean
    public CosmosContainer cosmosContainer(CosmosDatabase cosmosDatabase, CosmosProperties properties) {
        return cosmosDatabase.getContainer(properties.getContainer());
    }
}

✔ Uses Cosmos SDK for database connections

5️⃣ Repository Layer (Uses CosmosTemplate)

🔹 FinancialInstitutionRepository.java

@Repository
public class FinancialInstitutionRepository {

    @Autowired
    private QueryConfig queryConfig;

    @Autowired
    private CosmosTemplate cosmosTemplate;

    public List<FinancialInstitution> findByFinancialInstitutionCode(String financialInstitutionCode) {
        String query = queryConfig.getQuery("fetchAllBranchesQuery");
        SqlQuerySpec querySpec = new SqlQuerySpec(query)
            .setParameters(List.of(new SqlParameter("@code", financialInstitutionCode)));

        return cosmosTemplate.find(querySpec, FinancialInstitution.class);
    }

    public List<FinancialInstitution> findByFinancialInstitutionCodeAndBranch(String financialInstitutionCode, String financialInstitutionBranchCode) {
        String query = queryConfig.getQuery("fetchOneQuery");
        SqlQuerySpec querySpec = new SqlQuerySpec(query)
            .setParameters(List.of(
                new SqlParameter("@code", financialInstitutionCode),
                new SqlParameter("@branch", financialInstitutionBranchCode)
            ));

        return cosmosTemplate.find(querySpec, FinancialInstitution.class);
    }

    public List<FinancialInstitution> findByName(String name) {
        String query = queryConfig.getQuery("fetchByNameQuery");
        SqlQuerySpec querySpec = new SqlQuerySpec(query)
            .setParameters(List.of(new SqlParameter("@name", name)));

        return cosmosTemplate.find(querySpec, FinancialInstitution.class);
    }
}

