3) Use it in your run method (no RuntimeException for non-recoverable issues)

// step 1: parse
IncomingMessage parsedMessage = null;
try {
    parsedMessage = NotificationParser.process(body, context, headers);
} catch (Exception parseEx) {
    // Non-recoverable parse error → write blob and stop
    ErrorBlobWriter.write(
        "parseFailed",
        body,
        null,
        headers,
        ERROR_CONTAINER,                  // BlobContainerClient
        context.getLogger()
    );
    return; // STOP (no throw → no retry)
}

if (parsedMessage == null) {
    // Defensive (shouldn’t happen if process throws on parse errors)
    ErrorBlobWriter.write("parseReturnedNull", body, null, headers, ERROR_CONTAINER, context.getLogger());
    return;
}

// step 1.1: validate mandatory fields
var missing = MessageValidator.validateRequired(parsedMessage);
if (!missing.isEmpty()) {
    // Non-recoverable validation failure → write blob and stop
    ErrorBlobWriter.write(
        "validationFailed: " + String.join(", ", missing),
        body,
        parsedMessage,
        headers,
        ERROR_CONTAINER,
        context.getLogger()
    );
    return; // STOP (no throw → no retry)
}


