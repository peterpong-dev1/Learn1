@startuml
skinparam packageStyle rectangle

' ========== Package Colors ==========
skinparam packageBackgroundColor Black
package "Main Class" {
    class NeoAgentSearchApplication
}

skinparam packageBackgroundColor Navy
package "Controller Layer" {
    class AgentController
}

skinparam packageBackgroundColor DarkBlue
package "Service Layer" {
    interface AgentDetailByAgentIdService
    class AgentDetailByAgentIdServiceImpl
}

skinparam packageBackgroundColor DarkOrange
package "Repository Layer" {
    class AgentRepository
}

skinparam packageBackgroundColor SaddleBrown
package "Exception Layer" {
    class GlobalExceptionHandler
    class CustomValidationException
    class CustomDataNotFoundException
    class ErrorContainerDTO
    class ErrorResponseDTO
    class ErrorDetailDTO
}

skinparam packageBackgroundColor DimGray
package "Interceptor Layer" {
    class HttpHeaderInterceptor
    interface HandlerInterceptor
}

skinparam packageBackgroundColor DarkRed
package "Spring OOTB Exceptions" {
    class RuntimeException
    class MethodArgumentNotValidException
    class HttpRequestMethodNotSupportedException
}

skinparam packageBackgroundColor DarkSlateGray
package "DTO Layer" {
    class AgentDTO
    class NameDTO
    class PhoneNumberDTO
    class EmailDTO
    class DigitalTouchpointDTO
    class SolicitorDTO
    class AgencyDTO
    class AgencyOfficeDTO
    class ErrorContainerDTO
    class ErrorDetailDTO
    class ErrorResponseDTO
}

skinparam packageBackgroundColor Brown
package "Entity Layer" {
    class AgentEntity
    class NameEntity
    class PhoneNumberEntity
    class EmailEntity
    class DigitalTouchpointEntity
    class SolicitorEntity
    class AgencyEntity
    class AgencyOfficeEntity
}

skinparam packageBackgroundColor DarkOliveGreen
package "Config Layer" {
    class CosmosDBConfig
    class KeyVaultConfig
    class LoggerConfig
    class QueryPropertyFileConfig
    class WebConfig
}

skinparam packageBackgroundColor DarkSlateBlue
package "Enum Layer" {
    class CharacterSetType
    class ContactType
    class DigitalTouchPointType
    class Gender
    class PhoneType
}

skinparam packageBackgroundColor Black
package "Utility Layer" {
    class Utils
}

' ========== Relationships ==========
NeoAgentSearchApplication --> AgentController : Initializes (Spring Boot)

' Controller relationships
AgentController -[Blue]> AgentDetailByAgentIdService : Uses
AgentController -[Blue]> AgentDTO : Returns List<AgentDTO>
AgentController -[Blue]> LoggerConfig : Logs Requests
AgentController -[Red]> GlobalExceptionHandler : Catches and Handles

' Service relationships
AgentDetailByAgentIdServiceImpl -[DarkBlue]> AgentRepository : Uses
AgentDetailByAgentIdServiceImpl -[DarkBlue]> AgentMapper : Uses (Dependency)
AgentDetailByAgentIdServiceImpl -[DarkBlue]> LoggerConfig : Logs Information
AgentDetailByAgentIdServiceImpl -[DarkBlue]> Utils : Calls Static Methods
AgentDetailByAgentIdServiceImpl -[DarkBlue]> AgentDTO : Returns List<AgentDTO>

' Repository and Mapper relationships
AgentRepository -[DarkOrange]> AgentEntity : Fetches Data
AgentMapper -[DarkOrange]> AgentDTO : Maps Entity to DTO
AgentRepository -[DarkOrange]> CosmosContainer : Uses (Dependency)
AgentRepository -[DarkOrange]> QueryPropertyFileConfig : Reads Query Config
AgentRepository -[DarkOrange]> LoggerConfig : Logs Information
AgentRepository -[DarkOrange]> CosmosDBConfig : For Connection
CosmosDBConfig -[DarkOrange]> KeyVaultConfig : Uses (Dependency)

' Interceptor relationships
HttpHeaderInterceptor -[DimGray]> AgentController : Intercepts Requests

' Global Exception relationships
GlobalExceptionHandler -[Red]> CustomDataNotFoundException : Catches
GlobalExceptionHandler -[Red]> CustomValidationException : Catches
GlobalExceptionHandler -[Red]> ErrorContainerDTO : Returns Error Details
ErrorContainerDTO -[Red]> ErrorResponseDTO : Has
ErrorResponseDTO -[Red]> ErrorDetailDTO : Uses List<ErrorDetailDTO>

' Service and Repository throwing exceptions
AgentDetailByAgentIdServiceImpl -[Red]> CustomValidationException : Throws
AgentDetailByAgentIdServiceImpl -[Red]> CustomDataNotFoundException : Throws

' DTO Relationships
AgentDTO -[Gray]> NameDTO : Uses
AgentDTO -[Gray]> PhoneNumberDTO : Uses
AgentDTO -[Gray]> EmailDTO : Uses
AgentDTO -[Gray]> DigitalTouchpointDTO : Uses
AgentDTO -[Gray]> SolicitorDTO : Uses
AgentDTO -[Gray]> AgencyDTO : Uses
AgentDTO -[Gray]> AgencyOfficeDTO : Uses

' Entity Relationships
AgentEntity -[Gray]> NameEntity : Uses
AgentEntity -[Gray]> PhoneNumberEntity : Uses
AgentEntity -[Gray]> EmailEntity : Uses
AgentEntity -[Gray]> DigitalTouchpointEntity : Uses
AgentEntity -[Gray]> SolicitorEntity : Uses
AgentEntity -[Gray]> AgencyEntity : Uses
AgentEntity -[Gray]> AgencyOfficeEntity : Uses

' Enum Relationships
CharacterSetType -[Gray]> AgentEntity : Uses
ContactType -[Gray]> AgentEntity : Uses
DigitalTouchPointType -[Gray]> AgentEntity : Uses
Gender -[Gray]> AgentEntity : Uses
PhoneType -[Gray]> AgentEntity : Uses

@enduml