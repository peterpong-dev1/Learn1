package jp.co.mycompany.servicing.service;

import jp.co.mycompany.servicing.dto.FinancialInstitutionDTO;
import jp.co.mycompany.servicing.mapper.FinancialInstitutionMapper;
import jp.co.mycompany.servicing.repository.FinancialInstitutionRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.stream.Collectors;

@Service
public class FinancialInstitutionService {

    @Autowired
    private FinancialInstitutionRepository repository;

    @Autowired
    private FinancialInstitutionMapper mapper;

    public List<FinancialInstitutionDTO> searchInstitutions(String financialInstitutionCode, 
                                                             String financialInstitutionBranchCode, 
                                                             String name) {

        if (financialInstitutionCode != null && financialInstitutionBranchCode != null) {
            return repository.findByFinancialInstitutionCodeAndBranch(financialInstitutionCode, financialInstitutionBranchCode)
                             .stream().map(mapper::toDTO).collect(Collectors.toList());
        }

        if (financialInstitutionCode != null) {
            return repository.findByFinancialInstitutionCode(financialInstitutionCode)
                             .stream().map(mapper::toDTO).collect(Collectors.toList());
        }

        if (name != null) {
            return repository.findByName(name)
                             .stream().map(mapper::toDTO).collect(Collectors.toList());
        }

        return repository.findAll().stream().map(mapper::toDTO).collect(Collectors.toList());
    }
}

