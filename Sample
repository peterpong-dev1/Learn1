package com.yourpackage.functions;

import com.microsoft.azure.functions.annotation.*;
import com.microsoft.azure.functions.*;
import com.yourpackage.service.NotificationParser;

/**
 * Azure Function that is triggered by messages from Azure Service Bus.
 */
public class ServiceBusProcessorFunction {

    /**
     * Main trigger entry point. Just calls parser and handles errors.
     */
    @FunctionName("HandleServiceBusNotification")
    public void run(
        @ServiceBusQueueTrigger(
            name = "message",
            queueName = "YOUR_QUEUE_NAME",
            connection = "AzureServiceBusConnection"
        ) String rawMessage,
        final ExecutionContext context
    ) {
        try {
            NotificationParser.process(rawMessage, context);
        } catch (Exception e) {
            context.getLogger().severe("Failed to process message: " + e.getMessage());
        }
    }
}


