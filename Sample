3) Tiny loader to read this config from Blob

You already have a “get config from blob” utility for tracked fields. Here’s a twin loader for event rules (single file per container). Put it next to your other loader:

package com.neo.notification.rules;

import com.azure.storage.blob.BlobContainerClient;
import com.azure.storage.blob.specialized.BlockBlobClient;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.io.ByteArrayOutputStream;
import java.nio.charset.StandardCharsets;
import java.util.logging.Logger;

/** Reads /{containerName}/events.json (your single config file) from the CONFIG container. */
public final class EventConfigLoader {
    private static final ObjectMapper M = new ObjectMapper();

    private EventConfigLoader() {}

    public static EventConfig loadFromBlob(BlobContainerClient configContainer,
                                           String cosmosContainerName,
                                           Logger log) throws Exception {
        String path = cosmosContainerName + "/events.json"; // adjust if your layout differs
        BlockBlobClient blob = configContainer.getBlobClient(path).getBlockBlobClient();

        if (!blob.exists()) {
            log.warning("Event rules blob not found: " + path);
            return null;
        }

        ByteArrayOutputStream out = new ByteArrayOutputStream();
        blob.download(out);
        String json = out.toString(StandardCharsets.UTF_8);

        return M.readValue(json, EventConfig.class);
    }
}

	•	If you store the file as a single global events.json instead of under the container name, just change path accordingly.

