import com.azure.storage.blob.BlobClient;
import com.azure.storage.blob.BlobContainerClient;
import com.azure.storage.blob.models.BlobStorageException;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.nio.charset.StandardCharsets;
import java.time.Instant;
import java.time.format.DateTimeFormatter;

public class IgnoredTriggerLogger {

    private static final ObjectMapper MAPPER = new ObjectMapper();

    /**
     * Logs a skipped trigger to Blob Storage in JSON format with timestamped filename.
     *
     * @param container        The blob container client.
     * @param docId            Unique document ID or trigger ID.
     * @param notificationType The notification type.
     * @param agencyId         The agency ID that caused the skip.
     * @param reason           Human-readable reason for skipping.
     */
    public static void logSkippedTrigger(
            BlobContainerClient container,
            String docId,
            String notificationType,
            String agencyId,
            String reason
    ) {
        try {
            // Generate UTC timestamp
            String timestamp = Instant.now().toString(); // e.g., 2025-08-26T12:00:00Z

            // Create JSON object
            ObjectNode logEntry = MAPPER.createObjectNode();
            logEntry.put("timestamp", timestamp);
            logEntry.put("notificationType", notificationType);
            logEntry.put("agencyId", agencyId);
            logEntry.put("reason", reason);

            // Create filename
            String fileName = docId + "_" + timestamp.replace(":", "-") + ".json";

            // Upload as blob
            BlobClient blobClient = container.getBlobClient(fileName);
            byte[] jsonBytes = MAPPER.writeValueAsString(logEntry).getBytes(StandardCharsets.UTF_8);
            blobClient.uploadBinaryContent(jsonBytes);

            System.out.println("✅ Ignored trigger logged to blob: " + fileName);

        } catch (BlobStorageException e) {
            System.err.println("❌ Blob storage error while writing skipped log: " + e.getMessage());
        } catch (Exception e) {
            System.err.println("❌ Unexpected error during skipped trigger logging: " + e.getMessage());
        }
    }
}