package jp.co.neofirst.servicing.service.impl;

import jp.co.neofirst.servicing.dto.AddressDTO;
import jp.co.neofirst.servicing.dto.AddressSearchConditionsDTO;
import jp.co.neofirst.servicing.mapper.AddressMapper;
import jp.co.neofirst.servicing.model.AddressModel;
import jp.co.neofirst.servicing.repository.AddressRepository;
import jp.co.neofirst.servicing.service.AddressService;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.stereotype.Service;
import java.util.List;
import java.util.stream.Collectors;

/**
 * Implementation of AddressService for searching addresses.
 */
@Service
public class AddressServiceImpl implements AddressService {
    
    private static final Logger logger = LoggerFactory.getLogger(AddressServiceImpl.class);

    private final AddressRepository addressRepository;
    private final AddressMapper addressMapper;

    public AddressServiceImpl(AddressRepository addressRepository, AddressMapper addressMapper) {
        this.addressRepository = addressRepository;
        this.addressMapper = addressMapper;
    }

    @Override
    public List<AddressDTO> searchAddress(AddressSearchConditionsDTO searchConditions) {
        logger.info("Searching for addresses with conditions: {}", searchConditions);
        List<AddressModel> addressModels = addressRepository.searchWithDynamicQuery(searchConditions);
        logger.info("Address search returned {} results", addressModels.size());
        return addressModels.stream().map(addressMapper::toDTO).collect(Collectors.toList());
    }
}

