What Goes Where

pom.xml

Includes dependencies for:
	•	rest-assured
	•	rest-assured-openapi
	•	junit-jupiter (JUnit 5)
	•	json-path (optional)

BaseTest.java

Sets base URI and configures the OpenApiValidationFilter.

package com.example.base;

import io.restassured.RestAssured;
import io.restassured.module.openapi.OpenApiValidationFilter;
import org.junit.jupiter.api.BeforeAll;

public class BaseTest {
    protected static OpenApiValidationFilter validationFilter;

    @BeforeAll
    public static void setUp() {
        validationFilter = new OpenApiValidationFilter("src/test/resources/api-specs/openapi.yaml");
        RestAssured.baseURI = "https://your-api.com"; // replace with your target
    }
}

UserApiTest.java

package com.example.users;

import com.example.base.BaseTest;

import static io.restassured.RestAssured.*;
import static org.hamcrest.Matchers.*;
import org.junit.jupiter.api.Test;

public class UserApiTest extends BaseTest {

    @Test
    public void testGetUser200() {
        given()
            .filter(validationFilter)
            .pathParam("id", 1)
        .when()
            .get("/user/{id}")
        .then()
            .statusCode(200);
    }

    @Test
    public void testGetUser404() {
        given()
            .filter(validationFilter)
            .pathParam("id", 9999)
        .when()
            .get("/user/{id}")
        .then()
            .statusCode(404);
    }
}

LoginApiTest.java

package com.example.login;

import com.example.base.BaseTest;
import org.junit.jupiter.api.Test;

import static io.restassured.RestAssured.*;

public class LoginApiTest extends BaseTest {

    @Test
    public void testLogin200() {
        given()
            .filter(validationFilter)
            .contentType("application/json")
            .body("{ \"username\": \"admin\", \"password\": \"password\" }")
        .when()
            .post("/login")
        .then()
            .statusCode(200);
    }

    @Test
    public void testLogin400() {
        given()
            .filter(validationFilter)
            .contentType("application/json")
            .body("{ \"username\": \"admin\" }") // missing password
        .when()
            .post("/login")
        .then()
            .statusCode(400);
    }
}

openapi.yaml

Put your OpenAPI 3.0 spec here, under src/test/resources/api-specs/.

