1) ServiceBusSenderProvider (singleton, no shutdown hook)

package com.neo.bus;

import com.azure.messaging.servicebus.*;
import java.util.Objects;

/** One shared Service Bus sender per process (thread-safe). */
public final class ServiceBusSenderProvider {
    private static final String CONN = Objects.requireNonNull(
            System.getenv("ServiceBusConnection"), "ServiceBusConnection is required");
    private static final String ENTITY = Objects.requireNonNull(
            System.getenv("ServiceBusEntity"), "ServiceBusEntity is required");

    // If you use a Topic, swap sender().queueName(...) -> sender().topicName(...)
    private static final ServiceBusSenderClient SENDER =
            new ServiceBusClientBuilder()
                    .connectionString(CONN)
                    .sender()
                    .queueName(ENTITY)
                    .buildClient();

    private ServiceBusSenderProvider() {}

    public static ServiceBusSenderClient sender() {
        return SENDER; // safe to reuse across threads
    }
}


