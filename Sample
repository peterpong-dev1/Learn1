1) Provider (cached sender, thread-safe; no synchronized)

package com.yourco.sb;

import com.azure.messaging.servicebus.ServiceBusClientBuilder;
import com.azure.messaging.servicebus.ServiceBusSenderClient;

import java.util.Map;
import java.util.Objects;
import java.util.concurrent.ConcurrentHashMap;

/** Reuses a sender per (connectionSettingName, queueName) using computeIfAbsent. */
public final class ServiceBusSenderProvider {
    private static final Map<String, ServiceBusSenderClient> CACHE = new ConcurrentHashMap<>();
    private ServiceBusSenderProvider() {}

    public static ServiceBusSenderClient get(String connectionSettingName, String queueName) {
        Objects.requireNonNull(connectionSettingName, "connectionSettingName");
        Objects.requireNonNull(queueName, "queueName");
        final String cacheKey = connectionSettingName + "::" + queueName;

        return CACHE.computeIfAbsent(cacheKey, key -> {
            String conn = System.getenv(connectionSettingName);
            if (conn == null || conn.isBlank()) {
                throw new IllegalStateException("Missing Service Bus connection setting: " + connectionSettingName);
            }
            return new ServiceBusClientBuilder()
                    .connectionString(conn)
                    .sender()
                    .queueName(queueName)
                    .buildClient();
        });
    }
}


