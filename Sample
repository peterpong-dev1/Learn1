private String appendDailyCountToMessage(
        String message,
        Map<String, Map<String, Integer>> countsByCategory,
        ExecutionContext context,
        BlobContainerClient errorContainer,
        NotificationPayLoadMessage parsedMessage) {

    ObjectMapper M = new ObjectMapper();
    try {
        JsonNode parsed = M.readTree(message);
        ObjectNode root = parsed.isObject()
                ? (ObjectNode) parsed
                : M.createObjectNode().put("raw", message);

        // dailyCountsByCategory: { "NB": {...}, "TR": {...}, "UP": {...} }
        ObjectNode byCat = M.createObjectNode();

        for (Map.Entry<String, Map<String, Integer>> cat : countsByCategory.entrySet()) {
            String category = cat.getKey();                    // e.g. "NB","TR","UP"
            Map<String, Integer> perEvent = cat.getValue();

            ObjectNode catNode = M.createObjectNode();         // { eventKey: count }
            if (perEvent != null) {
                for (Map.Entry<String, Integer> e : perEvent.entrySet()) {
                    if (e.getKey() != null && e.getValue() != null) {
                        catNode.put(e.getKey(), e.getValue());
                    }
                }
            }
            byCat.set(category, catNode);
        }

        root.set("dailyCountsByCategory", byCat);
        return M.writeValueAsString(root);

    } catch (Exception e) {
        context.getLogger().severe("Failed to append daily counts: " + e.getMessage());
        // (optional) log payload to blob...
        return message; // fall back to original message
    }
}