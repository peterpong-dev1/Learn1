import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

import com.azure.spring.data.cosmos.core.CosmosTemplate;
import com.azure.cosmos.models.SqlQuerySpec;
import com.azure.cosmos.models.SqlParameter;
import jp.co.mycompany.servicing.model.FinancialInstitution;
import jp.co.mycompany.servicing.repository.FinancialInstitutionRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import java.util.List;
import java.util.stream.Stream;

class FinancialInstitutionRepositoryTest {

    @Mock
    private CosmosTemplate cosmosTemplate;  // Mocked CosmosDB template

    @InjectMocks
    private FinancialInstitutionRepository repository;  // Repository under test

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
    }

    @Test
    void testFindByFinancialInstitutionCode_ReturnsResults() {
        // Given
        String code = "123";
        List<FinancialInstitution> expectedResults = List.of(new FinancialInstitution(code, "Bank A"));

        SqlQuerySpec querySpec = new SqlQuerySpec("SELECT * FROM c WHERE c.financialInstitutionCode = @code",
                List.of(new SqlParameter("@code", code)));

        // When
        when(cosmosTemplate.queryItems(querySpec, FinancialInstitution.class))
                .thenReturn(expectedResults.stream());

        // Then
        List<FinancialInstitution> results = repository.findByFinancialInstitutionCode(code);
        assertEquals(1, results.size());
        assertEquals("Bank A", results.get(0).getName());

        verify(cosmosTemplate, times(1)).queryItems(querySpec, FinancialInstitution.class);
    }

    @Test
    void testFindByFinancialInstitutionCode_EmptyResults() {
        // Given
        String code = "999";
        SqlQuerySpec querySpec = new SqlQuerySpec("SELECT * FROM c WHERE c.financialInstitutionCode = @code",
                List.of(new SqlParameter("@code", code)));

        // When
        when(cosmosTemplate.queryItems(querySpec, FinancialInstitution.class))
                .thenReturn(Stream.empty());

        // Then
        List<FinancialInstitution> results = repository.findByFinancialInstitutionCode(code);
        assertTrue(results.isEmpty());
        verify(cosmosTemplate, times(1)).queryItems(querySpec, FinancialInstitution.class);
    }

    @Test
    void testFindByFinancialInstitutionCodeAndBranch_ReturnsResults() {
        // Given
        String code = "123";
        String branch = "456";
        List<FinancialInstitution> expectedResults = List.of(new FinancialInstitution(code, "Bank A"));

        SqlQuerySpec querySpec = new SqlQuerySpec("SELECT * FROM c WHERE c.financialInstitutionCode = @code AND c.financialInstitutionBranchCode = @branch",
                List.of(new SqlParameter("@code", code), new SqlParameter("@branch", branch)));

        // When
        when(cosmosTemplate.queryItems(querySpec, FinancialInstitution.class))
                .thenReturn(expectedResults.stream());

        // Then
        List<FinancialInstitution> results = repository.findByFinancialInstitutionCodeAndBranch(code, branch);
        assertEquals(1, results.size());
        assertEquals("Bank A", results.get(0).getName());

        verify(cosmosTemplate, times(1)).queryItems(querySpec, FinancialInstitution.class);
    }

    @Test
    void testFindByName_ReturnsResults() {
        // Given
        String name = "Bank A";
        List<FinancialInstitution> expectedResults = List.of(new FinancialInstitution("123", name));

        SqlQuerySpec querySpec = new SqlQuerySpec("SELECT * FROM c WHERE c.name = @name",
                List.of(new SqlParameter("@name", name)));

        // When
        when(cosmosTemplate.queryItems(querySpec, FinancialInstitution.class))
                .thenReturn(expectedResults.stream());

        // Then
        List<FinancialInstitution> results = repository.findByName(name);
        assertEquals(1, results.size());
        assertEquals("Bank A", results.get(0).getName());

        verify(cosmosTemplate, times(1)).queryItems(querySpec, FinancialInstitution.class);
    }

    @Test
    void testFindByFinancialInstitutionCode_ThrowsException() {
        // Given
        String code = "123";
        SqlQuerySpec querySpec = new SqlQuerySpec("SELECT * FROM c WHERE c.financialInstitutionCode = @code",
                List.of(new SqlParameter("@code", code)));

        // When
        when(cosmosTemplate.queryItems(querySpec, FinancialInstitution.class))
                .thenThrow(new RuntimeException("Database error"));

        // Then
        Exception exception = assertThrows(RuntimeException.class, () -> repository.findByFinancialInstitutionCode(code));
        assertEquals("Database error", exception.getMessage());

        verify(cosmosTemplate, times(1)).queryItems(querySpec, FinancialInstitution.class);
    }
}

