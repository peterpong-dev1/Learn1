@startuml AgentSearch
top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam ranksep 60
skinparam nodesep 50
skinparam dpi 300
hide empty methods

' ========== Repository & Utility Layer ==========
package "Repository & Utils" {
    
    ' Keep Repository & Utility Functions at the Same Level
    AgentRepository -down-> AgentEntity : Fetches Data
    AgentRepository -down-> QueryPropertyFileConfig : Reads Query Config
    AgentRepository -down-> LoggerConfig : Logs Information
    AgentRepository -down-> CosmosDBConfig : Uses
    CosmosDBConfig -down-> KeyVaultConfig : Uses Dependency

    ' Separate Utils to Avoid Overlap
    Utils -right-> AgentRepository : Calls Static Methods
    Utils -right-> AgentDTO : Assists with Data Transformation
}

@enduml