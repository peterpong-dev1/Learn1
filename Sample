package com.yourcompany.notification;

import com.microsoft.azure.functions.annotation.*;
import com.microsoft.azure.functions.*;

import java.net.URI;
import java.net.http.*;
import java.time.Duration;
import java.util.UUID;
import java.util.logging.Logger;

/**
 * Azure Function that listens to Service Bus queue and triggers an HTTP POST request to a Notification API.
 */
public class ServiceBusTrigForNotifyApiFunction {

    // Create a reusable HttpClient with timeout settings
    private static final HttpClient httpClient = HttpClient.newBuilder()
        .connectTimeout(Duration.ofSeconds(5))
        .build();

    /**
     * Azure Function triggered by messages from Service Bus Queue
     */
    @FunctionName("SendNotificationFunction")
    public void run(
        @ServiceBusQueueTrigger(
            name = "message",
            queueName = "your-queue-name", // Replace with your actual queue name
            connection = "ServiceBusConnection" // From local.settings.json
        ) String message,
        final ExecutionContext context
    ) {
        Logger logger = context.getLogger();
        logger.info("Received Service Bus message: " + message);

        // Step 1: Prepare the POST request
        String requestId = UUID.randomUUID().toString();
        HttpRequest request;
        try {
            request = HttpRequest.newBuilder()
                .uri(new URI("http://localhost:8080/v1/common/financialInstitution")) // Replace with your endpoint
                .header("Content-Type", "application/json")
                .header("X-Request-ID", requestId)
                .POST(HttpRequest.BodyPublishers.ofString(message))
                .timeout(Duration.ofSeconds(10))
                .build();
        } catch (Exception e) {
            logger.severe("Failed to build request: " + e.getMessage());
            throw new RuntimeException(e);
        }

        // Step 2: Send the request with retry logic
        int maxRetries = 3;
        int attempt = 0;
        long backoffMillis = 1000; // Start with 1 second

        while (attempt < maxRetries) {
            try {
                attempt++;
                HttpResponse<String> response = httpClient.send(request, HttpResponse.BodyHandlers.ofString());
                int statusCode = response.statusCode();

                if (statusCode >= 200 && statusCode < 300) {
                    logger.info("Notification sent successfully. Status: " + statusCode + ". Body: " + response.body());
                    return;
                } else {
                    logger.warning("Attempt " + attempt + ": Notification failed with status " + statusCode + ". Retrying...");
                }

            } catch (Exception ex) {
                logger.warning("Attempt " + attempt + ": Exception sending request: " + ex.getMessage());
            }

            try {
                Thread.sleep(backoffMillis);
                backoffMillis *= 2; // Exponential backoff
            } catch (InterruptedException ie) {
                Thread.currentThread().interrupt();
                logger.severe("Retry interrupted");
                throw new RuntimeException("Retry interrupted", ie);
            }
        }

        logger.severe("Notification failed after " + maxRetries + " attempts.");
        throw new RuntimeException("Notification failed after retries.");
    }
}