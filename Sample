1. Updated openapi.yaml with 400 Response

Update your OpenAPI spec to define 400 responses for invalid or missing query parameters.

openapi: 3.0.1
info:
  title: Search APIs
  version: 1.0.0
paths:
  /calendar/search:
    get:
      summary: Search calendar
      parameters:
        - in: query
          name: date
          required: true
          schema:
            type: string
            format: date
      responses:
        '200':
          description: List of events
          content:
            application/json:
              schema:
                type: array
                items:
                  type: string
        '400':
          description: Invalid date input
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  /address/search:
    get:
      summary: Search address
      parameters:
        - in: query
          name: postalCode
          required: true
          schema:
            type: string
      responses:
        '200':
          description: List of addresses
          content:
            application/json:
              schema:
                type: array
                items:
                  type: object
                  properties:
                    street:
                      type: string
                    city:
                      type: string
        '400':
          description: Missing postal code
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

  /financialinstitution/search:
    get:
      summary: Search financial institutions
      parameters:
        - in: query
          name: name
          required: true
          schema:
            type: string
      responses:
        '200':
          description: List of financial institutions
          content:
            application/json:
              schema:
                type: array
                items:
                  type: object
                  properties:
                    id:
                      type: string
                    name:
                      type: string
        '400':
          description: Missing institution name
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Error'

components:
  schemas:
    Error:
      type: object
      properties:
        code:
          type: integer
        message:
          type: string



