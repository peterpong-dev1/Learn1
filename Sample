public List<YourEntity> getOffsetPage(CosmosContainer cosmosContainer, int offset, int limit) {
    String query = String.format(
        "SELECT * FROM c ORDER BY c.associationRegistrationNumber ASC OFFSET %d LIMIT %d", offset, limit
    );

    SqlQuerySpec querySpec = new SqlQuerySpec(query);
    CosmosQueryRequestOptions options = new CosmosQueryRequestOptions();

    Iterator<FeedResponse<YourEntity>> iterator = cosmosContainer
            .queryItems(querySpec, options, YourEntity.class)
            .iterableByPage()
            .iterator();

    FeedResponse<YourEntity> response = null;

    // Loop to skip empty pages (cross-partition scenario)
    while (iterator.hasNext()) {
        response = iterator.next();
        if (!response.getResults().isEmpty()) {
            break;
        }
    }

    if (response != null && !response.getResults().isEmpty()) {
        List<YourEntity> results = response.getResults();
        double ru = response.getRequestCharge();
        System.out.println("✅ Offset = " + offset + ", Limit = " + limit);
        System.out.println("🔹 RU Charge: " + ru);
        System.out.println("🔹 Records Fetched: " + results.size());
        return results;
    } else {
        System.out.println("⚠️ No results returned at this offset (even after fallback)");
        return Collections.emptyList();
    }
}