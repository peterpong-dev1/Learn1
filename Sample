✅ 1. Producer-Side Azure Function (Cosmos DB Trigger)

This function writes/update timestamp to Azure Table and forwards all messages to the Notification Queue.

ProducerFunction.java

package com.example.functions;

import com.azure.data.tables.TableClient;
import com.azure.data.tables.TableClientBuilder;
import com.azure.data.tables.models.TableEntity;
import com.azure.messaging.servicebus.*;
import com.fasterxml.jackson.databind.ObjectMapper;

import java.time.Instant;
import java.util.List;
import java.util.Map;

/**
 * Azure Function triggered by Cosmos DB Change Feed.
 * Updates Azure Table with latest timestamp and forwards message to queue.
 */
public class ProducerFunction {

    private static final String CONNECTION_STRING = System.getenv("AzureWebJobsStorage");
    private static final String TABLE_NAME = "MessageTracker";
    private static final String QUEUE_NAME = System.getenv("NOTIFICATION_QUEUE_NAME");
    private static final String SERVICE_BUS_CONNECTION = System.getenv("SERVICE_BUS_CONNECTION");

    private final TableClient tableClient;
    private final ServiceBusSenderClient senderClient;
    private final ObjectMapper mapper = new ObjectMapper();

    public ProducerFunction() {
        this.tableClient = new TableClientBuilder()
                .connectionString(CONNECTION_STRING)
                .tableName(TABLE_NAME)
                .buildClient();

        this.senderClient = new ServiceBusClientBuilder()
                .connectionString(SERVICE_BUS_CONNECTION)
                .sender()
                .queueName(QUEUE_NAME)
                .buildClient();
    }

    /**
     * Main function called for each Cosmos DB change.
     *
     * @param documents The changed documents
     */
    public void process(List<Map<String, Object>> documents) {
        for (Map<String, Object> doc : documents) {
            try {
                String docId = doc.get("docId").toString();
                String notificationType = doc.get("notificationType").toString();
                String triggerType = doc.get("triggerType").toString();
                String recipientType = doc.get("recipientType").toString();
                String timestamp = doc.get("lastUpdatedTime").toString(); // ISO format
                Instant updatedTime = Instant.parse(timestamp);

                String rowKey = notificationType + "|" + triggerType + "|" + recipientType;

                TableEntity entity = new TableEntity(docId, rowKey);
                entity.addProperty("LastUpdatedTime", updatedTime.toString());

                tableClient.upsertEntity(entity); // Upsert the entity (insert or replace)

                // Send full message to queue
                String payload = mapper.writeValueAsString(doc);
                senderClient.sendMessage(new ServiceBusMessage(payload));

            } catch (Exception e) {
                System.err.println("❌ Failed to process document: " + e.getMessage());
                e.printStackTrace();
            }
        }
    }
}


