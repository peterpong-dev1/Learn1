package service;

import com.azure.data.tables.TableClient;
import com.azure.data.tables.TableClientBuilder;
import com.azure.data.tables.models.TableEntity;
import com.azure.data.tables.models.TableServiceException;

import java.time.Instant;

public class AzureTableService {

    private final TableClient tableClient;

    public AzureTableService(String connectionString, String tableName) {
        this.tableClient = new TableClientBuilder()
                .connectionString(connectionString)
                .tableName(tableName)
                .buildClient();

        tableClient.createTableIfNotExists();
    }

    public boolean shouldProcess(String docId, String rowKey, Instant incomingTime) {
        try {
            TableEntity existing = tableClient.getEntity(docId, rowKey);
            String storedTimeStr = existing.getProperty("LastUpdatedTime").toString();
            Instant storedTime = Instant.parse(storedTimeStr);

            if (incomingTime.isAfter(storedTime)) {
                upsert(docId, rowKey, incomingTime);
                return true;
            } else {
                return false;
            }
        } catch (TableServiceException e) {
            if (e.getResponse().getStatusCode() == 404) {
                insert(docId, rowKey, incomingTime);
                return true;
            } else {
                throw e;
            }
        }
    }

    private void insert(String docId, String rowKey, Instant timestamp) {
        TableEntity entity = new TableEntity(docId, rowKey);
        entity.addProperty("LastUpdatedTime", timestamp.toString());
        tableClient.createEntity(entity);
    }

    private void upsert(String docId, String rowKey, Instant timestamp) {
        TableEntity entity = new TableEntity(docId, rowKey);
        entity.addProperty("LastUpdatedTime", timestamp.toString());
        tableClient.upsertEntity(entity);
    }
}


