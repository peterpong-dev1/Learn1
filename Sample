package entity;

import com.azure.data.tables.models.TableEntity;

public class ProcessingCheckpointEntity extends TableEntity {
    public static final String LAST_UPDATED_TIME_KEY = "LastUpdatedTime";

    public ProcessingCheckpointEntity(String partitionKey, String rowKey) {
        super(partitionKey, rowKey);
    }

    public void setLastUpdatedTime(String timestamp) {
        this.addProperty(LAST_UPDATED_TIME_KEY, timestamp);
    }

    public String getLastUpdatedTime() {
        Object value = this.getProperties().get(LAST_UPDATED_TIME_KEY);
        return value != null ? value.toString() : null;
    }
}


