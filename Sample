package com.example.calendar.dto;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@Data
@NoArgsConstructor // Required for object creation
@AllArgsConstructor // Allows full constructor initialization
public class CalenderDTO {
    private String id;
    private String calendarDay;  // Stored as `String` for `yyyy-MM-dd`
    private boolean businessDayFlag;
}

2️⃣ Updated CalenderEntity.java (Without @Builder)

Since we don’t want to use @Builder, we define a full constructor and no-args constructor for manual object creation.

package com.example.calendar.entity;

import com.azure.spring.data.cosmos.core.mapping.Container;
import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;
import org.springframework.data.annotation.Id;

@Data
@NoArgsConstructor // Required for Cosmos DB entity creation
@AllArgsConstructor // Allows constructor-based object creation
@Container(containerName = "CalendarContainer")
public class CalenderEntity {
    @Id
    private String id;
    private String calendarDay;  // Stored as String in DB
    private boolean businessDayFlag;
}

🔹 Why @NoArgsConstructor and @AllArgsConstructor?
	•	@NoArgsConstructor is needed by Cosmos DB SDK when mapping database results.
	•	@AllArgsConstructor lets us create objects easily.

3️⃣ Updated CalenderMapper.java (Without @Builder)
	•	Manually creates objects instead of using @Builder.
	•	Uses constructors to keep it readable.

package com.example.calendar.mapper;

import com.example.calendar.dto.CalenderDTO;
import com.example.calendar.entity.CalenderEntity;
import java.util.List;
import java.util.stream.Collectors;

public class CalenderMapper {

    // Convert DTO to Entity (API Request → DB Model)
    public static CalenderEntity toEntity(CalenderDTO dto) {
        return new CalenderEntity(
                dto.getId(),
                dto.getCalendarDay(),  // Keep it as String since DB stores it as a String
                dto.isBusinessDayFlag()
        );
    }

    // Convert Entity to DTO (DB Model → API Response)
    public static CalenderDTO toDTO(CalenderEntity entity) {
        return new CalenderDTO(
                entity.getId(),
                entity.getCalendarDay(), // No need for conversion
                entity.isBusinessDayFlag()
        );
    }

    // Convert List of Entities to List of DTOs
    public static List<CalenderDTO> toDTOList(List<CalenderEntity> entities) {
        return entities.stream().map(CalenderMapper::toDTO).collect(Collectors.toList());
    }
}

